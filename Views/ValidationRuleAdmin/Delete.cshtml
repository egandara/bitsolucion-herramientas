@model NotebookValidator.Web.Models.ValidationRule

@{
    ViewData["Title"] = "Eliminar Regla";
}

<style>
    body {
        background-color: #0f111a;
    }

    .card-delete {
        background-color: #161b22 !important;
        border: 1px solid #30363d;
    }

    /* Color corregido para la descripción */
    .text-description-delete {
        color: #abb2bf !important;
        font-size: 0.95rem;
    }

    .dl-audit dt {
        color: #58a6ff; /* Azul cian para los títulos de los datos */
    }

    .dl-audit dd {
        color: #ffffff;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-delete text-white border-danger shadow-lg">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar Eliminación</h4>
                </div>
                <div class="card-body p-4">
                    <p class="lead text-warning fw-bold">¿Estás seguro de que deseas eliminar esta regla de validación?</p>

                    <p class="text-description-delete">Esta acción no se puede deshacer y el motor dejará de validar este patrón inmediatamente.</p>

                    <hr class="border-secondary my-4" />

                    <dl class="row dl-audit">
                        <dt class="col-sm-4">Nombre de la Regla:</dt>
                        <dd class="col-sm-8 fw-bold">@Model.RuleName</dd>

                        <dt class="col-sm-4 mt-2">Mensaje de Detalle:</dt>
                        <dd class="col-sm-8 mt-2 text-truncate">@Model.DetailsMessage</dd>

                        <dt class="col-sm-4 mt-2">Patrón Regex:</dt>
                        <dd class="col-sm-8 mt-2">
                            <code class="text-success bg-black p-2 rounded d-inline-block border border-secondary" style="word-break: break-all;">
                                @Model.RegexPattern
                            </code>
                        </dd>

                        <dt class="col-sm-4 mt-2">Severidad:</dt>
                        <dd class="col-sm-8 mt-2">
                            <span class="badge @(Model.Severity == "Critical" ? "bg-danger" : "bg-warning text-dark")">
                                @Model.Severity
                            </span>
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-end mt-5">
                        <a asp-action="Index" class="btn btn-outline-light me-2">
                            <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                        </a>
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                <i class="bi bi-trash-fill me-1"></i> Eliminar Definitivamente
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

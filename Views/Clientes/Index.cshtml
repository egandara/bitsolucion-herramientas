@model IEnumerable<NotebookValidator.Web.Models.GestorProyectos.Cliente>
@using NotebookValidator.Web.Models.GestorProyectos
@{
    ViewData["Title"] = "Mantenedor de Empresas";
}

<div class="container-fluid dashboard-xl-container mt-3" style="max-width: 950px !important;">
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h4 fw-bold mb-0 text-white" style="font-family: 'Poppins', sans-serif;">Gestión de Empresas / Clientes</h1>
            <p class="mb-0 small text-white-50">Administra las empresas para la creación de carpetas corporativas.</p>
        </div>
        <a asp-controller="Clientes" asp-action="Catalogo" class="btn btn-success fw-bold btn-sm px-3">
            <i class="bi bi-database-gear me-2"></i>Catálogo Corporativo de Linaje
        </a>
    </div>

    <div class="card p-4 border-0 mb-4" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-white small fw-bold mb-1">Nombre de la Empresa</label>
                    <input type="text" name="nombre" class="form-control bg-dark text-white border-secondary font-monospace" placeholder="Ej: BANCO BCI" required autocomplete="off" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-info small fw-bold mb-1"><i class="bi bi-clock me-1"></i>Entrada</label>
                    <input type="time" name="horaEntrada" class="form-control bg-dark text-white border-secondary text-center" value="09:00" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-warning small fw-bold mb-1"><i class="bi bi-clock-history me-1"></i>Salida (L-J)</label>
                    <input type="time" name="horaSalidaNormal" class="form-control bg-dark text-white border-secondary text-center" value="18:00" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-success small fw-bold mb-1"><i class="bi bi-calendar-check me-1"></i>Salida (Vie)</label>
                    <input type="time" name="horaSalidaViernes" class="form-control bg-dark text-white border-secondary text-center" value="16:00" required />
                </div>
                <div class="col-md-3 text-end">
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-plus-circle me-1"></i> Agregar Cliente
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="card p-0 border-0 overflow-hidden" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead style="background-color: #111424;">
                <tr>
                    <th class="ps-4 border-secondary text-white-50 small" style="width: 8%;">ID</th>
                    <th class="border-secondary text-white-50 small" style="width: 35%;">Nombre de la Empresa</th>
                    <th class="border-secondary text-white-50 small text-center" style="width: 20%;">Horario Laboral</th>
                    <th class="border-secondary text-white-50 small text-center" style="width: 12%;">Estado</th>
                    <th class="pe-4 border-secondary text-white-50 small text-end" style="width: 25%;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-white-50">No hay clientes registrados en el sistema.</td>
                    </tr>
                }
                else
                {
                    @foreach (var cliente in Model)
                    {
                        <tr style="background-color: #0b0d16;">
                            <td class="ps-4 text-secondary font-monospace small">#@cliente.Id</td>
                            <td class="fw-bold text-white">@cliente.Nombre</td>
                            <td class="text-center font-monospace text-white-50" style="font-size: 0.75rem;">
                                <i class="bi bi-clock text-info me-1"></i>@cliente.HoraEntrada.ToString(@"hh\:mm") - @cliente.HoraSalidaNormal.ToString(@"hh\:mm")<br />
                                <span class="text-success" style="font-size: 0.65rem;">(Viernes: @cliente.HoraSalidaViernes.ToString(@"hh\:mm"))</span>
                            </td>
                            <td class="text-center">
                                @if (cliente.Activo)
                                {
                                    <span class="badge bg-success" style="font-size: 0.7rem;">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger" style="font-size: 0.7rem;">Inactivo</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-warning" title="Editar Cliente"
                                            onclick="abrirModalEditar(@cliente.Id, '@cliente.Nombre', '@cliente.HoraEntrada.ToString(@"hh\:mm")', '@cliente.HoraSalidaNormal.ToString(@"hh\:mm")', '@cliente.HoraSalidaViernes.ToString(@"hh\:mm")')">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </button>

                                    <form asp-action="ToggleStatus" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@cliente.Id" />
                                        @if (cliente.Activo)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Activar">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalEditarCliente" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background-color: #0b0d16; border: 1px solid #ffc107;">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editClienteId" />

                <div class="modal-header border-secondary p-3">
                    <h6 class="modal-title fw-bold text-warning"><i class="bi bi-pencil-square me-2"></i>Editar Cliente</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4" style="background-color: #07091e;">
                    <div class="mb-3">
                        <label class="form-label text-white-50 small fw-bold mb-1">Nombre de la Empresa</label>
                        <input type="text" name="nombre" id="editNombre" class="form-control bg-dark text-white border-secondary font-monospace" required autocomplete="off" />
                    </div>
                    <div class="row g-2">
                        <div class="col-4">
                            <label class="form-label text-info small fw-bold mb-1">Entrada</label>
                            <input type="time" name="horaEntrada" id="editEntrada" class="form-control bg-dark text-white border-secondary text-center" required />
                        </div>
                        <div class="col-4">
                            <label class="form-label text-warning small fw-bold mb-1">Salida (L-J)</label>
                            <input type="time" name="horaSalidaNormal" id="editSalidaL" class="form-control bg-dark text-white border-secondary text-center" required />
                        </div>
                        <div class="col-4">
                            <label class="form-label text-success small fw-bold mb-1">Salida (Vie)</label>
                            <input type="time" name="horaSalidaViernes" id="editSalidaV" class="form-control bg-dark text-white border-secondary text-center" required />
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-secondary p-2">
                    <button type="button" class="btn btn-sm btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-sm btn-warning fw-bold text-dark"><i class="bi bi-save me-1"></i> Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModalEditar(id, nombre, entrada, salidaN, salidaV) {
            document.getElementById('editClienteId').value = id;
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editEntrada').value = entrada;
            document.getElementById('editSalidaL').value = salidaN;
            document.getElementById('editSalidaV').value = salidaV;

            var modal = new bootstrap.Modal(document.getElementById('modalEditarCliente'));
            modal.show();
        }
    </script>
}

@model NotebookValidator.Web.Models.MapeoColumnasViewModel
@{
    ViewData["Title"] = "Configurar Mapeo";
}

<style>
    /* STEPPER MODERNO Y ELEGANTE */
    .stepper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 50px;
        position: relative;
        padding: 0 10%;
    }

        .stepper::before {
            content: "";
            position: absolute;
            top: 22px;
            left: 10%;
            width: 80%;
            height: 3px;
            background: rgba(255, 255, 255, 0.1);
            z-index: 1;
            border-radius: 5px;
        }

    .step {
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent !important;
        width: 120px;
    }

    .step-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #1e293b;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        font-weight: bold;
        font-size: 1.2rem;
        border: 6px solid #0f172a;
        transition: all 0.3s ease;
    }

    .step-label {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

    .step.completed .step-circle {
        background: #198754;
        color: white;
        border-color: #0f172a;
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.3);
    }

    .step.completed .step-label {
        color: #198754;
    }

    .step.active .step-circle {
        background: #ffc107;
        color: #000;
        border-color: #0f172a;
        box-shadow: 0 0 20px rgba(255, 193, 7, 0.4);
        transform: scale(1.15);
    }

    .step.active .step-label {
        color: #ffc107;
        text-shadow: 0 0 10px rgba(255, 193, 7, 0.3);
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #495057;
        border-radius: 10px;
    }

    #loadingOverlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.85);
        z-index: 10000;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
    }
</style>

<div class="container py-4">
    <div class="stepper mb-5">
        <div class="step completed"><div class="step-circle"><i class="bi bi-check-lg"></i></div><div class="step-label">Carga</div></div>
        <div class="step active"><div class="step-circle">2</div><div class="step-label">Mapeo</div></div>
        <div class="step"><div class="step-circle">3</div><div class="step-label">Resultados</div></div>
    </div>

    <form asp-action="EjecutarCuadratura" method="post" id="formCuadratura">
        @Html.HiddenFor(m => m.TempPathArchivo1)
        @Html.HiddenFor(m => m.TempPathArchivo2)
        <input type="hidden" name="TieneEncabezados1" value="@Model.TieneEncabezados1.ToString().ToLower()" />
        <input type="hidden" name="TieneEncabezados2" value="@Model.TieneEncabezados2.ToString().ToLower()" />
        @Html.HiddenFor(m => m.AliasArchivo1)
        @Html.HiddenFor(m => m.AliasArchivo2)

        <div class="card bg-dark border-secondary mb-4 shadow-sm">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-white"><i class="bi bi-key-fill text-warning me-2"></i>Definición de Llaves Primarias</h5>
                <button type="button" id="btnAutoMap" class="btn btn-warning btn-sm fw-bold text-dark"><i class="bi bi-magic"></i> Auto-Enlazar</button>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="text-white small fw-bold">Columnas en @Model.AliasArchivo1</label>
                            <button type="button" class="btn btn-link btn-sm text-info p-0" onclick="preview('@Model.TempPathArchivo1.Replace("\\", "\\\\")', @Model.TieneEncabezados1.ToString().ToLower())"><i class="bi bi-eye"></i> Ver muestra</button>
                        </div>
                        <div class="border border-secondary rounded p-3 custom-scrollbar" style="max-height: 250px; overflow-y:auto; background: #0f172a;">
                            @foreach (var col in Model.ColumnasArchivo1)
                            {
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input key-checkbox-1" type="checkbox" name="LlaveArchivo1" value="@col" id="L1_@col.Replace(" ", "_")">
                                    <label class="form-check-label text-white small" style="cursor:pointer;" for="L1_@col.Replace(" ", "_")">@col</label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="text-white small fw-bold">Columnas en @Model.AliasArchivo2</label>
                            <button type="button" class="btn btn-link btn-sm text-info p-0" onclick="preview('@Model.TempPathArchivo2.Replace("\\", "\\\\")', @Model.TieneEncabezados2.ToString().ToLower())"><i class="bi bi-eye"></i> Ver muestra</button>
                        </div>
                        <div class="border border-secondary rounded p-3 custom-scrollbar" style="max-height: 250px; overflow-y:auto; background: #0f172a;">
                            @foreach (var col in Model.ColumnasArchivo2)
                            {
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input key-checkbox-2" type="checkbox" name="LlaveArchivo2" value="@col" id="L2_@col.Replace(" ", "_")">
                                    <label class="form-check-label text-white small" style="cursor:pointer;" for="L2_@col.Replace(" ", "_")">@col</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card bg-dark border-secondary mb-4 shadow-sm">
            <div class="card-header border-secondary">
                <h5 class="mb-0 text-white">Columnas a Comparar</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle" id="tablaMapeo">
                        <thead>
                            <tr class="text-muted small">
                                <th>Columna @Model.AliasArchivo1</th>
                                <th>Columna @Model.AliasArchivo2</th>
                                <th>Tolerancia (Opc.)</th>
                                <th class="text-center">Quitar</th>
                            </tr>
                        </thead>
                        <tbody id="mapeoBody">
                            @foreach (var sug in Model.Sugerencias)
                            {
                                <tr>
                                    <td>
                                        <select name="ColsComparar1" class="form-select bg-dark text-white border-secondary">
                                            <option value="">-- Ignorar --</option>
                                            @foreach (var c in Model.ColumnasArchivo1)
                                            {
                                                <option value="@c" selected="@(c == sug.ColumnaArchivo1)">@c</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select name="ColsComparar2" class="form-select bg-dark text-white border-secondary">
                                            <option value="">-- Ignorar --</option>
                                            @foreach (var c in Model.ColumnasArchivo2)
                                            {
                                                <option value="@c" selected="@(c == sug.ColumnaArchivo2)">@c</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input type="number" step="any" name="Tolerancias" class="form-control bg-dark text-white border-secondary custom-placeholder" placeholder="Ej: 0.01" /></td>
                                    <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm rounded-circle" onclick="this.closest('tr').remove()"><i class="bi bi-trash"></i></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-outline-info btn-sm mt-2" onclick="agregarFila()">+ Añadir columna a comparar</button>
            </div>
        </div>

        <div class="card bg-dark border-info mb-4 shadow-sm">
            <div class="card-body">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="ModoAgrupacion" value="true" id="swAgrup">
                    <label class="form-check-label text-info fw-bold" for="swAgrup"><i class="bi bi-layers me-1"></i> MODO AGRUPACIÓN (SUMARIZAR)</label>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning text-dark font-weight-bold btn-lg">Ejecutar Cuadratura Final <i class="bi bi-play-circle ms-2"></i></button>
            <a asp-action="Index" class="btn btn-outline-light ms-2 btn-lg">Cancelar</a>
        </div>
    </form>
</div>

<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white">Muestra de datos (Primeros 5 registros)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive"><table class="table table-dark table-sm mb-0 small" id="previewTable"><thead id="previewHead"></thead><tbody id="previewBody"></tbody></table></div>
            </div>
        </div>
    </div>
</div>

<div id="loadingOverlay"><div class="spinner-border text-warning mb-3" style="width: 4rem; height: 4rem;"></div><h3 class="text-white fw-bold">Cruzando Registros...</h3></div>

<script>
    function preview(path, headers) {
        fetch('@Url.Action("ObtenerPrevisualizacion", "Cuadratura")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `tempPath=${encodeURIComponent(path)}&tieneEncabezados=${headers}`
        })
        .then(r => r.json()).then(data => {
            document.getElementById('previewHead').innerHTML = '<tr>' + data.headers.map(h => `<th>${h}</th>`).join('') + '</tr>';
            document.getElementById('previewBody').innerHTML = data.rows.map(r => '<tr>' + r.map(c => `<td>${c}</td>`).join('') + '</tr>').join('');
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }).catch(err => {
            toastr.error("Error al obtener la previsualización del archivo.");
            console.error(err);
        });
    }

    function agregarFila() {
        const body = document.getElementById('mapeoBody');
        const row = body.rows[0].cloneNode(true);
        row.querySelectorAll('select').forEach(s => s.value = "");
        row.querySelector('input').value = "";
        body.appendChild(row);
    }

    document.getElementById("btnAutoMap").addEventListener("click", function() {
        const checkboxes1 = document.querySelectorAll('.key-checkbox-1');
        const checkboxes2 = document.querySelectorAll('.key-checkbox-2');
        const columnasEnComparacion = new Set();
        document.querySelectorAll('#mapeoBody select').forEach(sel => { if (sel.value) columnasEnComparacion.add(sel.value.toLowerCase()); });

        checkboxes1.forEach(chk => chk.checked = false); checkboxes2.forEach(chk => chk.checked = false);
        let matchCount = 0; let skippedCount = 0;

        checkboxes1.forEach(chk1 => {
            const valLower = chk1.value.toLowerCase();
            const chk2 = Array.from(checkboxes2).find(c => c.value.toLowerCase() === valLower);
            if (chk2) {
                if (!columnasEnComparacion.has(valLower)) { chk1.checked = true; chk2.checked = true; matchCount++; }
                else { skippedCount++; }
            }
        });

        if(matchCount > 0) toastr.success(`Se enlazaron ${matchCount} llaves.`, "Mapeo Exitoso");
        else toastr.warning("No se encontraron llaves nuevas.", "Sin coincidencias");
    });

    document.getElementById('formCuadratura').addEventListener('submit', function (e) {
        if (document.querySelectorAll('.key-checkbox-1:checked').length === 0 || document.querySelectorAll('.key-checkbox-2:checked').length === 0) {
            e.preventDefault(); toastr.error("Debes seleccionar al menos una llave primaria en cada archivo."); return false;
        }
        document.getElementById('loadingOverlay').style.display = 'flex';
    });
</script>

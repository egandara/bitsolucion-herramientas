@model NotebookValidator.Web.Models.ResultadoCuadratura
@using System.Text.Json
@using System.Linq
@using System
@{
    ViewData["Title"] = "Resultados de Cuadratura";

    int totalCuadrados = Model.TotalCoincidenciasExactas;
    int totalDiferencias = Model.RegistrosConDiferencias.Select(d => d.LlaveIdentificadora).Distinct().Count();
    int totalHuerfanos = Model.HuerfanosArchivo1.Count + Model.HuerfanosArchivo2.Count;
    int totalRegistros = totalCuadrados + totalDiferencias + totalHuerfanos;

    double pctCuadrados = totalRegistros > 0 ? Math.Round((double)totalCuadrados / totalRegistros * 100, 2) : 0;
    double pctDiferencias = totalRegistros > 0 ? Math.Round((double)totalDiferencias / totalRegistros * 100, 2) : 0;
    double pctHuerfanos = totalRegistros > 0 ? Math.Round((double)totalHuerfanos / totalRegistros * 100, 2) : 0;

    var diferenciasAgrupadas = Model.RegistrosConDiferencias
        .GroupBy(d => d.ColumnaConFalla)
        .OrderByDescending(g => g.Count())
        .ToList();
}

<style>
    .accordion-button {
        background-color: #212529 !important;
        color: #ffc107 !important;
        border-bottom: 1px solid #495057;
    }

        .accordion-button:not(.collapsed) {
            background-color: #343a40 !important;
            box-shadow: none;
        }

        .accordion-button::after {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

    .accordion-item {
        border-color: #495057;
    }

    .dataTables_wrapper .dataTables_length select,
    .dataTables_wrapper .dataTables_filter input {
        background-color: #212529;
        color: #fff;
        border: 1px solid #495057;
    }

    .dataTables_wrapper .dataTables_paginate .pagination .page-link {
        background-color: #212529;
        border-color: #495057;
        color: #fff;
    }

    .dataTables_wrapper .dataTables_paginate .pagination .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    .dataTables_wrapper .dataTables_paginate .pagination .page-item.disabled .page-link {
        color: #6c757d;
        background-color: #212529;
        border-color: #495057;
    }

    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_length label,
    .dataTables_wrapper .dataTables_filter label {
        color: #adb5bd !important;
        margin-bottom: 10px;
        margin-top: 10px;
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Resultados de la Validación</h2>

        <div class="d-flex">
            <form asp-action="ExportarExcel" method="post">
                <input type="hidden" name="jsonResultado" value='@JsonSerializer.Serialize(Model)' />
                <button type="submit" class="btn btn-success me-2 fw-bold">
                    <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
                </button>
            </form>
            <a asp-action="Index" class="btn btn-primary fw-bold">Nueva Cuadratura</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-5">
            <div class="card bg-dark border-light h-100">
                <div class="card-header border-light text-white font-weight-bold">Distribución de Cuadratura</div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                    <div style="position: relative; width: 100%; max-width: 280px;">
                        <canvas id="graficoCuadratura"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="row h-100">
                <div class="col-12 mb-3">
                    <div class="card h-100 border-0" style="background-color: #198754; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                        <div class="card-body d-flex align-items-center justify-content-between text-white">
                            <div>
                                <h3 class="display-5 fw-bold mb-0">@totalCuadrados</h3>
                                <p class="mb-0 fw-bold" style="color: #ffffff !important;">Registros cuadrados exactos</p>
                            </div>
                            <h2 class="fw-bold">@pctCuadrados%</h2>
                        </div>
                    </div>
                </div>
                <div class="col-12 mb-3">
                    <div class="card h-100 border-0" style="background-color: #ffc107; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                        <div class="card-body d-flex align-items-center justify-content-between text-dark">
                            <div>
                                <h3 class="display-5 fw-bold mb-0">@totalDiferencias</h3>
                                <p class="mb-0 fw-bold" style="color: #000000 !important;">Match de llave con diferencias</p>
                            </div>
                            <h2 class="fw-bold">@pctDiferencias%</h2>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card h-100 border-0" style="background-color: #dc3545; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                        <div class="card-body d-flex align-items-center justify-content-between text-white">
                            <div>
                                <h3 class="display-5 fw-bold mb-0">@totalHuerfanos</h3>
                                <p class="mb-0 fw-bold" style="color: #ffffff !important;">Registros huérfanos</p>
                            </div>
                            <h2 class="fw-bold">@pctHuerfanos%</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.RegistrosConDiferencias.Any())
    {
        <div class="mb-3 p-3 bg-dark border border-warning rounded shadow-sm">
            <span class="text-white fw-bold me-3"><i class="fas fa-exclamation-triangle text-warning"></i> Campos con diferencias:</span>
            @foreach (var grupo in diferenciasAgrupadas)
            {
                <span class="badge bg-warning text-dark fs-6 me-2 mb-1 shadow-sm">
                    @grupo.Key <span class="badge bg-dark text-white ms-1">@grupo.Count()</span>
                </span>
            }
        </div>

        <div class="mb-3 p-3 bg-dark border border-info rounded shadow-sm d-flex align-items-center flex-wrap">
            <label class="text-white fw-bold me-3"><i class="fas fa-filter text-info"></i> Ocultar diferencias menores o iguales a:</label>
            <input type="number" id="globalTolerance" class="form-control bg-dark text-info border-info me-3 fw-bold" style="max-width: 150px;" step="any" placeholder="Ej: 0.5" />
            <span class="text-light small mt-2 mt-md-0">Escribe un valor y las tablas se limpiarán en tiempo real.</span>
        </div>

        <div class="mb-4">
            <button class="btn btn-warning w-100 mb-2 fw-bold text-dark shadow-sm collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDiferencias">
                <i class="fas fa-list"></i> Ver Detalle de Diferencias Agrupadas por Campo
            </button>

            <div class="collapse" id="collapseDiferencias">
                <div class="card bg-dark border-warning shadow">
                    <div class="card-body p-3">

                        <div class="accordion accordion-flush" id="accordionDiferencias">
                            @{
                                int index = 0;
                            }
                            @foreach (var grupo in diferenciasAgrupadas)
                            {
                                string headingId = $"heading_{index}";
                                string collapseId = $"collapse_{index}";

                                // CÁLCULOS ANALÍTICOS (RESUMEN ESTADÍSTICO)
                                double sumaDiferencias = grupo.Sum(d => d.DiferenciaNumerica ?? 0);
                                double impactoAbsoluto = grupo.Sum(d => Math.Abs(d.DiferenciaNumerica ?? 0));

                                <div class="accordion-item bg-dark mb-2 rounded">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button collapsed fw-bold fs-5" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                            <div class="d-flex w-100 align-items-center me-3 flex-wrap">
                                                <div style="flex: 1; min-width: 200px;" class="text-start text-warning">
                                                    @grupo.Key
                                                </div>

                                                <div style="flex: 2; text-align: center;" class="d-none d-lg-block">
                                                    <span class="badge bg-secondary me-2 p-2" title="Suma matemática (los positivos anulan los negativos)">Suma Neta: @sumaDiferencias.ToString("N2")</span>
                                                    <span class="badge border border-danger text-danger p-2" title="Impacto real contable (suma del valor absoluto de todos los errores)">Riesgo Absoluto: @impactoAbsoluto.ToString("N2")</span>
                                                </div>

                                                <div style="flex: 1;" class="text-end">
                                                    <span class="badge bg-danger">@grupo.Count() Errores (Bruto)</span>
                                                </div>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#accordionDiferencias">
                                        <div class="accordion-body p-3">
                                            <table class="table table-dark table-striped table-sm mb-0 table-diferencias w-100">
                                                <thead>
                                                    <tr class="text-warning border-bottom border-warning">
                                                        <th class="ps-3">Llave Primaria</th>
                                                        <th class="text-end">@Model.AliasArchivo1</th>
                                                        <th class="text-end">@Model.AliasArchivo2</th>
                                                        <th class="text-end pe-3">Diferencia</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var dif in grupo)
                                                    {
                                                        // Guardamos el data-diff para el filtro JavaScript
                                                        string diffValue = (dif.DiferenciaNumerica ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
                                                        <tr data-diff="@diffValue">
                                                            <td class="ps-3"><span class="badge bg-secondary">@dif.LlaveIdentificadora</span></td>
                                                            <td class="text-end">@dif.ValorArchivo1</td>
                                                            <td class="text-end">@dif.ValorArchivo2</td>
                                                            <td class="text-end fw-bold text-warning pe-3">@dif.Diferencia</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                index++;
                            }
                        </div>

                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.HuerfanosArchivo1.Any() || Model.HuerfanosArchivo2.Any())
    {
        <div class="row">
            @if (Model.HuerfanosArchivo1.Any())
            {
                <div class="col-md-6">
                    <div class="card bg-dark border-danger mb-4 shadow">
                        <div class="card-header border-danger text-danger fw-bold">Sólo en @Model.AliasArchivo1 (@Model.HuerfanosArchivo1.Count)</div>
                        <div class="card-body p-3">
                            <table class="table table-dark table-striped table-sm w-100 table-huerfanos">
                                <thead><tr class="text-danger"><th>Llave Primaria</th></tr></thead>
                                <tbody>@foreach(var h in Model.HuerfanosArchivo1){
                                <tr><td>@h</td></tr>
                            }
    </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        @if (Model.HuerfanosArchivo2.Any())
        {
            <div class="col-md-6">
                <div class="card bg-dark border-danger mb-4 shadow">
                    <div class="card-header border-danger text-danger fw-bold">Sólo en @Model.AliasArchivo2 (@Model.HuerfanosArchivo2.Count)</div>
                    <div class="card-body p-3">
                        <table class="table table-dark table-striped table-sm w-100 table-huerfanos">
                            <thead><tr class="text-danger"><th>Llave Primaria</th></tr></thead>
                            <tbody>@foreach(var h in Model.HuerfanosArchivo2){
                            <tr><td>@h</td></tr>
                        }
</tbody>
                    </table>
                </div>
            </div>
        </div>
                }
    </div>
        }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // 1. Gráfico
            const ctx = document.getElementById('graficoCuadratura').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Cuadrados', 'Diferencias', 'Huérfanos'],
                    datasets: [{
                        data: [@totalCuadrados, @totalDiferencias, @totalHuerfanos],
                        backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                        hoverOffset: 15,
                        borderWidth: 0,
                        cutout: '70%'
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { color: '#fff', padding: 20, font: { size: 12, weight: 'bold' } } } }
                }
            });

            // 2. DataTables API
            const dataTableOptions = {
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10, lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                ordering: true, searching: true, info: true
            };

            $('.table-diferencias').DataTable(dataTableOptions);
            $('.table-huerfanos').DataTable(dataTableOptions);

            $('#accordionDiferencias').on('shown.bs.collapse', function () {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });

            // 3. LOGICA DEL FILTRO DINÁMICO DE TOLERANCIA
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex, rowData, counter) {
                    // Si no es una tabla de diferencias, no aplica el filtro
                    if (!settings.nTable.classList.contains('table-diferencias')) return true;

                    let tolStr = $('#globalTolerance').val();
                    if (!tolStr) return true; // Si está en blanco, mostrar todo

                    let tol = parseFloat(tolStr);
                    if (isNaN(tol)) return true;

                    // Capturamos el data-diff crudo de la fila HTML
                    let tr = settings.aoData[dataIndex].nTr;
                    let diffStr = tr.getAttribute('data-diff');
                    if (!diffStr) return true;

                    // Convertimos la diferencia absoluta (sin importar el signo)
                    let diff = Math.abs(parseFloat(diffStr));

                    // Solo mostramos la fila si la diferencia es MAYOR que la tolerancia escrita
                    return diff > tol;
                }
            );

            // Redibujar las tablas cada vez que el usuario escriba en el filtro
            $('#globalTolerance').on('keyup change', function() {
                $('.table-diferencias').DataTable().draw();
            });

        });
    </script>
}

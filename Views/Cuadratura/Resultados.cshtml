@model NotebookValidator.Web.Models.ResultadoCuadratura
@using System.Text.Json
@using System.Linq
@using System
@{
    ViewData["Title"] = "Resultados Finales";
    int totalCuadrados = Model.TotalCoincidenciasExactas;
    int totalDiferencias = Model.RegistrosConDiferencias.Select(d => d.LlaveIdentificadora).Distinct().Count();
    int totalHuerfanos = Model.HuerfanosArchivo1.Count + Model.HuerfanosArchivo2.Count;
    int total = totalCuadrados + totalDiferencias + totalHuerfanos;

    double pctCuadrados = total > 0 ? Math.Round((double)totalCuadrados / total * 100, 2) : 0;
    double pctDiferencias = total > 0 ? Math.Round((double)totalDiferencias / total * 100, 2) : 0;
    double pctHuerfanos = total > 0 ? Math.Round((double)totalHuerfanos / total * 100, 2) : 0;

    var diferenciasAgrupadas = Model.RegistrosConDiferencias
        .GroupBy(d => d.ColumnaConFalla)
        .OrderByDescending(g => g.Count())
        .ToList();
}

<style>
    /* Estilos Stepper y Dashboard */
    .stepper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 50px;
        position: relative;
        padding: 0 10%;
    }

        .stepper::before {
            content: "";
            position: absolute;
            top: 22px;
            left: 10%;
            width: 80%;
            height: 3px;
            background: rgba(255, 255, 255, 0.1);
            z-index: 1;
            border-radius: 5px;
        }

    .step {
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent !important;
        width: 120px;
    }

    .step-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #1e293b;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        font-weight: bold;
        font-size: 1.2rem;
        border: 6px solid #0f172a;
        transition: all 0.3s ease;
    }

    .step-label {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

    .step.completed .step-circle {
        background: #198754;
        color: white;
        border-color: #0f172a;
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.3);
    }

    .step.completed .step-label {
        color: #198754;
    }

    .step.active .step-circle {
        background: #ffc107;
        color: #000;
        border-color: #0f172a;
        box-shadow: 0 0 20px rgba(255, 193, 7, 0.4);
        transform: scale(1.15);
    }

    .step.active .step-label {
        color: #ffc107;
        text-shadow: 0 0 10px rgba(255, 193, 7, 0.3);
    }

    .nav-tabs {
        border-bottom: 1px solid #495057;
    }

        .nav-tabs .nav-link {
            color: #adb5bd !important;
            font-weight: 600;
            background-color: transparent !important;
            border: transparent !important;
        }

            .nav-tabs .nav-link:hover {
                color: white !important;
            }

            .nav-tabs .nav-link.active {
                background-color: #1a1d20 !important;
                color: #ffc107 !important;
                border-color: #495057 #495057 transparent !important;
                border-bottom: 2px solid #ffc107 !important;
            }

    .accordion-button {
        background-color: #212529 !important;
        color: white !important;
        font-weight: bold;
    }

        .accordion-button:not(.collapsed) {
            background-color: #2c3034 !important;
            color: #ffc107 !important;
            box-shadow: none;
            border-bottom: 1px solid #495057;
        }

        .accordion-button::after {
            filter: invert(1);
        }

    .stat-bar {
        border-radius: 6px;
        padding: 15px 25px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .stat-bar-green {
        background-color: #198754;
    }

    .stat-bar-yellow {
        background-color: #ffc107;
        color: #ffffff;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    }

    .stat-bar-red {
        background-color: #dc3545;
    }

    .stat-bar-left h2 {
        margin: 0;
        font-weight: 900;
        font-size: 2.2rem;
    }

    .stat-bar-left span {
        font-size: 0.9rem;
        font-weight: 600;
        opacity: 0.9;
    }

    .stat-bar-right h2 {
        margin: 0;
        font-weight: 900;
        font-size: 2rem;
    }

    .badge-diferencia {
        background-color: #ffc107;
        color: #000;
        font-weight: bold;
        font-size: 0.95rem;
        border-radius: 6px;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* NUEVO BADGE: Etiqueta color Cyan para la agrupación */
    .badge-agrupacion {
        background-color: #0dcaf0;
        color: #000;
        font-weight: bold;
        font-size: 0.95rem;
        border-radius: 6px;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .custom-placeholder::placeholder {
        color: #adb5bd !important;
        opacity: 1;
        font-weight: normal;
    }
</style>

<div class="container-fluid py-4">
    <div class="stepper mb-5">
        <div class="step completed"><div class="step-circle"><i class="bi bi-check-lg"></i></div><div class="step-label">Carga</div></div>
        <div class="step completed"><div class="step-circle"><i class="bi bi-check-lg"></i></div><div class="step-label">Mapeo</div></div>
        <div class="step active"><div class="step-circle">3</div><div class="step-label">Resultados</div></div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="bi bi-file-earmark-bar-graph me-2 text-warning"></i>Informe de Validación</h2>
        <div class="d-flex gap-2">
            <form asp-action="ExportarExcel" method="post">
                <input type="hidden" name="exportId" value="@ViewBag.ExportId" />
                <button type="submit" class="btn btn-success fw-bold"><i class="bi bi-file-excel me-1"></i> Exportar</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-warning fw-bold">Nuevo Proceso</a>
        </div>
    </div>

    @if (Model.EsModoAgrupacion)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card bg-dark border-info text-info">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-layers me-2"></i> <strong>@Model.AliasArchivo1:</strong> @Model.TotalOriginal1 registros resumidos en <strong>@Model.TotalAgrupado1</strong></span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-dark border-info text-info">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-layers me-2"></i> <strong>@Model.AliasArchivo2:</strong> @Model.TotalOriginal2 registros resumidos en <strong>@Model.TotalAgrupado2</strong></span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-5">
            <div class="card bg-dark border-secondary h-100 shadow-sm">
                <div class="card-header border-secondary text-white small">Distribución de Cuadratura</div>
                <div class="card-body d-flex justify-content-center align-items-center" style="min-height: 250px;">
                    <canvas id="chartResultados" style="max-height: 200px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-7 d-flex flex-column justify-content-between">
            <div class="stat-bar stat-bar-green flex-grow-1">
                <div class="stat-bar-left"><h2>@totalCuadrados</h2><span>Registros cuadrados exactos</span></div>
                <div class="stat-bar-right"><h2>@pctCuadrados.ToString("0.##")%</h2></div>
            </div>
            <div class="stat-bar stat-bar-yellow flex-grow-1">
                <div class="stat-bar-left"><h2>@totalDiferencias</h2><span>Match de llave con diferencias</span></div>
                <div class="stat-bar-right"><h2>@pctDiferencias.ToString("0.##")%</h2></div>
            </div>
            <div class="stat-bar stat-bar-red flex-grow-1 mb-0">
                <div class="stat-bar-left"><h2>@totalHuerfanos</h2><span>Registros huérfanos</span></div>
                <div class="stat-bar-right"><h2>@pctHuerfanos.ToString("0.##")%</h2></div>
            </div>
        </div>
    </div>

    @if (Model.EsModoAgrupacion && Model.LlavesAgrupacion.Any())
    {
        <div class="card bg-dark border-info mb-3 shadow-sm" style="border-width: 1px;">
            <div class="card-body py-3 d-flex align-items-center flex-wrap gap-3">
                <span class="text-white fw-bold fs-6"><i class="bi bi-key-fill text-info me-2"></i>Agrupado por las llaves:</span>
                @foreach (var llave in Model.LlavesAgrupacion)
                {
                    <span class="badge-agrupacion shadow-sm">@llave</span>
                }
            </div>
        </div>
    }

    @if (diferenciasAgrupadas.Any())
    {
        <div class="card bg-dark border-warning mb-4 shadow-sm" style="border-width: 1px;">
            <div class="card-body py-3 d-flex align-items-center flex-wrap gap-3">
                <span class="text-white fw-bold fs-6">Campos con diferencias:</span>
                @foreach (var grupo in diferenciasAgrupadas)
                {
                    <span class="badge-diferencia shadow-sm">@grupo.Key <span>@grupo.Count()</span></span>
                }
            </div>
        </div>
    }

    <ul class="nav nav-tabs border-secondary mb-3" id="tabRes">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tDif"><i class="bi bi-exclamation-circle me-1 text-danger"></i> Diferencias</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tHuer"><i class="bi bi-person-x me-1 text-warning"></i> Huérfanos</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tOk"><i class="bi bi-check-circle me-1 text-success"></i> Cuadrados</button></li>
    </ul>

    <div class="tab-content bg-dark border border-secondary p-3 rounded shadow">
        <div class="tab-pane fade show active" id="tDif">
            <div class="mb-4 d-flex align-items-center bg-dark p-3 rounded border border-info shadow-sm">
                <label class="text-white fw-bold me-3 mb-0">Ocultar diferencias menores o iguales a:</label>
                <input type="number" id="globalTolerance" class="form-control bg-dark border-info w-25 custom-placeholder text-white" placeholder="Escribe un valor..." />
                <span class="ms-3 small fst-italic" style="color: #adb5bd;">Escribe un valor y las tablas se limpiarán en tiempo real.</span>
            </div>

            <div class="accordion" id="accordionDiferencias">
                @foreach (var grupo in diferenciasAgrupadas)
                {
                    string collapseId = "col_" + grupo.Key.Replace(" ", "_").Replace(".", "");
                    <div class="accordion-item bg-dark border-secondary">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <span class="badge bg-danger me-3 fs-6 text-white">@grupo.Count()</span> Columna: <span class="ms-1 text-info">@grupo.Key</span>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse">
                            <div class="accordion-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-dark table-hover table-sm mb-0 table-diferencias w-100">
                                        <thead><tr><th>Llave Primaria</th><th class="text-end">@Model.AliasArchivo1</th><th class="text-end">@Model.AliasArchivo2</th><th class="text-end">Dif</th></tr></thead>
                                        <tbody>
                                            @foreach (var reg in grupo)
                                            {
                                                <tr data-diff="@reg.DiferenciaNumerica">
                                                    <td class="text-white"><code>@reg.LlaveIdentificadora</code></td>
                                                    <td class="text-end text-white">@reg.ValorArchivo1</td>
                                                    <td class="text-end text-white">@reg.ValorArchivo2</td>
                                                    <td class="text-end text-danger fw-bold">@reg.Diferencia</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="tHuer">
            <div class="row">
                <div class="col-md-6 border-end border-secondary">
                    <h5 class="text-warning border-bottom border-secondary pb-2 mb-3">Solo en @Model.AliasArchivo1</h5>
                    <div class="overflow-auto" style="max-height: 400px;">
                        @foreach (var h in Model.HuerfanosArchivo1)
                        {
                            <div class="text-white small py-1 border-bottom border-secondary"><code>@h</code></div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <h5 class="text-warning border-bottom border-secondary pb-2 mb-3">Solo en @Model.AliasArchivo2</h5>
                    <div class="overflow-auto" style="max-height: 400px;">
                        @foreach (var h in Model.HuerfanosArchivo2)
                        {
                            <div class="text-white small py-1 border-bottom border-secondary"><code>@h</code></div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tOk">
            <div class="table-responsive">
                <table class="table table-dark table-sm table-hover w-100" id="tableCuadrados">
                    <thead><tr><th>Llave Primaria</th><th>Estado</th><th>Detalle</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.RegistrosCuadrados)
                        {
                            <tr><td class="text-white"><code>@r.LlaveIdentificadora</code></td><td><span class="badge bg-success text-white">OK</span></td><td class="small" style="color: #adb5bd !important;">@r.DetalleValores</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.table-diferencias, #tableCuadrados').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
                "pageLength": 10
            });

            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function () { $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust(); });
            $('.accordion-button').on('click', function() { setTimeout(() => { $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust(); }, 200); });

            $.fn.dataTable.ext.search.push(function(settings, data, dataIndex, rowData, counter) {
                if (!settings.nTable.classList.contains('table-diferencias')) return true;
                let tolStr = $('#globalTolerance').val();
                if (!tolStr) return true;
                let tol = parseFloat(tolStr);
                let tr = settings.aoData[dataIndex].nTr;
                let diffStr = tr.getAttribute('data-diff');
                if (!diffStr) return true;
                let diff = Math.abs(parseFloat(diffStr.replace(',', '.')));
                return diff > tol;
            });

            $('#globalTolerance').on('keyup change', function() { $('.table-diferencias').DataTable().draw(); });

            new Chart(document.getElementById('chartResultados').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Cuadrados', 'Diferencias', 'Huérfanos'],
                    datasets: [{ data: [@totalCuadrados, @totalDiferencias, @totalHuerfanos], backgroundColor: ['#198754', '#ffc107', '#dc3545'], borderWidth: 0 }]
                },
                options: { cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#fff', padding: 20 } } }, maintainAspectRatio: false }
            });
        });
    </script>
}

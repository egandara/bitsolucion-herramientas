@using NotebookValidator.Web.Services
@model List<Finding>
@{
    ViewData["Title"] = "Validador de Notebooks";
}

<style>
    /* 1. CORRECCIÓN DE VISIBILIDAD EN CARGA */
    .text-light-muted {
        color: #abb2bf !important; /* Gris claro legible */
    }

    #upload-card .card-body strong {
        color: #ffc107; /* Título de sección en dorado */
    }

    /* ======================================================================== */
    /* DISEÑO DE LA LISTA DE ARCHIVOS CON SCROLL PERSONALIZADO */
    /* ======================================================================== */
    #file-list {
        max-height: 260px !important; /* Altura elástica para soportar cargas masivas sin romper layouts */
        overflow-y: auto !important; /* Habilita el scrollbar vertical sutil */
        background-color: #0d1117 !important;
        border: 1px solid #30363d !important;
        border-radius: 6px;
        padding: 5px !important;
    }

        /* Estilización del Scrollbar para Integración de Interfaz Oscura */
        #file-list::-webkit-scrollbar {
            width: 6px;
        }

        #file-list::-webkit-scrollbar-track {
            background: #0d1117;
        }

        #file-list::-webkit-scrollbar-thumb {
            background: #30363d;
            border-radius: 3px;
        }

            #file-list::-webkit-scrollbar-thumb:hover {
                background: #ffc107;
            }

        #file-list .list-group-item {
            background-color: #161b22 !important;
            border: 1px solid #30363d !important;
            color: #c9d1d9;
            box-sizing: border-box;
            padding: 5px 8px !important;
            font-size: 0.75rem !important;
            margin-bottom: 4px !important;
            border-radius: 4px !important;
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
        }

        #file-list .file-left {
            display: flex;
            align-items: center;
            flex: 1 1 auto;
            min-width: 0;
            gap: 0.5rem;
        }

            #file-list .file-left .file-name {
                display: block;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                max-width: 200px; /* Seguridad de truncado elástico para no empujar la columna derecha */
                color: #c9d1d9;
            }

        #file-list .file-heading-container {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0; /* Impide que la columna del tamaño y botón colapse por nombres largos */
        }

        #file-list .file-right .text-muted {
            color: #8b949e !important;
            font-size: 0.72rem !important;
            font-weight: bold;
        }

        #file-list .file-right .btn-danger {
            padding: 1px 6px !important;
            font-size: 0.75rem !important;
            line-height: 1.2 !important;
            height: 20px !important;
            border-radius: 3px !important;
        }

    /* ======================================================================== */
    /* CORREGIDO: CONTROL DE ENCABEZADOS UNIFORMES (AMARILLO CORPORATIVO) */
    /* ======================================================================== */
    #resultsTable {
        table-layout: fixed !important; /* Fuerza el control estricto de los porcentajes configurados abajo */
        width: 100% !important;
        margin-top: 15px !important;
        border-collapse: collapse !important;
    }

        #resultsTable th, #resultsTable td {
            padding: 8px 10px !important;
            vertical-align: middle !important;
            font-size: 0.76rem !important;
            line-height: 1.35 !important;
            box-sizing: border-box;
            overflow: hidden;
        }

        /* Forzar que todos los encabezados y sus pseudo-elementos internos de ordenamiento de DataTables sean amarillos */
        #resultsTable thead th,
        #resultsTable thead th *,
        #resultsTable thead th::after,
        #resultsTable thead th::before {
            background-color: #121620 !important;
            color: #ffc107 !important;
            font-weight: 600 !important;
        }

        #resultsTable thead th {
            border-bottom: 2px solid #ffc107 !important;
        }

        #resultsTable tbody tr.clickable-row:hover {
            background-color: rgba(255, 193, 7, 0.05) !important;
            transition: background-color 0.1s ease-in-out;
        }

        /* Bloque A: Estructura y anchos proporcionales (Afecta a TH y TD por igual) */
        #resultsTable .col-archivo {
            width: 32% !important;
            white-space: normal !important;
            word-break: break-all !important;
            overflow-wrap: break-word !important;
        }

        #resultsTable .col-tipo {
            width: 12% !important;
            white-space: normal !important;
        }

        #resultsTable .col-celda {
            width: 4% !important;
            text-align: center !important;
        }

        #resultsTable .col-linea {
            width: 4% !important;
            text-align: center !important;
        }

        #resultsTable .col-contenido {
            width: 15% !important;
            word-break: break-all !important;
        }

        #resultsTable .col-detalle {
            width: 26% !important;
            white-space: normal !important;
            word-break: break-word !important;
        }

        #resultsTable .col-acciones {
            width: 7% !important;
            text-align: center !important;
        }

        /* Bloque B: Colores de fuente específicos EXCLUSIVOS para las celdas del cuerpo (Evita oscurecer los TH) */
        #resultsTable tbody td.col-archivo {
            color: #0f172a !important; /* Slate oscuro profundo sobre el fondo blanco */
            font-weight: 500 !important;
        }

        #resultsTable tbody td.col-celda {
            color: #334155 !important;
        }

        #resultsTable tbody td.col-linea {
            color: #334155 !important;
        }

        #resultsTable tbody td.col-detalle {
            color: #1e293b !important; /* Gris carbón de alto contraste técnico para las descripciones */
        }

        /* Estilo de micro-ajuste para los botones de acción dentro de la tabla */
        #resultsTable .btn-sm {
            padding: 2px 6px !important;
            font-size: 0.72rem !important;
            line-height: 1.2 !important;
            height: 22px !important;
        }

        #resultsTable code {
            background-color: #0d1117 !important;
            color: #f8f8f2 !important;
            padding: 2px 4px !important;
            border-radius: 4px !important;
            border: 1px solid #21262d !important;
            display: inline-block;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    /* ======================================================================== */

    /* 3. REDISEÑO TOTAL DEL POPUP (codeModal) */
    #codeModal .modal-content {
        background-color: #161b22;
        border: 1px solid #ffc107;
        box-shadow: 0 0 20px rgba(255, 193, 7, 0.2);
    }

    #codeModal .modal-header {
        border-bottom: 1px solid #30363d;
        padding: 1.2rem 1.5rem;
    }

    #codeModal .modal-title {
        color: #ffc107;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    #codeModal .modal-body {
        padding: 1.5rem;
    }

    .code-view-container {
        background-color: #0d1117;
        color: #58a6ff;
        padding: 18px;
        border-radius: 8px;
        border: 1px solid #30363d;
        font-family: 'Cascadia Code', 'Consolas', 'Monaco', monospace;
        font-size: 0.9rem;
        white-space: pre-wrap;
        word-wrap: break-word;
        max-height: 500px;
        overflow-y: auto;
        line-height: 1.5;
        text-align: left;
    }

    .modal-label-custom {
        color: #abb2bf !important;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: bold;
        margin-bottom: 0.8rem;
        display: block;
        letter-spacing: 1px;
    }

    #smartFixModal .modal-content {
        background-color: #0f111a;
        border: 1px solid #495057;
    }
</style>

<div class="text-center">
    <h1 class="display-4 fw-bold" style="color: #fff;">Validador de Notebooks</h1>
    <p class="text-light-muted">Sube uno o más archivos (.py, .ipynb, .zip) para buscar malas prácticas y asegurar la calidad del código.</p>
</div>

<div class="row mt-4">
    <div class="col-lg-5">
        <div id="upload-card" class="card h-100 d-flex flex-column shadow-lg" style="background-color: #161b22; border: 1px solid #30363d;">
            <div class="card-header border-bottom border-secondary py-3">
                <h5 class="mb-0 text-white"><i class="bi bi-file-earmark-arrow-up-fill me-2 text-warning"></i>1. Cargar Archivos para Análisis</h5>
            </div>
            <div class="card-body d-flex flex-column">
                <input type="file" id="file-input" multiple class="d-none" accept=".py,.ipynb,.zip" />
                <button type="button" class="btn btn-warning fw-bold w-100 py-2 shadow-sm" onclick="document.getElementById('file-input').click();">
                    <i class="bi bi-folder2-open me-2"></i> Elegir Archivos...
                </button>
                <hr class="border-secondary" />

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <span id="selected-count" class="badge bg-dark border border-secondary">0 archivos</span>
                        <span id="total-size" class="badge bg-dark border border-secondary ms-2">0 B</span>
                    </div>
                    <small class="text-light-muted"><i class="bi bi-info-circle me-1"></i>Sugerencia: archivos ≤ 50 MB</small>
                </div>

                <strong class="mb-2 d-block">Archivos en cola para analizar:</strong>
                <ul id="file-list" class="list-group mt-1 flex-grow-1 border-0">
                    <li id="empty-list-item" class="list-group-item text-light-muted fst-italic">No se han seleccionado archivos.</li>
                </ul>
            </div>
            <div class="card-footer border-top border-secondary text-end bg-transparent py-3">
                <button type="button" id="clear-files-button" class="btn btn-outline-light btn-sm me-2">Limpiar Lista</button>
                <button type="button" id="validate-button" class="btn btn-primary px-4 fw-bold" disabled aria-disabled="true">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                    Analizar Archivos
                </button>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div id="summary-card" class="card h-100 d-flex flex-column shadow-lg" style="display: none; background-color: #161b22; border: 1px solid #30363d;">
            <div class="card-header d-flex justify-content-between align-items-center border-bottom border-secondary py-3">
                <h5 class="mb-0 text-white"><i class="bi bi-table text-warning me-2"></i> 2. Resumen del Análisis</h5>
                <button type="button" id="btn-bulk-fix" class="btn btn-sm btn-warning fw-bold shadow-sm" style="display:none;" onclick="applyBulkFix()">
                    <i class="bi bi-magic me-1"></i> Smart Fix Masivo
                </button>
            </div>
            <div class="card-body" id="summary-content"></div>
            <div class="card-footer border-top border-secondary d-flex justify-content-between align-items-center bg-transparent py-3">
                <button type="button" id="btn-download-fixed" class="btn btn-outline-warning fw-bold" style="display: none;" onclick="downloadCorrectedNotebook()">
                    <i class="bi bi-magic me-1"></i> Descargar Versión Corregida
                </button>
                <a asp-action="ExportToExcel" asp-controller="Home" id="export-button" class="btn btn-success fw-bold" style="display: none;">
                    <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
                </a>
            </div>
        </div>
    </div>
</div>

<div id="results-container" class="mt-4">
    @if (Model != null && Model.Any())
    {
        @await Html.PartialAsync("_ValidationResults", Model)
    }
</div>

<div class="modal fade" id="codeModal" tabindex="-1" aria-labelledby="codeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="codeModalLabel">
                    <i class="bi bi-info-square-fill me-2"></i>Contexto del Hallazgo Detectado
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="modal-label-custom">Código fuente de la celda:</label>
                <div class="code-view-container">
                    <code id="code-content" class="language-python"></code>
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="smartFixModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content text-white">
            <div class="modal-header">
                <h5 class="modal-title text-warning fw-bold"><i class="bi bi-magic me-2"></i>CORRECCIÓN INTELIGENTE</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label small text-muted">Contenido de la Celda Detectada:</label>
                    <pre class="p-2 rounded" style="background-color: #050505; border: 1px solid #333;"><code id="fix-original-code" style="color: #ffc107;"></code></pre>
                </div>
                <div class="row mb-3 align-items-end">
                    <div class="col-md-7">
                        <label class="form-label small text-warning fw-bold">Variable de Base de Datos (X):</label>
                        <select id="fix-var-select" class="form-select bg-dark text-white border-secondary shadow-sm"></select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted">Nombre de Variable Sugerido:</label>
                        <input type="text" id="fix-step-name" class="form-control bg-dark text-white border-secondary" readonly style="font-family: monospace;">
                    </div>
                </div>
                <div class="mb-0">
                    <label id="preview-label" class="form-label small text-success fw-bold">NUEVO CÓDIGO ESTANDARIZADO:</label>
                    <pre class="p-2 rounded border border-success" style="background-color: #050505;"><code id="fix-preview-code" class="text-white"></code></pre>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btn-apply-fix" class="btn btn-warning fw-bold" onclick="confirmFix()"><i class="bi bi-check-circle me-1"></i> Aplicar al Notebook</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/home-index.js" asp-append-version="true"></script>
}

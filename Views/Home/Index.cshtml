@{
    ViewData["Title"] = "Panel Principal";
}

<style>
    .welcome-section {
        padding: 4rem 1rem;
        text-align: center;
    }

    .home-card {
        background-color: var(--card-bg, #1a1a1a);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        padding: 2.5rem;
        text-align: center;
        transition: all 0.3s ease;
        text-decoration: none !important;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .home-card:hover {
            transform: translateY(-10px);
            border-color: #ffc107;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
            background-color: rgba(255, 255, 255, 0.05);
        }

    .home-icon {
        font-size: 3.5rem;
        color: #ffc107;
        margin-bottom: 1.5rem;
    }

    .card-title {
        color: #ffffff;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .card-text {
        color: #b0b0b0;
        font-size: 0.95rem;
        line-height: 1.6;
    }
</style>

<div class="container">
    <div class="welcome-section">
        <h1 class="display-4 fw-bold text-white mb-3">
            Bienvenido a <span class="text-warning">Bit Solución</span>
        </h1>
        <p class="lead text-white-50">Selecciona el módulo con el que deseas trabajar hoy.</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-4">
            <a asp-controller="Home" asp-action="Validador" class="home-card">
                <i class="bi bi-file-earmark-check home-icon"></i>
                <h3 class="card-title">Validador de Notebooks</h3>
                <p class="card-text">Analiza archivos .py e .ipynb buscando malas prácticas y errores estructurales.</p>
            </a>
        </div>

        <div class="col-md-6 col-lg-4">
            <a asp-controller="DataProfiling" asp-action="Index" class="home-card">
                <i class="bi bi-bar-chart-steps home-icon"></i>
                <h3 class="card-title">Perfilamiento de Datos</h3>
                <p class="card-text">Radiografía completa de archivos pesados con detección automática de PII y duplicados.</p>
            </a>
        </div>

        <div class="col-md-6 col-lg-4">
            <a asp-controller="Cuadratura" asp-action="Index" class="home-card">
                <i class="bi bi-table home-icon"></i>
                <h3 class="card-title">Cuadratura de Datos</h3>
                <p class="card-text">Compara y concilia múltiples fuentes de datos para asegurar la consistencia.</p>
            </a>
        </div>
    </div>
</div>

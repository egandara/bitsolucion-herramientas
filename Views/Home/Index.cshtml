@using NotebookValidator.Web.Services
@model List<Finding>
@{
    ViewData["Title"] = "Validador de Notebooks";
}

<style>
    /* Ajustes para lista de archivos: izquierda flexible con truncado, derecha fija */
    #file-list .list-group-item {
        box-sizing: border-box;
        overflow: hidden; /* evita scroll horizontal por contenido largo */
    }

    #file-list .file-left {
        display: flex;
        align-items: center;
        flex: 1 1 auto; /* ocupa el espacio disponible */
        min-width: 0; /* necesario para que text-overflow funcione en flex children */
        gap: 0.5rem;
    }

    #file-list .file-left .file-name {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
    }

    #file-list .file-right {
        display: flex;
        align-items: center;
        flex: 0 0 auto; /* contenido de la derecha no crece */
        gap: 0.5rem;
        margin-left: 0.5rem;
    }

    #file-list .file-right small {
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* Asegura que el botón eliminar no se reduzca */
    #file-list .file-right .btn {
        flex-shrink: 0;
    }
</style>

<div class="text-center">
    <h1 class="display-4">Validador de Notebooks</h1>
    <p>Sube uno o más archivos (.py, .ipynb, .zip) para buscar malas prácticas.</p>
</div>

<div class="row mt-4">

    <div class="col-lg-5">
        <div id="upload-card" class="card h-100 d-flex flex-column">
            <div class="card-header">
                <h5>
                    <i class="bi bi-file-earmark-arrow-up-fill me-2"></i>1. Cargar Archivos para Análisis.
                </h5>
            </div>
            <div class="card-body d-flex flex-column">
                <input type="file" id="file-input" multiple class="d-none" accept=".py,.ipynb,.zip" />
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('file-input').click();">
                    Elegir Archivos...
                </button>

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <span id="selected-count" class="badge bg-secondary">0 archivos</span>
                        <span id="total-size" class="badge bg-secondary ms-2">0 B</span>
                    </div>
                    <small class="text-muted">Sugerencia: archivos ≤ 50 MB</small>
                </div>

                <strong>Archivos en cola para analizar:</strong>
                <ul id="file-list" class="list-group mt-2 flex-grow-1">
                    <li id="empty-list-item" class="list-group-item text-muted">No se han seleccionado archivos.</li>
                </ul>
            </div>
            <div class="card-footer text-end">
                <button type="button" id="clear-files-button" class="btn btn-outline-secondary me-2">
                    Limpiar Lista
                </button>
                <button type="button" id="validate-button" class="btn btn-primary" disabled aria-disabled="true">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                    Analizar Archivos
                </button>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div id="summary-card" class="card h-100 d-flex flex-column" style="display: none;">
            <div class="card-header">
                <h5>
                    <i class="bi bi-table"></i> 2. Resumen del Análisis
                </h5>
            </div>
            <div class="card-body" id="summary-content">
            </div>
            <div class="card-footer text-end">
                <a asp-action="ExportToExcel" asp-controller="Home" id="export-button" class="btn btn-success" style="display: none;">
                    Exportar a Excel
                </a>
            </div>
        </div>
    </div>
</div>

<div id="results-container" class="mt-4">
    @if (Model != null && Model.Any())
    {
        @await Html.PartialAsync("_ValidationResults", Model)
    }
</div>

<div class="modal fade" id="codeModal" tabindex="-1" aria-labelledby="codeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="codeModalLabel">Contexto del Código</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre><code id="code-content" class="language-python"></code></pre>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/home-index.js" asp-append-version="true"></script>
}

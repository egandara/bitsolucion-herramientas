<div class="offcanvas offcanvas-end text-white border-start border-secondary" tabindex="-1" id="offcanvasModules" aria-labelledby="offcanvasModulesLabel" style="background-color: #0b0d16 !important; width: 380px;">
    <div class="offcanvas-header border-bottom border-secondary py-3">
        <h5 class="offcanvas-title fw-bold text-warning" id="offcanvasModulesLabel"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Módulos Ocultos</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body py-4">
        <p class="small text-white-50 mb-4">Los módulos que remuevas aparecerán aquí. Haz clic sobre cualquiera para restaurarlo en tu pantalla principal de inmediato.</p>
        <div id="modules-pool" class="d-flex flex-column gap-3"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>

    <script>
        const poolContainer = document.getElementById('modules-pool');
        const rootContainer = document.getElementById('dashboard-root');
        const databaseLayout = JSON.parse(rootContainer.getAttribute('data-layout') || 'null');

        // Todas las secciones disponibles
        const SECTIONS = ['validacion', 'datos', 'herramientas', 'sistema'];

        // Obtiene el row de una sección
        function getSectionRow(section) {
            return document.getElementById('section-row-' + section);
        }

        // Actualiza visibilidad del header de sección según si tiene tarjetas
        function updateSectionVisibility() {
            SECTIONS.forEach(sec => {
                const row = document.getElementById('section-row-' + sec);
                const header = document.getElementById('section-header-' + sec);
                if (!header) return;
                const hasCards = row && row.querySelectorAll('.grid-item').length > 0;
                if (hasCards) {
                    header.style.display = 'block';
                } else {
                    header.style.display = 'none';
                }
                if (row) row.style.display = hasCards ? '' : 'none';
            });
        }

        // Cuenta todos los módulos en el pool
        function updateHiddenCount() {
            const count = poolContainer.querySelectorAll('.grid-item').length;
            const btn = document.getElementById('btn-show-hidden');
            const countEl = document.getElementById('hidden-count');
            if (btn && countEl) {
                countEl.textContent = count;
                btn.classList.toggle('d-none', count === 0);
            }
        }

        // Manda una tarjeta al pool (ocultar)
        function moveToPool(item) {
            poolContainer.appendChild(item);
            const hideBtn = item.querySelector('.btn-toggle-view');
            if (hideBtn) {
                hideBtn.querySelector('i').className = 'bi bi-eye-slash-fill';
                hideBtn.setAttribute('title', 'Activar Módulo');
            }
        }

        // Restaura una tarjeta a su sección original
        function restoreToSection(item) {
            const section = item.getAttribute('data-section');
            const row = getSectionRow(section);
            if (row) row.appendChild(item);
            else document.getElementById('section-row-herramientas').appendChild(item);
        }

        document.addEventListener('DOMContentLoaded', function () {

            // Inicializar header de sistema via JS
            var sysHeader = document.getElementById("section-header-sistema");
            if (sysHeader) {
                sysHeader.textContent = "Sistema";
                sysHeader.setAttribute("class", "grid-section-header");
                sysHeader.style.display = "none";
                sysHeader.style.fontSize = "0.6rem";
                sysHeader.style.letterSpacing = "1.2px";
                sysHeader.style.fontWeight = "700";
                sysHeader.style.color = "rgba(255,193,7,0.35)";
                sysHeader.style.textTransform = "uppercase";
                sysHeader.style.padding = "6px 0 4px";
            }

            // Aplicar layout guardado en BD
            if (databaseLayout && databaseLayout.length > 0) {
                // Primero: aplicar tamaños y reordenar los que sí están en el layout
                databaseLayout.forEach(item => {
                    const element = document.querySelector(`.grid-item[data-id="${item.id}"]`);
                    if (!element) return;
                    if (item.size === 'large') {
                        element.classList.remove('col-md-4', 'col-lg-3');
                        element.classList.add('col-md-8', 'col-lg-6');
                        element.setAttribute('data-size', 'large');
                        const icon = element.querySelector('.btn-action-size i');
                        if (icon) icon.className = 'bi bi-arrows-angle-contract';
                    }
                    const section = element.getAttribute('data-section');
                    const row = getSectionRow(section);
                    if (row) row.appendChild(element);
                });

                // Segundo: los que NO están en el layout van al pool
                document.querySelectorAll('.grid-item').forEach(element => {
                    const id = element.getAttribute('data-id');
                    const inLayout = databaseLayout.find(x => x.id === id);
                    if (!inLayout) moveToPool(element);
                });
            }

            updateSectionVisibility();
            updateHiddenCount();

            // Inicializar Sortable en cada row de sección
            SECTIONS.forEach(sec => {
                const row = getSectionRow(sec);
                if (!row) return;
                Sortable.create(row, {
                    group: 'dashboard',
                    animation: 250,
                    ghostClass: 'sortable-ghost',
                    handle: '.card-module',
                    filter: '.card-actions, button',
                    preventOnFilter: false,
                    onEnd: function () {
                        updateSectionVisibility();
                        saveCurrentLayout();
                    }
                });
            });

            document.getElementById('btn-reset-layout').addEventListener('click', function (e) {
                e.preventDefault();
                if (confirm('¿Estás seguro de que deseas restablecer el diseño original y mostrar todos tus módulos autorizados?')) {
                    fetch('/Home/ResetDashboardLayout', { method: 'POST' })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) window.location.reload();
                            else alert('No se pudo restablecer el diseño: ' + data.message);
                        })
                        .catch(err => console.error("Error al restablecer layout:", err));
                }
            });
        });

        function toggleSize(button, event) {
            event.preventDefault();
            event.stopPropagation();
            const item = button.closest('.grid-item');
            const icon = button.querySelector('i');
            const isSmall = item.getAttribute('data-size') === 'small';
            if (isSmall) {
                item.classList.remove('col-md-4', 'col-lg-3');
                item.classList.add('col-md-8', 'col-lg-6');
                item.setAttribute('data-size', 'large');
                icon.className = 'bi bi-arrows-angle-contract';
            } else {
                item.classList.remove('col-md-8', 'col-lg-6');
                item.classList.add('col-md-4', 'col-lg-3');
                item.setAttribute('data-size', 'small');
                icon.className = 'bi bi-arrows-angle-expand';
            }
            saveCurrentLayout();
        }

        function toggleVisibilityClick(button, event) {
            event.preventDefault();
            event.stopPropagation();
            moveToPool(button.closest('.grid-item'));
            updateSectionVisibility();
            saveCurrentLayout();
            updateHiddenCount();
        }

        function handlePoolCardClick(card, event) {
            const item = card.closest('.grid-item');
            if (item.parentElement.id === 'modules-pool') {
                event.preventDefault();
                event.stopPropagation();
                restoreToSection(item);
                updateSectionVisibility();
                saveCurrentLayout();
                updateHiddenCount();
            }
        }

        function saveCurrentLayout() {
            const syncIndicator = document.getElementById('sync-indicator');
            syncIndicator.innerHTML = '<i class="bi bi-cloud-arrow-up-fill text-warning"></i> Sincronizando...';
            syncIndicator.style.opacity = '1';

            const currentLayout = [];
            SECTIONS.forEach(sec => {
                const row = getSectionRow(sec);
                if (!row) return;
                row.querySelectorAll('.grid-item').forEach(item => {
                    currentLayout.push({ id: item.getAttribute('data-id'), size: item.getAttribute('data-size') });
                });
            });

            fetch('/Home/SaveDashboardLayout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layoutJson: JSON.stringify(currentLayout) })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    syncIndicator.innerHTML = '<i class="bi bi-cloud-check-fill text-success"></i> Cambios guardados';
                    setTimeout(() => { syncIndicator.style.opacity = '0'; }, 2000);
                } else {
                    syncIndicator.innerHTML = '<i class="bi bi-cloud-slash-fill text-danger"></i> Error al guardar';
                }
            })
            .catch(() => {
                syncIndicator.innerHTML = '<i class="bi bi-cloud-slash-fill text-danger"></i> Error de conexión';
            });
        }
    </script>
}



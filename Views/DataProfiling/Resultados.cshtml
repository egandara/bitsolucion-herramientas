@model NotebookValidator.Web.Models.DataProfileResult
@{
    ViewData["Title"] = "Resultados del Perfilamiento";
}

<div id="antiForgeryToken" style="display:none;">
    @Html.AntiForgeryToken()
</div>

<style>
    .text-muted-light {
        color: #adb5bd !important;
    }

    .bg-dark-subtle {
        background-color: rgba(255,255,255,0.03) !important;
    }

    .pulse-danger {
        box-shadow: 0 0 0 rgba(220,53,69,0.4);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(220,53,69,0.4);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(220,53,69,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220,53,69,0);
        }
    }

    .pill {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        margin-right: 0.35rem;
        margin-bottom: 0.35rem;
        border-radius: 999px;
        background: rgba(255,193,7,0.15);
        color: #ffc107;
        font-size: 0.85rem;
        border: 1px solid rgba(255,193,7,0.25);
    }

        .pill .remove {
            margin-left: 0.4rem;
            cursor: pointer;
            color: #212529;
            opacity: 0.8;
        }

    .columns-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.625rem;
        max-height: 220px;
        overflow: auto;
        padding: 0.25rem;
    }

    .col-item {
        white-space: nowrap;
    }

    .controls-row {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        width: 100%;
    }

        .controls-row .form-control {
            flex: 1 1 auto;
            min-width: 160px;
        }

    .btn-duplicate {
        min-width: 170px;
    }

    .modal-content.bg-dark {
        border-color: rgba(255,255,255,0.08);
    }

    .duplicates-list {
        max-height: 60vh;
        overflow: auto;
        padding-right: 0.5rem;
    }

    .collapse-toggle {
        border-bottom: 1px solid rgba(255,193,7,0.12);
        background: linear-gradient(180deg, rgba(255,255,255,0.01), transparent);
    }

    .collapse-toggler {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: none;
        background: transparent;
        color: inherit;
        width: 100%;
        text-align: left;
        padding: 0;
    }

        .collapse-toggler .collapse-chevron {
            transition: transform 0.18s ease;
            font-size: 1.05rem;
            color: #ffc107;
        }

        .collapse-toggler:not(.collapsed) .collapse-chevron {
            transform: rotate(90deg);
        }

    .collapse-hint {
        font-size: 0.85rem;
        color: #adb5bd;
        margin-top: 2px;
        font-weight: 500;
        opacity: 0.8;
    }

    .collapse-toggle:hover {
        background: rgba(255, 193, 7, 0.1) !important;
        border-color: rgba(255, 193, 7, 0.5) !important;
        transition: all 0.3s ease;
    }

    .collapse-toggler:focus {
        box-shadow: none;
        outline: none;
    }

    .col-card-container {
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .filtro-btn.active {
        background-color: #ffc107 !important;
        color: #212529 !important;
        border-color: #ffc107 !important;
    }

    #inputBusquedaCol::placeholder {
        color: rgba(255, 255, 255, 0.6) !important;
        opacity: 1;
    }

    .chart-wrapper {
        position: relative;
        height: 250px;
        width: 100%;
    }

    @@media (max-width:768px) {
        .columns-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }

        .controls-row {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-duplicate {
            width: 100%;
            min-width: auto;
        }
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white"><i class="bi bi-bar-chart-steps text-warning me-2"></i> Radiografía de Datos</h2>
        <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Analizar otro archivo</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Archivo Analizado</h6>
                    <h5 class="text-warning text-break mb-0">@Model.FileName</h5>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Tipo de Archivo</h6>
                    <h3 class="text-white mb-0">@Model.FileExtension</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Tamaño</h6>
                    <h3 class="text-white mb-0">@Model.FileSizeFormatted</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Total de Filas</h6>
                    <h2 class="text-white mb-0">@Model.TotalRows.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Total de Columnas</h6>
                    <h2 class="text-white mb-0">@Model.TotalColumns</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Celdas Analizadas</h6>
                    <h3 class="text-white mb-0">@Model.TotalCells.ToString("N0")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Separador de Columnas</h6>
                    <h3 class="text-white mb-0 text-info">@Model.SeparatorUsed</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted-light mb-1">Salto de Línea (EOL)</h6>
                    <h4 class="text-white mb-0">@Model.LineEndingType</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center p-2">
                    <h6 class="text-muted-light mb-2">Tiempos de Ejecución</h6>
                    <div class="d-flex justify-content-evenly align-items-center w-100">
                        <div>
                            <div class="text-muted-light" style="font-size: 0.75rem;"><i class="bi bi-cloud-arrow-up text-info"></i> Subida</div>
                            <h5 class="text-white mb-0" id="uiUploadTime">-</h5>
                        </div>
                        <div style="width: 1px; height: 30px; background-color: #6c757d;"></div>
                        <div>
                            <div class="text-muted-light" style="font-size: 0.75rem;"><i class="bi bi-cpu text-warning"></i> Servidor</div>
                            <h5 class="text-white mb-0">@Model.ProcessingTimeFormatted</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-white mb-3 border-bottom border-warning pb-2">Búsqueda de Duplicados</h4>

    <div class="collapse-toggle mb-3 p-2 rounded" style="cursor: pointer; background: rgba(255, 193, 7, 0.05); border: 1px solid rgba(255, 193, 7, 0.2);" onclick="document.getElementById('btnToggleCollapse').click()">
        <button id="btnToggleCollapse" class="collapse-toggler collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDuplicates" aria-expanded="false" aria-controls="collapseDuplicates">
            <i class="bi bi-chevron-right collapse-chevron"></i>
            <h4 class="text-white mb-0 d-inline-block"><i class="bi bi-search text-warning me-2"></i>Búsqueda de Duplicados</h4>
            <span class="collapse-hint ms-auto d-none d-sm-inline text-warning"><i class="bi bi-eye me-1"></i> Click para expandir herramientas de limpieza</span>
        </button>
    </div>

    <div class="collapse" id="collapseDuplicates">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card bg-dark text-white border-secondary p-3 shadow-lg" style="border-left: 4px solid #ffc107 !important;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Opcional: Buscar filas duplicadas</strong>
                        <small class="text-muted-light">Selecciona una o más columnas como llave principal o marca "Comparar filas completas".</small>
                    </div>

                    <form id="findDuplicatesForm" class="row g-2" onsubmit="handleFindDuplicatesSubmit(event)">
                        <input type="hidden" name="tempFileName" value="@Model.TempFileName" />
                        <input type="hidden" name="hasHeaders" value="@Model.HasHeaders.ToString().ToLower()" />
                        <input type="hidden" name="fileSize" value="@Model.FileSizeFormatted" />
                        <input type="hidden" name="processingTime" value="@Model.ProcessingTimeFormatted" />

                        <div class="col-12">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="fullRow" name="fullRow" value="true" />
                                <label class="form-check-label" for="fullRow">Comparar filas completas</label>
                            </div>

                            <label class="form-label text-muted-light small">Seleccionar Columnas (si no seleccionas ninguna se compararán todas):</label>

                            <div class="controls-row mb-2">
                                <input id="columnSearch" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Buscar columna..." aria-label="Buscar columna" />
                                <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-light">Seleccionar todo</button>
                                <button type="button" id="clearAllBtn" class="btn btn-sm btn-outline-light">Limpiar</button>
                                <button type="submit" class="btn btn-warning btn-duplicate fw-bold">
                                    <i class="bi bi-intersect me-1"></i> Buscar Duplicados
                                </button>
                            </div>

                            <div id="selectedPills" class="mb-2" aria-live="polite"></div>

                            <div id="columnsContainer" class="columns-grid border border-secondary rounded p-2" style="background: rgba(0,0,0,0.2);">
                                @for (int i = 0; i < Model.ColumnProfiles.Count; i++)
                                {
                                    var col = Model.ColumnProfiles[i];
                                    <div class="col-item">
                                        <div class="form-check">
                                            <input class="form-check-input key-col-checkbox" type="checkbox" id="col_@i" name="keyColumns" value="@col.ColumnName" />
                                            <label class="form-check-label text-truncate" for="col_@i" title="@col.ColumnName">@col.ColumnName</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </form>

                    @if (Model.DuplicateGroups != null && Model.DuplicateGroups.Any())
                    {
                        <div class="mt-3">
                            <div class="alert bg-dark border-warning text-white d-flex justify-content-between align-items-center mb-0">
                                <div>
                                    <i class="bi bi-info-circle text-warning me-2"></i>
                                    Se encontraron <strong class="text-warning">@Model.DuplicateGroups.Sum(g => g.Count)</strong> filas duplicadas.
                                </div>
                                <div>
                                    <button type="button" class="btn btn-outline-warning btn-sm" data-bs-toggle="modal" data-bs-target="#duplicatesModal">
                                        <i class="bi bi-eye"></i> Ver Resultados
                                    </button>
                                    <button id="openDuplicatesModalAuto" type="button" class="d-none" data-bs-toggle="modal" data-bs-target="#duplicatesModal">Abrir</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="bg-dark-subtle p-3 rounded border border-secondary mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-dark text-warning border-secondary"><i class="bi bi-search"></i></span>
                    <input type="text" id="inputBusquedaCol" class="form-control bg-dark text-white border-secondary" placeholder="Buscar columna por nombre..." onkeyup="ejecutarFiltradoGlobal()">
                </div>
            </div>
            <div class="col-md-5">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="text-muted-light small me-1"><i class="bi bi-funnel"></i> Tipo:</span>
                    <button type="button" class="btn btn-sm btn-outline-light rounded-pill filtro-btn active" data-filtro="todos" onclick="cambiarFiltroTipo(this)">Todos</button>
                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill filtro-btn" data-filtro="Entero" onclick="cambiarFiltroTipo(this)">Enteros</button>
                    <button type="button" class="btn btn-sm btn-outline-info rounded-pill filtro-btn" data-filtro="Decimal" onclick="cambiarFiltroTipo(this)">Decimales</button>
                    <button type="button" class="btn btn-sm btn-outline-success rounded-pill filtro-btn" data-filtro="Fecha" onclick="cambiarFiltroTipo(this)">Fechas</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill filtro-btn" data-filtro="Texto" onclick="cambiarFiltroTipo(this)">Texto</button>
                </div>
            </div>
            <div class="col-md-3 text-end">
                <div class="form-check form-switch form-check-reverse d-inline-block">
                    <input class="form-check-input bg-danger border-danger" type="checkbox" id="switchAnomaliasGlobal" onchange="ejecutarFiltradoGlobal()">
                    <label class="form-check-label fw-bold text-danger me-2" for="switchAnomaliasGlobal" style="cursor:pointer;">
                        <i class="bi bi-shield-exclamation"></i> Solo Anomalías
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-4" id="columnasGridMain">
        @foreach (var col in Model.ColumnProfiles)
        {
            bool esAnomalia = col.HealthStatus != "Óptima";
            <div class="col col-card-container" data-nombre="@col.ColumnName.ToLower()" data-tipo="@col.InferredDataType" data-anomalia="@esAnomalia.ToString().ToLower()">
                <div class="card bg-dark text-white border-secondary h-100 shadow-sm position-relative @(col.IsPII ? "border-danger" : "")">
                    <div class="card-header border-secondary d-flex justify-content-between align-items-center bg-dark-subtle">
                        <h5 class="mb-0 text-truncate" title="@col.ColumnName" style="max-width: 50%;">@col.ColumnName</h5>
                        <div class="d-flex align-items-center">
                            @{
                                var badgeClass = "";
                                var badgeStyle = "";
                                if (col.InferredDataType == "Entero") { badgeClass = "bg-primary"; }
                                else if (col.InferredDataType == "Decimal") { badgeClass = "text-white"; badgeStyle = "background-color: #6f42c1;"; }
                                else if (col.InferredDataType == "Fecha") { badgeClass = "bg-success"; }
                                else { badgeClass = "bg-info text-dark"; }

                                var healthBadge = col.HealthStatus == "Óptima" ? "bg-success" : (col.HealthStatus == "Advertencia" ? "bg-warning text-dark" : "bg-danger");
                                var healthIcon = col.HealthStatus == "Óptima" ? "bi-check-circle" : (col.HealthStatus == "Advertencia" ? "bi-exclamation-triangle" : "bi-x-octagon");
                            }
                            <span class="badge @badgeClass fs-7" style="@badgeStyle">@col.InferredDataType</span>
                            <span class="badge @healthBadge fs-7 ms-1" title="Calidad del Dato"><i class="bi @healthIcon"></i></span>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        @if (col.IsPII)
                        {
                            <div class="alert alert-danger bg-danger text-white border-0 py-2 mb-3 pulse-danger text-center fw-bold" role="alert" style="font-size: 0.85rem;">
                                <i class="bi bi-shield-lock-fill me-1"></i> DATO SENSIBLE (PII): @col.PIIType
                            </div>
                        }

                        @if (col.InferredDataType == "Texto")
                        {
                            int totalValid = col.DetectedIntegerCount + col.DetectedDecimalCount + col.DetectedDateCount + col.DetectedTextCount;
                            int displayTotal = totalValid == 0 ? 1 : totalValid;
                            double intPct = Math.Round((double)col.DetectedIntegerCount / displayTotal * 100, 1);
                            double decPct = Math.Round((double)col.DetectedDecimalCount / displayTotal * 100, 1);
                            double datePct = Math.Round((double)col.DetectedDateCount / displayTotal * 100, 1);
                            double txtPct = Math.Round((double)col.DetectedTextCount / displayTotal * 100, 1);

                            string alertStyle = (intPct + decPct >= 80) ? "background-color: rgba(255,193,7,0.15); color: #ffc107;" : "background-color: rgba(13,202,240,0.15); color: #0dcaf0;";

                            <div class="mb-3 p-2 bg-dark-subtle border border-secondary rounded d-flex justify-content-between align-items-center gap-2">
                                <div class="text-start" style="font-size: 0.70rem; flex: 1;">
                                    <div class="text-muted-light mb-1" style="line-height: 1.3;">
                                        Enteros: <strong class="text-warning">@col.DetectedIntegerCount</strong> (@intPct%) &nbsp;|&nbsp;
                                        Dec: <strong class="text-warning">@col.DetectedDecimalCount</strong> (@decPct%) &nbsp;|&nbsp;
                                        Fechas: <strong class="text-warning">@col.DetectedDateCount</strong> (@datePct%) &nbsp;|&nbsp;
                                        Texto: <strong class="text-warning">@col.DetectedTextCount</strong> (@txtPct%)
                                    </div>
                                    <div class="px-2 py-1 rounded" style="@alertStyle display: inline-block;">
                                        @col.ValidationRecommendation
                                    </div>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-outline-warning btn-sm validate-col-btn px-2 py-1 text-nowrap" style="font-size: 0.75rem;" data-col="@col.ColumnName" data-temp="@Model.TempFileName" data-headers="@(Model.HasHeaders ? "true" : "false")" title="Buscar discrepancias exactas">
                                        <i class="bi bi-wrench-adjustable"></i> Validar
                                    </button>
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted-light small">Nulos / Vacíos</span>
                                <span class="small fw-bold @(col.NullPercentage > 0 ? "text-danger" : "text-success")">@col.NullPercentage% (@col.NullOrEmptyCount)</span>
                            </div>
                            <div class="progress" style="height: 6px; background-color: #343a40;">
                                <div class="progress-bar @(col.NullPercentage > 20 ? "bg-danger" : (col.NullPercentage > 0 ? "bg-warning" : "bg-success"))" role="progressbar" style="width: @col.NullPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <span class="text-muted-light small d-block mb-1">Valores Únicos</span>
                            <span class="fs-5 fw-bold">@col.UniqueValuesCount.ToString("N0") <span class="fs-6 text-muted-light fw-normal">(@col.UniquePercentage%)</span></span>
                        </div>

                        <textarea class="d-none top-values-data">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(col.TopValues))</textarea>

                        <div class="mt-auto pt-2">
                            <hr class="border-secondary mb-2 mt-0">
                            <button type="button" class="btn btn-sm btn-outline-info w-100 fw-bold"
                                    data-colname="@col.ColumnName"
                                    data-type="@col.InferredDataType"
                                    data-health="@col.HealthStatus"
                                    data-min="@col.MinValue"
                                    data-max="@col.MaxValue"
                                    data-avg="@(col.Average.HasValue? col.Average.Value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) : "-")"
                                    data-zeros="@col.ZeroCount"
                                    data-negatives="@col.NegativeCount"
                                    data-whitespaces="@col.WhitespaceCount"
                                    data-nulls="@col.NullOrEmptyCount"
                                    data-nullspct="@col.NullPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)"
                                    data-uniques="@col.UniqueValuesCount"
                                    data-uniquespct="@col.UniquePercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)"
                                    onclick="abrirOffcanvasDetalle(this)">
                                <i class="bi bi-bar-chart-steps me-1"></i> Ver Detalles y Estadísticas
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="offcanvas offcanvas-end bg-dark text-white border-start border-warning shadow-lg" tabindex="-1" id="detalleColumnaOffcanvas" style="width: 480px;">
        <div class="offcanvas-header bg-dark-subtle border-bottom border-secondary">
            <h5 class="offcanvas-title text-warning fw-bold"><i class="bi bi-layout-sidebar-reverse me-2"></i>Detalle de Columna</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
        </div>
        <div class="offcanvas-body">

            <h3 id="offNombre" class="mb-2 text-break">NombreColumna</h3>
            <div class="mb-4">
                <span id="offTipo" class="badge bg-primary fs-7">Tipo</span>
                <span id="offSalud" class="badge bg-success fs-7 ms-1">Salud</span>
            </div>

            <h6 class="text-muted-light mb-2 text-uppercase fw-bold" style="font-size: 0.8rem;">
                <i class="bi bi-clipboard-data text-light me-1"></i> Integridad y Cardinalidad
                <i class="bi bi-question-circle text-muted ms-1" style="cursor:help;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-container="body" title="Indica qué tan completa está la columna y cuánta variedad de datos tiene."></i>
            </h6>
            <div class="row text-center mb-4 g-2">
                <div class="col-6">
                    <div class="bg-dark-subtle p-2 rounded border border-secondary h-100 d-flex flex-column justify-content-center">
                        <div class="text-muted-light mb-1" style="font-size: 0.65rem;">NULOS / VACÍOS</div>
                        <div class="fw-bold fs-5 text-white"><span id="offNullsPct">0.0</span>%</div>
                        <div class="small text-muted-light"><span id="offNullsCount">0</span> registros</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-dark-subtle p-2 rounded border border-secondary h-100 d-flex flex-column justify-content-center">
                        <div class="text-muted-light mb-1" style="font-size: 0.65rem;">VALORES ÚNICOS</div>
                        <div class="fw-bold fs-5 text-info"><span id="offUniquesPct">0.0</span>%</div>
                        <div class="small text-muted-light"><span id="offUniquesCount">0</span> distintos</div>
                    </div>
                </div>
            </div>

            <div id="seccionEstadisticasNumericas">
                <h6 id="offStatsTitle" class="text-muted-light mb-2 text-uppercase fw-bold" style="font-size: 0.8rem;">
                    <i class="bi bi-calculator text-info me-1"></i> Estadísticas Numéricas
                    <i class="bi bi-question-circle text-muted ms-1" style="cursor:help;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-container="body" title="Resumen matemático de los valores detectados."></i>
                </h6>
                <div class="row text-center mb-4 g-2">
                    <div class="col-4">
                        <div class="bg-dark-subtle p-2 rounded border border-secondary h-100">
                            <div id="offLabelMin" class="text-muted-light mb-1" style="font-size: 0.65rem;">MÍNIMO</div>
                            <div id="offMin" class="fw-bold small text-truncate">-</div>
                        </div>
                    </div>
                    <div id="offColAvg" class="col-4">
                        <div class="bg-dark-subtle p-2 rounded border border-warning h-100" style="box-shadow: inset 0 0 10px rgba(255,193,7,0.1);">
                            <div class="text-warning mb-1" style="font-size: 0.65rem;">PROMEDIO</div>
                            <div id="offAvg" class="fw-bold small text-warning">-</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-dark-subtle p-2 rounded border border-secondary h-100">
                            <div id="offLabelMax" class="text-muted-light mb-1" style="font-size: 0.65rem;">MÁXIMO</div>
                            <div id="offMax" class="fw-bold small text-truncate">-</div>
                        </div>
                    </div>
                </div>
            </div>

            <h6 class="text-muted-light mb-2 text-uppercase fw-bold" style="font-size: 0.8rem;">
                <i class="bi bi-exclamation-octagon text-danger me-1"></i> Conteo de Anomalías Extras
                <i class="bi bi-question-circle text-muted ms-1" style="cursor:help;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-container="body" title="Valores que normalmente representan errores de captura de datos o datos faltantes ocultos."></i>
            </h6>
            <ul class="list-group list-group-flush mb-4 rounded border border-secondary">
                <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center border-secondary">
                    Valores en Cero (0) <span id="offZeros" class="badge bg-secondary rounded-pill">0</span>
                </li>
                <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center border-secondary">
                    Valores Negativos <span id="offNegatives" class="badge bg-secondary rounded-pill">0</span>
                </li>
                <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center border-secondary">
                    Solo Espacios Blancos (" ") <span id="offWhitespaces" class="badge bg-secondary rounded-pill">0</span>
                </li>
            </ul>

            <h6 class="text-muted-light mb-2 text-uppercase fw-bold" style="font-size: 0.8rem;">
                <i class="bi bi-bar-chart-line text-success me-1"></i> Top Valores Frecuentes
            </h6>
            <div class="bg-black p-3 rounded border border-secondary">
                <div id="noChartData" class="text-muted-light small fst-italic text-center py-3" style="display:none;">No hay datos frecuentes para graficar.</div>
                <div class="chart-wrapper" id="chartContainer">
                    <canvas id="topValuesChart"></canvas>
                </div>
            </div>

        </div>
    </div>

    <div class="modal fade" id="duplicatesModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning"><i class="bi bi-exclamation-triangle me-2"></i> Filas Duplicadas (<span id="duplicatesCount">0</span>)</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div id="duplicatesInfo" class="mb-3 text-muted-light"></div>
                    <div class="duplicates-list" id="duplicatesList"></div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cerrar</button>
                    <button id="exportDuplicatesBtn" type="button" class="btn btn-warning">Exportar CSV</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="validateColumnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-warning">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning"><i class="bi bi-wrench-adjustable me-2"></i> Análisis de Conversión</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div id="validationSummary" class="mb-3 p-3 bg-dark-subtle rounded border border-secondary"></div>
                    <div id="validationAdvice" class="alert alert-info py-2" style="font-size: 0.9rem;"></div>

                    <div class="mb-3">
                        <label class="form-label small text-muted-light">Probar compatibilidad con:</label>
                        <div class="d-flex gap-2">
                            <button id="simToInteger" class="btn btn-sm btn-outline-primary">Entero</button>
                            <button id="simToDecimal" class="btn btn-sm btn-outline-info">Decimal</button>
                            <button id="simToDate" class="btn btn-sm btn-outline-success">Fecha</button>
                        </div>
                    </div>

                    <h6 class="text-warning mb-2">Muestra de conflictos (Mismatches):</h6>
                    <div id="validationMismatches" style="max-height: 300px; overflow-y: auto; padding-right: 5px;">
                        <div class="text-muted-light small">Selecciona una opción arriba para buscar valores que no cumplan con el formato.</div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        (function () {
            const antiTokenInput = document.querySelector('#antiForgeryToken input[name="__RequestVerificationToken"]');
            const token = antiTokenInput ? antiTokenInput.value : '';

            const autoBtn = document.getElementById('openDuplicatesModalAuto');
            if (autoBtn) autoBtn.click();

            const uiUploadTime = document.getElementById('uiUploadTime');
            if (uiUploadTime) {
                const upTime = sessionStorage.getItem('uploadDuration');
                uiUploadTime.innerText = upTime ? (upTime + ' seg') : '< 1 seg';
            }

            function postForm(url, data) {
                const params = new URLSearchParams();
                for (const k in data) {
                    if (data[k] === null || typeof data[k] === 'undefined') continue;
                    params.append(k, String(data[k]));
                }

                return fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': token
                    },
                    body: params.toString()
                }).then(r => {
                    if (!r.ok) {
                        return r.text().then(t => { throw new Error('Error en la petición: ' + (t || r.statusText || r.status)); });
                    }
                    return r.json();
                });
            }

            window.handleFindDuplicatesSubmit = function (e) {
                e.preventDefault();
                const form = document.getElementById('findDuplicatesForm');
                const btn = form.querySelector('button[type="submit"]');
                const originalHTML = btn.innerHTML;

                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Buscando...';
                btn.disabled = true;

                const formData = new FormData(form);
                const keyColumns = Array.from(document.querySelectorAll('.key-col-checkbox:checked')).map(cb => cb.value);
                const fullRow = document.getElementById('fullRow').checked;
                const data = {
                    tempFileName: formData.get('tempFileName'),
                    hasHeaders: formData.get('hasHeaders'),
                    fileSize: formData.get('fileSize'),
                    processingTime: formData.get('processingTime'),
                    fullRow: fullRow
                };

                if (keyColumns.length > 0) {
                    keyColumns.forEach(col => {
                        data['keyColumns'] = data['keyColumns'] ? data['keyColumns'] + ',' + col : col;
                    });
                }

                postForm('@Url.Action("FindDuplicates", "DataProfiling")', { ...data, keyColumns: keyColumns.join(',') })
                    .then(res => {
                        if (res.success && res.duplicateGroups && res.duplicateGroups.length > 0) {
                            populateDuplicatesModal(res.duplicateGroups);
                            const modal = new bootstrap.Modal(document.getElementById('duplicatesModal'), {});
                            modal.show();
                        } else {
                            alert('No se encontraron duplicados con los criterios seleccionados.');
                        }
                    })
                    .catch(err => {
                        alert('Error al buscar duplicados: ' + err.message);
                    })
                    .finally(() => {
                        btn.innerHTML = originalHTML;
                        btn.disabled = false;
                    });
            };

            function populateDuplicatesModal(duplicateGroups) {
                const totalCount = duplicateGroups.reduce((sum, g) => sum + g.count, 0);
                document.getElementById('duplicatesCount').textContent = totalCount;
                document.getElementById('duplicatesInfo').innerHTML =
                    `Se encontraron <strong class="text-warning">${totalCount}</strong> filas dentro de <strong class="text-warning">${duplicateGroups.length}</strong> grupos. Puedes revisar los grupos abajo.`;

                let html = '<div class="row g-3">';
                duplicateGroups.forEach(grp => {
                    html += `
                        <div class="col-md-6">
                            <div class="card bg-dark border-danger">
                                 <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="mb-0 text-truncate" title="${grp.sampleDisplay}">Clave: ${grp.sampleDisplay}</h6>
                                            <small class="text-muted-light">Ocurrencias: <strong class="text-warning">${grp.count}</strong></small>
                                        </div>
                                        <div class="text-end small text-muted-light">
                                             <div>Filas: ${grp.rowIndices.slice(0, 10).join(', ')} ${grp.rowIndices.length > 10 ? `... (${grp.rowIndices.length} filas)` : ''}</div>
                                        </div>
                                     </div>
                                </div>
                            </div>
                            <div class="text-muted-light small fst-italic">Muestra de valores: ${grp.sampleDisplay}</div>
                        </div>
                    `;
                });
                html += '</div>';
                document.getElementById('duplicatesList').innerHTML = html;
            }

            document.querySelectorAll('.validate-col-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const columnName = this.getAttribute('data-col');
                    const temp = this.getAttribute('data-temp');
                    const hasHeaders = this.getAttribute('data-headers') === 'true';

                    document.getElementById('validationMismatches').innerHTML = '<div class="text-muted-light small">Selecciona una opción arriba para buscar valores que no cumplan con el formato.</div>';
                    document.getElementById('validationAdvice').className = "alert alert-info py-2";
                    document.getElementById('validationAdvice').innerHTML = "Cargando análisis general...";

                    postForm('@Url.Action("ValidateTextColumn", "DataProfiling")', { tempFileName: temp, columnName: columnName, hasHeaders: hasHeaders })
                        .then(function (res) {
                            showValidationModal(columnName, temp, hasHeaders, res);
                        })
                        .catch(function (err) {
                            alert('Error al validar la columna: ' + err.message);
                        });
                });
            });

            function showValidationModal(columnName, temp, hasHeaders, data) {
                const modalEl = document.getElementById('validateColumnModal');
                const summary = document.getElementById('validationSummary');
                const advice = document.getElementById('validationAdvice');
                const mismatches = document.getElementById('validationMismatches');

                summary.innerHTML = `
                    <div><strong class="text-warning">${columnName}</strong> — Muestra: <strong>${data.totalSampled}</strong> filas</div>
                    <div class="mt-2 small text-muted-light">
                        Enteros: <strong class="text-warning">${data.integerCount}</strong> (${data.integerPercentage}%),
                        Decimales: <strong class="text-warning">${data.decimalCount}</strong> (${data.decimalPercentage}%),
                        Fechas: <strong class="text-warning">${data.dateCount}</strong> (${data.datePercentage}%),
                        Texto: <strong class="text-warning">${data.textCount}</strong> (${data.textPercentage}%)
                    </div>
                `;

                advice.textContent = data.recommendation || 'Haz clic en los botones de prueba para ver qué valores bloquean la conversión.';

                document.getElementById('simToInteger').onclick = function () { testTarget('Entero'); };
                document.getElementById('simToDecimal').onclick = function () { testTarget('Decimal'); };
                document.getElementById('simToDate').onclick = function () { testTarget('Fecha'); };

                function testTarget(targetType) {
                    mismatches.innerHTML = '<div class="text-center p-3"><div class="spinner-border text-warning spinner-border-sm" role="status"></div> Buscando discrepancias...</div>';
                    postForm('@Url.Action("ValidateTextColumn", "DataProfiling")', { tempFileName: temp, columnName: columnName, targetType: targetType, hasHeaders: hasHeaders })
                        .then(resp => {
                            const targetMismatches = resp.mismatchRows || [];

                            if (targetMismatches.length > 0) {
                                advice.className = "alert alert-warning py-2";
                                advice.innerHTML = `Se encontraron <strong>${targetMismatches.length}</strong> valores en la muestra que impiden la conversión a <strong>${targetType}</strong>.`;
                                populateMismatchList(targetMismatches);
                            } else {
                                advice.className = "alert alert-success py-2";
                                advice.innerHTML = `No se encontraron problemas para convertir a <strong>${targetType}</strong> en la muestra analizada.`;
                                mismatches.innerHTML = '<div class="text-success small">Todo parece estar correcto.</div>';
                            }
                        })
                        .catch(err => alert('Error: ' + err.message));
                }

                function populateMismatchList(mismatchArray) {
                    mismatches.innerHTML = '';
                    const rows = document.createElement('div');
                    rows.className = 'row g-2';
                    mismatchArray.forEach(function (m) {
                        const col = document.createElement('div');
                        col.className = 'col-12';
                        col.innerHTML = `<div class="card bg-dark border-danger"><div class="card-body p-2"><div class="d-flex justify-content-between"><div class="text-truncate" style="max-width:70%"><strong>Fila #${m.rowIndex}</strong> — ${m.value}</div><div class="text-muted-light small">${m.reason}</div></div></div></div>`;
                        rows.appendChild(col);
                    });
                    mismatches.appendChild(rows);
                }

                const bsModal = new bootstrap.Modal(modalEl, { backdrop: true });
                bsModal.show();
            }
        })();

        // ==========================================
        // VARIABLES GLOBALES Y FUNCIONES DE VISTA
        // ==========================================
        let filtroTipoGlobal = 'todos';
        let offcanvasInstance = null;
        let topValuesChartInstance = null;

        function cambiarFiltroTipo(btn) {
            document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filtroTipoGlobal = btn.getAttribute('data-filtro');
            ejecutarFiltradoGlobal();
        }

        function ejecutarFiltradoGlobal() {
            const inputBusqueda = document.getElementById('inputBusquedaCol');
            const texto = inputBusqueda ? inputBusqueda.value.toLowerCase() : '';
            const switchAnomalias = document.getElementById('switchAnomaliasGlobal');
            const soloAnomalias = switchAnomalias ? switchAnomalias.checked : false;

            const tarjetas = document.querySelectorAll('.col-card-container');

            tarjetas.forEach(t => {
                const nombre = t.getAttribute('data-nombre');
                const tipo = t.getAttribute('data-tipo');
                const esAnomalia = t.getAttribute('data-anomalia') === 'true';

                const matchTexto = nombre.includes(texto);
                const matchTipo = (filtroTipoGlobal === 'todos' || tipo === filtroTipoGlobal);
                const matchAnomalia = (!soloAnomalias || esAnomalia);

                if (matchTexto && matchTipo && matchAnomalia) {
                    t.style.display = "block";
                    setTimeout(() => { t.style.opacity = "1"; t.style.transform = "scale(1)"; }, 10);
                } else {
                    t.style.opacity = "0";
                    t.style.transform = "scale(0.95)";
                    setTimeout(() => { t.style.display = "none"; }, 300);
                }
            });
        }

        function abrirOffcanvasDetalle(btn) {
            // Asignaciones base
            document.getElementById('offNombre').innerText = btn.getAttribute('data-colname');
            const tipo = btn.getAttribute('data-type');
            const salud = btn.getAttribute('data-health');

            const badgeTipo = document.getElementById('offTipo');
            badgeTipo.innerText = tipo;
            badgeTipo.className = "badge fs-7 " + (tipo === 'Entero' ? 'bg-primary' : (tipo === 'Decimal' ? 'bg-info text-dark' : (tipo === 'Fecha' ? 'bg-success' : 'bg-secondary')));

            const badgeSalud = document.getElementById('offSalud');
            badgeSalud.innerText = salud;
            badgeSalud.className = "badge fs-7 ms-1 " + (salud === 'Óptima' ? 'bg-success' : (salud === 'Advertencia' ? 'bg-warning text-dark' : 'bg-danger'));

            // Métricas de Integridad
            const nullsCount = parseInt(btn.getAttribute('data-nulls'));
            const nullsPct = btn.getAttribute('data-nullspct');
            document.getElementById('offNullsPct').innerText = nullsPct;
            document.getElementById('offNullsCount').innerText = nullsCount.toLocaleString();

            const uniqueCount = parseInt(btn.getAttribute('data-uniques'));
            const uniquePct = btn.getAttribute('data-uniquespct');
            document.getElementById('offUniquesPct').innerText = uniquePct;
            document.getElementById('offUniquesCount').innerText = uniqueCount.toLocaleString();

            // Ocultamiento Dinámico según tipo de columna
            if (tipo === 'Fecha') {
                document.getElementById('seccionEstadisticasNumericas').style.display = 'block';
                document.getElementById('offStatsTitle').innerHTML = '<i class="bi bi-calendar-event text-success me-1"></i> Rango Temporal <i class="bi bi-question-circle text-muted ms-1" style="cursor:help;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-container="body" title="Fechas extremas detectadas."></i>';
                document.getElementById('offLabelMin').innerText = 'FECHA INICIO';
                document.getElementById('offLabelMax').innerText = 'FECHA FIN';
                document.getElementById('offColAvg').style.display = 'none';
                document.getElementById('offMin').innerText = btn.getAttribute('data-min');
                document.getElementById('offMax').innerText = btn.getAttribute('data-max');

                actualizarTooltipsModal();
            } else if (tipo === 'Texto') {
                document.getElementById('seccionEstadisticasNumericas').style.display = 'none';
            } else {
                document.getElementById('seccionEstadisticasNumericas').style.display = 'block';
                document.getElementById('offStatsTitle').innerHTML = '<i class="bi bi-calculator text-info me-1"></i> Estadísticas Numéricas <i class="bi bi-question-circle text-muted ms-1" style="cursor:help;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-container="body" title="Resumen matemático de los valores detectados."></i>';
                document.getElementById('offLabelMin').innerText = 'MÍNIMO';
                document.getElementById('offLabelMax').innerText = 'MÁXIMO';
                document.getElementById('offColAvg').style.display = 'block';
                document.getElementById('offMin').innerText = btn.getAttribute('data-min');
                document.getElementById('offMax').innerText = btn.getAttribute('data-max');
                document.getElementById('offAvg').innerText = btn.getAttribute('data-avg');

                actualizarTooltipsModal();
            }

            // Anomalías
            const zeros = parseInt(btn.getAttribute('data-zeros'));
            const negs = parseInt(btn.getAttribute('data-negatives'));
            const whites = parseInt(btn.getAttribute('data-whitespaces'));

            document.getElementById('offZeros').innerText = zeros;
            document.getElementById('offZeros').className = "badge rounded-pill " + (zeros > 0 ? "bg-warning text-dark" : "bg-secondary");
            document.getElementById('offNegatives').innerText = negs;
            document.getElementById('offNegatives').className = "badge rounded-pill " + (negs > 0 ? "bg-danger" : "bg-secondary");
            document.getElementById('offWhitespaces').innerText = whites;
            document.getElementById('offWhitespaces').className = "badge rounded-pill " + (whites > 0 ? "bg-warning text-dark" : "bg-secondary");

            // Configuración del gráfico de Chart.js
            const topValuesData = btn.closest('.card-body').querySelector('.top-values-data').value;
            let topValues = [];
            try {
                topValues = JSON.parse(topValuesData);
            } catch(e) {
                console.error(e);
            }

            const chartCanvas = document.getElementById('topValuesChart');
            if(topValuesChartInstance) {
                topValuesChartInstance.destroy();
            }

            if(topValues && topValues.length > 0) {
                document.getElementById('chartContainer').style.display = 'block';
                document.getElementById('noChartData').style.display = 'none';

                const labels = topValues.map(v => (v.Value === null || v.Value === "") ? "(Vacío)" : (v.Value.length > 25 ? v.Value.substring(0, 25) + "..." : v.Value));
                const chartData = topValues.map(v => v.Percentage);

                topValuesChartInstance = new Chart(chartCanvas.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: '% de Frecuencia',
                            data: chartData,
                            backgroundColor: 'rgba(255, 193, 7, 0.8)',
                            borderColor: '#ffc107',
                            borderWidth: 1,
                            borderRadius: 4
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) { return " " + context.raw + '% del total'; }
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                max: 100,
                                grid: { color: 'rgba(255, 255, 255, 0.1)' },
                                ticks: { color: '#adb5bd' }
                            },
                            y: {
                                grid: { display: false },
                                ticks: { color: '#adb5bd', font: { family: 'monospace', size: 11 } }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('chartContainer').style.display = 'none';
                document.getElementById('noChartData').style.display = 'block';
            }

            if(!offcanvasInstance) {
                offcanvasInstance = new bootstrap.Offcanvas(document.getElementById('detalleColumnaOffcanvas'));
            }
            offcanvasInstance.show();
        }

        function actualizarTooltipsModal() {
            var tooltips = [].slice.call(document.getElementById('seccionEstadisticasNumericas').querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltips.map(function (t) { return new bootstrap.Tooltip(t, { container: 'body' }); });
        }

        document.addEventListener("DOMContentLoaded", function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    trigger: 'hover',
                    container: 'body'
                });
            });

            const searchInput = document.getElementById('columnSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const term = this.value.toLowerCase();
                    document.querySelectorAll('.col-item').forEach(item => {
                        const text = item.textContent.toLowerCase();
                        item.style.display = text.includes(term) ? 'block' : 'none';
                    });
                });
            }

            const selectAllBtn = document.getElementById('selectAllBtn');
            if (selectAllBtn) {
                selectAllBtn.addEventListener('click', function() {
                    document.querySelectorAll('.key-col-checkbox').forEach(cb => {
                        if (cb.closest('.col-item').style.display !== 'none') {
                            cb.checked = true;
                        }
                    });
                });
            }

            const clearAllBtn = document.getElementById('clearAllBtn');
            if (clearAllBtn) {
                clearAllBtn.addEventListener('click', function() {
                    document.querySelectorAll('.key-col-checkbox').forEach(cb => cb.checked = false);
                    if (searchInput) searchInput.value = '';
                    document.querySelectorAll('.col-item').forEach(item => item.style.display = 'block');
                });
            }
        });
    </script>
}

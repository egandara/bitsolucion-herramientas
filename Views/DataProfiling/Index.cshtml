@{
    ViewData["Title"] = "Perfilamiento de Datos";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-white">Perfilamiento de Datos</h1>
        <p class="form-check-label">Sube un archivo (.xlsx, .csv) para obtener una radiografía automática de su contenido.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card bg-dark text-white border-warning shadow-lg">
                <div class="card-header border-warning" style="background-color: rgba(255, 193, 7, 0.1);">
                    <h4 class="mb-0 text-warning"><i class="bi bi-file-earmark-spreadsheet me-2"></i> Cargar Archivo para Análisis</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Analyze" asp-controller="DataProfiling" method="post" enctype="multipart/form-data">
                        
                        <div class="mb-4">
                            <label for="archivo" class="form-label fw-bold">Seleccionar Archivo:</label>
                            <input class="form-control bg-dark text-white border-secondary" type="file" id="archivo" name="archivo" accept=".xlsx, .xls, .csv, .txt" required>
                            <div class="form-check-label">Formatos soportados: Excel (.xlsx, .xls) y Archivos Planos (.csv, .txt).</div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" id="tieneEncabezados" name="tieneEncabezados" value="true" checked>
                            <label class="form-check-label" for="tieneEncabezados">
                                El archivo contiene encabezados en la primera fila
                            </label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold text-dark">
                                <i class="bi bi-search me-2"></i> Generar Radiografía
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

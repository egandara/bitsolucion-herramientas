@{
    ViewData["Title"] = "Generador de Jobs Multi-Ambiente";
}

<style>
    nav a, aside a, [class*="sidebar"] a, .nav-sidebar a, .main-sidebar a, .nav-link {
        padding-top: 0.18rem !important;
        padding-bottom: 0.18rem !important;
        font-size: 0.8rem !important;
        line-height: 1.2 !important;
    }

    nav li, aside li, [class*="sidebar"] li, .nav-sidebar li, .nav-item {
        margin-top: 0px !important;
        margin-bottom: 0px !important;
        padding-top: 0px !important;
        padding-bottom: 0px !important;
    }

    .custom-placeholder::placeholder {
        color: rgba(255, 255, 255, 0.35) !important;
        opacity: 1 !important;
    }

    .dashboard-xl-container {
        max-width: 1420px !important;
        margin: 0 auto;
    }

    #staging-table th {
        background-color: #111424 !important;
        color: rgba(255, 255, 255, 0.85) !important;
        font-size: 0.82rem;
        padding: 8px;
        border-bottom: 2px solid #ffc107 !important;
    }

    #staging-table td {
        background-color: #0d0f1d !important;
        padding: 12px 10px;
        border-color: rgba(255,255,255,0.06) !important;
        vertical-align: top;
    }

    .perm-table th {
        background-color: #161b22 !important;
        color: rgba(255,255,255,0.7) !important;
        font-size: 0.75rem;
        padding: 6px;
    }

    .perm-table td {
        background-color: #0b0d16 !important;
        padding: 4px;
        border-color: rgba(255,255,255,0.05) !important;
    }

    .perm-scroll-box {
        max-height: 180px !important;
        overflow-y: auto;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 6px;
    }

    .radio-dot-container {
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

    .radio-dot-label {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.7rem;
        font-weight: bold;
        color: #ffffff !important;
        cursor: pointer;
        user-select: none;
    }

    .radio-dot-input {
        appearance: none;
        width: 11px;
        height: 11px;
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-radius: 50%;
        outline: none;
        background-color: transparent;
        cursor: pointer;
        transition: all 0.15s ease-in-out;
        position: relative;
    }

        .radio-dot-input:checked {
            border-color: #ffc107 !important;
            background-color: #ffc107 !important;
            box-shadow: 0 0 6px rgba(255, 193, 7, 0.6);
        }

        .radio-dot-input.run-check:checked {
            border-color: #0dcaf0 !important;
            background-color: #0dcaf0 !important;
            box-shadow: 0 0 6px rgba(13, 202, 240, 0.6);
        }

    .custom-switch-container {
        background-color: #111424 !important;
        border: 1px solid rgba(255, 193, 7, 0.15) !important;
        border-radius: 6px;
        padding: 10px 14px;
    }

    @@keyframes fadeInRow {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .gov-row td {
        background-color: #111424 !important;
        animation: fadeInRow 0.25s ease-in-out;
        border-bottom: 2px solid rgba(255, 193, 7, 0.2) !important;
    }

    .timeline-step {
        border-left: 2px solid rgba(255, 193, 7, 0.3);
        padding-left: 20px;
        position: relative;
        margin-bottom: 20px;
    }

        .timeline-step::before {
            content: '';
            position: absolute;
            left: -8px;
            top: 0;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background-color: #ffc107;
            box-shadow: 0 0 8px rgba(255, 193, 7, 0.6);
        }

    .accordion-button::after {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    .filename-live-badge {
        font-family: monospace;
        font-size: 0.68rem;
        background-color: rgba(0, 0, 0, 0.4);
        padding: 3px 6px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.05);
        word-break: break-all;
    }
</style>

<div class="container-fluid dashboard-xl-container">
    <div class="mb-4 text-center">
        <h1 class="h3 fw-bold mb-2" style="font-family: 'Poppins', sans-serif; color: #fff; font-size: 1.8rem;">Generador de Jobs Multi-Ambiente</h1>
        <p class="mb-3 small text-white-50" style="font-size: 0.85rem;">Transforma, parametriza y limpia configuraciones de tareas para Databricks según el flujo de arquitectura.</p>

        <div class="d-flex justify-content-center mt-3">
            <div class="btn-group shadow-lg" role="group" aria-label="Modo de Operación" style="border-radius: 8px; overflow: hidden; border: 1px solid rgba(255, 193, 7, 0.4);">
                <input type="radio" class="btn-check" name="modeSwitch" id="modeUC" autocomplete="off" checked>
                <label class="btn btn-outline-warning px-5 py-2 fw-bold" for="modeUC" style="font-size: 1.05rem;"><i class="bi bi-boxes me-2"></i>Modo Unity Catalog (YAML)</label>

                <input type="radio" class="btn-check" name="modeSwitch" id="modeLegacy" autocomplete="off">
                <label class="btn btn-outline-info px-5 py-2 fw-bold" for="modeLegacy" style="font-size: 1.05rem;"><i class="bi bi-filetype-json me-2"></i>Modo Legacy (JSON)</label>
            </div>
        </div>
    </div>

    <div id="panel-fase1" class="row g-3">
        <div class="col-12 col-lg-5 d-flex flex-column">
            <div class="card p-3 border-0 flex-grow-1" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">1</div>
                        <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Carga de Entradas</h6>
                    </div>
                    <button id="clear-jobs-btn" class="btn btn-outline-secondary" style="display: none; border-radius: 4px; font-size: 0.7rem; padding: 2px 6px;">Limpiar Cola</button>
                </div>

                <div id="job-drop-zone" class="gemini-drop-zone my-2 p-4 text-center" style="border: 2px dashed rgba(255,255,255,0.1); border-radius: 8px; cursor: pointer; background: rgba(255,255,255,0.01);">
                    <div>
                        <i class="bi bi-folder-symlink fs-2 mb-1 d-block style_icon" style="opacity: 0.4; color: #ffc107;"></i>
                        <label for="job-file-upload" class="btn btn-secondary px-3" style="cursor: pointer; border-radius: 4px; font-size: 0.75rem;">
                            <span id="drop-zone-btn-text">Elegir Archivos (YAML / ZIP)</span>
                            <input id="job-file-upload" type="file" class="d-none" accept=".yml,.yaml,.zip" multiple>
                        </label>
                        <p class="mt-1 small mb-0 text-white-50" style="font-size: 0.75rem;" id="drop-zone-desc">Arrastra aquí tus YAML de configuración y el ZIP con los notebooks del proceso</p>
                    </div>
                </div>

                <div id="job-file-list" class="mb-2 font-monospace" style="font-size: 0.75rem;"></div>

                <div class="alert alert-info border border-info mb-2 p-2 text-white" style="background-color: rgba(13, 202, 240, 0.05); border-radius: 6px;">
                    <h6 class="fw-bold mb-1 text-info" style="font-size: 0.75rem;"><i class="bi bi-lightbulb-fill me-1"></i>¿De dónde saco el YAML de mi Job?</h6>
                    <ol class="mb-2 ps-3 text-white-50" style="font-size: 0.7rem; margin-bottom: 0.5rem !important;">
                        <li>En Databricks ve a <strong>Workflows</strong> y abre tu Job de desarrollo.</li>
                        <li>Haz clic en los tres puntos (<strong>⋮</strong>) en la esquina superior derecha.</li>
                        <li>Selecciona <strong>"Edit as YAML"</strong> y guarda ese contenido en un archivo <code>.yml</code>.</li>
                    </ol>
                    <div class="p-2 rounded" style="background-color: rgba(255, 193, 7, 0.1); border-left: 3px solid #ffc107;">
                        <p class="mb-0 text-warning" style="font-size: 0.7rem;">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i><strong>IMPORTANTE:</strong> Sube siempre el YAML puro recién extraído de Databricks. <strong>No recicles ni reutilices archivos generados anteriormente</strong>, la aplicación se encargará de hacer todo el trabajo pesado de limpieza y parametrización por ti.
                        </p>
                    </div>
                </div>

                <div id="health-check-panel" class="alert alert-dark border border-secondary mt-2 mb-3 d-none" style="background-color: #07091e; padding: 10px 14px; border-radius: 6px;">
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-activity text-info me-2 fs-6"></i>
                        <strong class="text-white" style="font-size: 0.8rem;">Radar de Análisis</strong>
                    </div>
                    <ul class="mb-0 ps-3 text-white-50 font-monospace" style="font-size: 0.7rem;">
                        <li>Configuraciones Detectadas (YAML/JSON): <span id="hc-config-count" class="text-success fw-bold">0</span></li>
                        <li>Paquetes de Código Detectados (ZIP): <span id="hc-zip-count" class="text-primary fw-bold">0</span></li>
                        <li id="hc-uc-warning" class="text-warning mt-1 d-none" style="list-style-type: none; margin-left: -1rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i> Se recomienda subir un .ZIP con los notebooks para auto-descubrir tablas.</li>
                    </ul>
                </div>

                <button type="button" id="btnProcesarFase1" class="btn btn-warning w-100 py-2 fw-bold mt-auto" style="border-radius: 6px; font-size: 0.85rem;" disabled>
                    <span id="spinner-fase1" class="spinner-border spinner-border-sm me-2 d-none"></span>
                    <i class="bi bi-arrow-right-circle me-1"></i>Analizar e Iniciar Conversión
                </button>
            </div>
        </div>

        <div class="col-12 col-lg-7 d-flex flex-column gap-3">
            <div id="card-spark" class="card p-3 border-0 d-none" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2); display: flex; flex-direction: column;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">2</div>
                    <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Spark Configurations de Destino (Solo JSON)</h6>
                </div>
                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label font-monospace small mb-1" style="color: rgba(255,255,255,0.7); font-size: 0.72rem;">Spark Config (Certificación)</label>
                        <span id="badge-json-cert" class="badge font-monospace mb-1 bg-secondary text-white-50" style="font-size: 0.6rem;">Vacío / Opcional</span>
                    </div>
                    <textarea class="form-control font-monospace small text-white custom-placeholder json-linter-input" id="globalCertSpark" rows="2" placeholder='{"spark.master": "local[*, 4]"}' style="background-color: #172a45; border-color: #233554; font-size: 0.72rem; border-radius: 4px;"></textarea>
                </div>
                <div class="mb-1">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label font-monospace small mb-1" style="color: rgba(255,255,255,0.7); font-size: 0.72rem;">Spark Config (Producción)</label>
                        <span id="badge-json-prod" class="badge font-monospace mb-1 bg-secondary text-white-50" style="font-size: 0.6rem;">Vacío / Opcional</span>
                    </div>
                    <textarea class="form-control font-monospace small text-white custom-placeholder json-linter-input" id="globalProdSpark" rows="2" placeholder='{"spark.databricks.cluster.profile": "serverless"}' style="background-color: #172a45; border-color: #233554; font-size: 0.72rem; border-radius: 4px;"></textarea>
                </div>
            </div>

            <div id="card-permissions" class="card p-3 border-0" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">2</div>
                    <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Gobernanza de Permisos (Solo YAML Bundles)</h6>
                </div>
                <div class="table-responsive perm-scroll-box flex-grow-1">
                    <table class="table perm-table align-middle m-0" id="permissions-table">
                        <thead>
                            <tr>
                                <th>Nivel de Acceso</th>
                                <th>Usuario / Grupo Corporativo BCI</th>
                                <th style="width: 40px; text-align: center;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="permissions-tbody">
                            <tr>
                                <td>
                                    <select class="form-select form-select-sm font-monospace py-0 bg-dark text-white border-secondary" style="font-size: 0.72rem; height: 26px;">
                                        <option value="CAN_MANAGE" selected>Can Manage</option>
                                        <option value="IS_OWNER">Is Owner</option>
                                        <option value="CAN_MANAGE_RUN">Can Manage Run</option>
                                        <option value="CAN_VIEW">Can View</option>
                                    </select>
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control font-monospace bg-dark text-white border-secondary perm-user-name" placeholder="usuario" style="font-size: 0.72rem; height: 26px;" />
                                        <input type="text" class="form-control font-monospace bg-dark text-white-50 border-secondary perm-user-domain" value="@@bci.cl" style="font-size: 0.72rem; height: 26px; max-width: 90px;" />
                                    </div>
                                </td>
                                <td class="text-center"><button type="button" class="btn btn-outline-danger py-0" onclick="$(this).closest('tr').remove()" style="height: 24px; line-height: 1;">&times;</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-outline-warning mt-2 ms-auto" id="add-permission-row" style="font-size: 0.7rem; padding: 2px 8px; border-radius: 4px;"><i class="bi bi-plus-circle me-1"></i>Añadir Permiso</button>
            </div>

            <div id="card-autocert" class="card p-3 border-0" style="background-color: rgba(255, 193, 7, 0.04); border: 1px solid rgba(255, 193, 7, 0.2) !important; border-radius: 10px;">
                <div class="form-check form-switch custom-switch-warning d-flex align-items-center mb-3">
                    <input class="form-check-input" type="checkbox" id="chkMasterAutocert" style="cursor: pointer; width: 38px; height: 20px; margin-top:0;">
                    <label class="form-check-label fw-bold text-warning ms-3" for="chkMasterAutocert" style="cursor: pointer; user-select: none; font-size: 0.95rem;">
                        🛡️ Activar Autocertificación
                    </label>
                </div>
                <div class="mb-1 px-1">
                    <label for="txtBundleName" class="form-label text-white small mb-1" style="font-size: 0.74rem; font-weight: 600;"><i class="bi bi-git me-1 text-warning"></i> Nombre del Repositorio / Bundle BCI:</label>
                    <input type="text" id="txtBundleName" class="form-control form-control-sm font-monospace bg-dark text-white border-secondary custom-placeholder shadow-sm" placeholder="Escaneando notebook_path automáticamente..." value="" style="font-size:0.75rem; height:26px; padding:2px 6px; color:#fff !important; border-width: 1px;" />
                </div>
                <p class="text-white-50 ms-1 mt-2 mb-0" style="font-size: 0.72rem; line-height: 1.3;">El nombre ingresado se asignará a la propiedad <code class="text-warning">bundle.name</code> y enlazará las rutas absolutas del CI.</p>
            </div>

            <div class="accordion" id="accordionCheatsheet">
                <div class="accordion-item bg-dark border-secondary" style="border-radius: 8px; overflow: hidden;">
                    <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button collapsed fw-bold font-monospace shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne" style="background-color: #0b0d16; color: #ffc107; font-size: 0.75rem; padding: 12px 16px;">
                            <i class="bi bi-journal-check me-2 fs-6"></i> Recordatorio de Estándares BCI
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#accordionCheatsheet">
                        <div class="accordion-body text-white-50" style="background-color: #111424; font-size: 0.72rem; padding: 14px 18px;">
                            <div class="row">
                                <div class="col-6">
                                    <ul class="mb-0 ps-3" style="list-style-type: square;">
                                        <li class="mb-1"><strong class="text-white">Tablas:</strong> Solo minúsculas, máx. 30 caracteres. Prohibido el uso de <code>SELECT *</code>.</li>
                                        <li class="mb-1"><strong class="text-white">Bitácora Oficial:</strong> <code>catalog_bcidigital_dsr_001.sch_ida.bitacora_allpurpose</code></li>
                                    </ul>
                                </div>
                                <div class="col-6 border-start border-secondary border-opacity-25">
                                    <ul class="mb-0 ps-3" style="list-style-type: square;">
                                        <li class="mb-1"><strong class="text-white">Matriz Tipo A:</strong> Origen Delta ➔ Destino Delta.</li>
                                        <li class="mb-1"><strong class="text-white">Storage Conv:</strong> <code>sbx</code> (Desarrollo), <code>dev</code> (Certificación), <code>prd</code> (Producción).</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="panel-fase2" class="mt-3 d-none" style="animation: fadeIn 0.3s ease-in-out;">
        <form asp-action="DownloadPackage" method="post" id="package-form">
            <div id="hidden-permissions-container"></div>

            <div class="card p-4 border-0" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3 pb-2">
                    <div>
                        <h5 class="fw-bold text-warning mb-0" style="font-family: 'Poppins', sans-serif; font-size: 1.1rem;"><i class="bi bi-shield-fill-exclamation me-2"></i>Fase de Confirmación de Nombres y Flujos</h5>
                        <p class="mb-0 small text-white-50" style="font-size: 0.75rem;">Modifica o confirma el nombre comercial del Job. La información a continuación impactará el formato final.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" id="btnVolverFase1" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 4px; font-size: 0.75rem;"><i class="bi bi-arrow-left"></i> Volver a Carga</button>
                    </div>
                </div>

                <div class="table-responsive border border-secondary border-opacity-25 rounded mb-4">
                    <table class="table align-middle m-0 font-monospace" id="staging-table" style="font-size: 0.75rem;">
                        <thead>
                            <tr>
                                <th style="width: 25%;">Archivo Cargado</th>
                                <th style="width: 25%;">Entorno Desarrollo</th>
                                <th style="width: 25%;">Entorno Certificación</th>
                                <th style="width: 25%;">Entorno Producción</th>
                            </tr>
                        </thead>
                        <tbody id="staging-tbody"></tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-3 mt-2 border-top border-secondary border-opacity-25">
                    <button type="button" id="btn-guide-modal" class="btn btn-outline-info px-4 py-2 fw-bold d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#manualGuideModal" style="border-radius: 6px; font-size: 0.9rem;">
                        <i class="bi bi-journal-richtext fs-5"></i> Ver Guía de UI Databricks
                    </button>

                    <div class="d-flex align-items-center ms-auto">
                        <div class="text-end me-3 text-white-50 small">
                            <span class="d-block fw-bold text-white">¿Todo listo?</span>
                            <span style="font-size: 0.75rem;">Haz clic para empaquetar el flujo final en un ZIP.</span>
                        </div>
                        <button type="submit" class="btn btn-success px-5 py-2 fw-bold d-flex align-items-center gap-2 shadow-sm" style="border-radius: 6px; font-size: 0.95rem;">
                            <i class="bi bi-cloud-arrow-down-fill fs-5"></i> Descargar Estructuras ZIP
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="manualGuideModal" tabindex="-1" aria-labelledby="manualGuideModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content text-white" style="background-color: #0b0d16; border: 1px solid #ffc107;">
            <div class="modal-header border-secondary">
                <h5 class="modal-title fw-bold text-warning" id="manualGuideModalLabel"><i class="bi bi-info-circle-fill me-2"></i>Guía de Integración Manual en UI</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-4" style="background-color: #07091e;">
                <p class="mb-4 text-white-50 small">Si no deseas usar el YAML generado y prefieres agregar el notebook de certificación descargado a tu Job existente directamente desde la interfaz gráfica de Databricks, sigue estos pasos:</p>

                <div class="timeline-step">
                    <h6 class="fw-bold text-white mb-1">Paso 1: Agregar la Tarea</h6>
                    <p class="text-white-50 small mb-2">Ingresa a tu Job en Databricks (Workflows). Al final de tu diagrama, haz clic en el botón <span class="badge bg-primary">+ Add task</span>.</p>
                </div>

                <div class="timeline-step">
                    <h6 class="fw-bold text-white mb-1">Paso 2: Configurar el Tipo de Tarea</h6>
                    <ul class="text-white-50 small mb-2" style="list-style-type: none; padding-left: 0;">
                        <li><strong>Task name:</strong> <code class="text-warning bg-dark px-1">Auto_Certificacion_BigData</code></li>
                        <li><strong>Type:</strong> Selecciona <span class="badge bg-secondary">Notebook</span></li>
                        <li><strong>Source:</strong> Selecciona <span class="badge bg-secondary">Workspace</span></li>
                        <li><strong>Path:</strong> Selecciona el archivo <code class="text-info bg-dark px-1">auto_certification_bigdata.scala</code> descargado.</li>
                        <li><strong>Depends on:</strong> Selecciona la <em>última tarea</em> real de tu flujo de trabajo.</li>
                    </ul>
                </div>

                <div class="timeline-step">
                    <h6 class="fw-bold text-white mb-1">Paso 3: Añadir Parámetros (Parameters)</h6>
                    <p class="text-white-50 small mb-2">Haz clic en <strong>+ Add</strong> en la sección Parameters e inyecta estas variables exactas:</p>
                    <div class="table-responsive">
                        <table class="table table-dark table-bordered table-sm font-monospace" style="font-size: 0.7rem;">
                            <thead class="text-warning">
                                <tr><th>Key</th><th>Value (Ejemplo)</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>ejecutarAutocertificacion</td><td>true</td></tr>
                                <tr><td>origen1</td><td>nombre_tabla_origen</td></tr>
                                <tr><td>destino1</td><td>nombre_tabla_destino</td></tr>
                                <tr><td>nombreJob</td><td>Mi_Proceso_BCI</td></tr>
                                <tr><td>schemaBitacora</td><td>catalog_bcidigital_prd_001.prd_slv_governance</td></tr>
                                <tr><td>tipo</td><td>A</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="timeline-step" style="border-left-color: transparent;">
                    <h6 class="fw-bold text-success mb-1"><i class="bi bi-check-circle-fill me-1"></i>Paso 4: Guardar y Ejecutar</h6>
                    <p class="text-white-50 small mb-0">Guarda la tarea. Tu Job ahora certificará automáticamente los linajes al terminar.</p>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.jobParametersMap = {};
        document.addEventListener('DOMContentLoaded', function () {
            const fileUpload = document.getElementById('job-file-upload');
            const dropZone = document.getElementById('job-drop-zone');
            const fileListContainer = document.getElementById('job-file-list');
            const btnProcesarFase1 = document.getElementById('btnProcesarFase1');
            const clearJobsBtn = document.getElementById('clear-jobs-btn');

            const modeUC = document.getElementById('modeUC');
            const modeLegacy = document.getElementById('modeLegacy');
            const cardSpark = document.getElementById('card-spark');
            const cardPerms = document.getElementById('card-permissions');
            const cardAutocert = document.getElementById('card-autocert');
            const accordionCheatsheet = document.getElementById('accordionCheatsheet');
            const btnGuideModal = document.getElementById('btn-guide-modal');
            const dropZoneBtnText = document.getElementById('drop-zone-btn-text');
            const dropZoneDesc = document.getElementById('drop-zone-desc');
            const healthCheckPanel = document.getElementById('health-check-panel');

            let jobStore = new DataTransfer();
            let jsonConfigsValid = true;

            function applyMode() {
                jobStore = new DataTransfer();
                fileUpload.value = '';
                renderJobList();

                if (modeUC.checked) {
                    cardSpark.classList.add('d-none');
                    cardPerms.classList.remove('d-none');
                    cardAutocert.classList.remove('d-none');
                    accordionCheatsheet.classList.remove('d-none');
                    btnGuideModal.classList.remove('d-none');
                    fileUpload.accept = ".yml,.yaml,.zip";
                    dropZoneBtnText.innerText = "Elegir Archivos (YAML / ZIP)";
                    dropZoneDesc.innerText = "Arrastra aquí tus YAML de configuración y el ZIP con los notebooks del proceso";
                } else {
                    cardSpark.classList.remove('d-none');
                    cardPerms.classList.add('d-none');
                    cardAutocert.classList.add('d-none');
                    accordionCheatsheet.classList.add('d-none');
                    btnGuideModal.classList.add('d-none');
                    fileUpload.accept = ".json";
                    dropZoneBtnText.innerText = "Elegir Archivos (JSON)";
                    dropZoneDesc.innerText = "Arrastra aquí tus configuraciones de Databricks en formato JSON antiguo";
                }
                evalProcesarBtnState();
            }

            modeUC.addEventListener('change', applyMode);
            modeLegacy.addEventListener('change', applyMode);
            applyMode();

            const validateFileStructure = (file) => {
                return new Promise((resolve, reject) => {
                    if (file.name.toLowerCase().endsWith('.zip')) {
                        resolve();
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const text = e.target.result;

                        if (modeUC.checked && (file.name.endsWith('.yml') || file.name.endsWith('.yaml'))) {
                            const repoMatch = text.match(/(?:\.bundles\/|\/Repos\/[^\/]+\/|\/Shared\/)([^\/]+)\//i);
                            if (repoMatch && repoMatch[1]) {
                                const bundleInput = document.getElementById('txtBundleName');
                                if (!bundleInput.value) {
                                    bundleInput.value = repoMatch[1];
                                    toastr.info(`Repositorio inferido automáticamente: ${repoMatch[1]}`, "Inferencia Exitosa");
                                }
                            }
                        }

                        if (file.name.endsWith('.json')) {
                            try { JSON.parse(text); resolve(); }
                            catch (err) { reject(new Error("Faltan llaves, comillas o comas finales.")); }
                        } else {
                            if (text.includes('resources:') || text.includes('tasks:') || text.includes('bundle:')) { resolve(); }
                            else { reject(new Error("No se detectó una cabecera de recursos válida de Databricks.")); }
                        }
                    };
                    reader.onerror = () => reject(new Error("Error físico de lectura."));
                    reader.readAsText(file);
                });
            };

            const handleFiles = async (files) => {
                btnProcesarFase1.disabled = true;
                for (const file of files) {
                    const ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
                    if (modeUC.checked && ext !== '.yml' && ext !== '.yaml' && ext !== '.zip') {
                        toastr.warning(`En Modo UC solo se admiten: .yml, .yaml, .zip`);
                        continue;
                    }
                    if (modeLegacy.checked && ext !== '.json') {
                        toastr.warning(`En Modo Legacy solo se admiten: .json`);
                        continue;
                    }

                    try {
                        await validateFileStructure(file);
                        jobStore.items.add(file);
                    } catch (error) {
                        toastr.error(`❌ Estructura Inválida en "${file.name}": ${error.message}`);
                    }
                }
                renderJobList();
            };

            if(fileUpload) fileUpload.addEventListener('change', (e) => handleFiles(e.target.files));
            if(dropZone) {
                dropZone.addEventListener('dragover', (e) => e.preventDefault());
                dropZone.addEventListener('drop', (e) => { e.preventDefault(); handleFiles(e.dataTransfer.files); });
            }

            function renderJobList() {
                fileListContainer.innerHTML = '';
                clearJobsBtn.style.display = 'none';

                let configCount = 0;
                let zipCount = 0;
                if (jobStore.files.length > 0) {
                    const list = document.createElement('ul');
                    list.className = 'list-group m-0 p-0';
                    Array.from(jobStore.files).forEach((file, index) => {
                        const listItem = document.createElement('li');

                        let badgeExt = "bg-secondary";
                        if(file.name.endsWith('.zip')) {
                            badgeExt = "bg-primary";
                            zipCount++;
                        } else {
                            if(file.name.endsWith('.yml') || file.name.endsWith('.yaml')) badgeExt = "bg-warning text-dark";
                            configCount++;
                        }

                        listItem.className = 'list-group-item d-flex justify-content-between align-items-center py-1 px-2 border-secondary bg-dark text-white-50';
                        listItem.innerHTML = `<span class="text-truncate" style="max-width:85%;"><span class="badge ${badgeExt} me-2" style="font-size:0.6rem;">${file.name.split('.').pop().toUpperCase()}</span>${file.name}</span>`;

                        const removeBtn = document.createElement('button');
                        removeBtn.className = 'btn btn-danger btn-sm py-0 px-1';
                        removeBtn.innerHTML = '&times;';
                        removeBtn.type = 'button';
                        removeBtn.onclick = () => {
                            const newFiles = new DataTransfer();
                            Array.from(jobStore.files).forEach((f, i) => { if (i !== index) newFiles.items.add(f); });
                            jobStore = newFiles;
                            renderJobList();
                        };
                        listItem.appendChild(removeBtn);
                        list.appendChild(listItem);
                    });
                    fileListContainer.appendChild(list);
                    clearJobsBtn.style.display = 'block';

                    healthCheckPanel.classList.remove('d-none');
                    document.getElementById('hc-config-count').innerText = configCount;
                    document.getElementById('hc-zip-count').innerText = zipCount;
                    if(modeUC.checked && zipCount === 0 && configCount > 0) {
                        document.getElementById('hc-uc-warning').classList.remove('d-none');
                    } else {
                        document.getElementById('hc-uc-warning').classList.add('d-none');
                    }
                } else {
                    healthCheckPanel.classList.add('d-none');
                }

                evalProcesarBtnState();
            }

            if (clearJobsBtn) {
                clearJobsBtn.addEventListener('click', () => {
                    jobStore = new DataTransfer();
                    fileUpload.value = '';
                    renderJobList();
                });
            }

            document.getElementById('add-permission-row').addEventListener('click', function() {
                const rowHtml = `<tr>
                    <td>
                        <select class="form-select form-select-sm font-monospace py-0 bg-dark text-white border-secondary" style="font-size: 0.72rem; height: 26px;">
                            <option value="CAN_MANAGE" selected>Can Manage</option>
                            <option value="IS_OWNER">Is Owner</option>
                            <option value="CAN_MANAGE_RUN">Can Manage Run</option>
                            <option value="CAN_VIEW">Can View</option>
                        </select>
                    </td>
                    <td>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control font-monospace bg-dark text-white border-secondary perm-user-name" placeholder="usuario" style="font-size: 0.72rem; height: 26px;" />
                            <input type="text" class="form-control font-monospace bg-dark text-white-50 border-secondary perm-user-domain" value="@@bci.cl" style="font-size: 0.72rem; height: 26px; max-width: 90px;" />
                        </div>
                    </td>
                    <td class="text-center"><button type="button" class="btn btn-outline-danger py-0" onclick="$(this).closest('tr').remove()" style="height: 24px; line-height: 1;">&times;</button></td>
                </tr>`;
                $('#permissions-tbody').append(rowHtml);
            });

            function validateJsonInput(textareaId, badgeId) {
                const txtArea = document.getElementById(textareaId);
                const badge = document.getElementById(badgeId);
                const val = txtArea.value.trim();

                if (!val) {
                    badge.className = "badge font-monospace bg-secondary text-white-50";
                    badge.textContent = "Vacío / Opcional";
                    txtArea.style.borderColor = "#233554";
                    return true;
                }
                try {
                    JSON.parse(val);
                    badge.className = "badge font-monospace bg-success text-white";
                    badge.textContent = "✓ JSON Válido";
                    txtArea.style.borderColor = "#198754";
                    return true;
                } catch (e) {
                    badge.className = "badge font-monospace bg-danger text-white";
                    badge.textContent = "✗ JSON Inválido";
                    txtArea.style.borderColor = "#dc3545";
                    return false;
                }
            }

            function evalProcesarBtnState() {
                const isCertValid = validateJsonInput('globalCertSpark', 'badge-json-cert');
                const isProdValid = validateJsonInput('globalProdSpark', 'badge-json-prod');
                jsonConfigsValid = isCertValid && isProdValid;

                const hasValidJobConfig = Array.from(jobStore.files).some(f => !f.name.toLowerCase().endsWith('.zip'));
                if (modeUC.checked) {
                    btnProcesarFase1.disabled = !hasValidJobConfig;
                } else {
                    btnProcesarFase1.disabled = !(hasValidJobConfig && jsonConfigsValid);
                }
            }

            $('.json-linter-input').on('input', function() { evalProcesarBtnState(); });

            window.updateJobFileName = function(index) {
                const qaFlag = document.querySelector(`input[name="dev_radio_${index}"]:checked`)?.value || 'qa';
                const runFlag = document.querySelector(`input[name="radRunProd_${index}"]:checked`)?.value || 'norun';
                let baseDesc = document.getElementById(`baseDesc_${index}`).value.trim() || 'descripcion';

                const seqStr = String(index + 1).padStart(3, '0');
                const finalFileName = `${seqStr}-${qaFlag}-${runFlag}-${baseDesc}`;

                document.getElementById(`devNames_${index}`).value = finalFileName;
                document.getElementById(`certNames_${index}`).value = finalFileName;
                document.getElementById(`prodNames_${index}`).value = finalFileName;

                const badge = document.getElementById(`badgeDev_${index}`);
                if (badge) badge.innerText = finalFileName + ".yml";

                const mainRow = document.querySelector(`.main-job-row[data-row-idx="${index}"]`);
                const isProv = mainRow ? mainRow.getAttribute('data-is-prov') === 'true' : false;

                const govRow = document.getElementById(`govRow_${index}`);
                if (govRow) {
                    if (qaFlag === 'qa' && !isProv) govRow.classList.remove('d-none');
                    else govRow.classList.add('d-none');
                }
            };

            $('#btnProcesarFase1').on('click', function(e) {
                e.preventDefault();
                if (modeLegacy.checked && !jsonConfigsValid) return;

                var ajaxData = new FormData();
                Array.from(jobStore.files).forEach(file => { ajaxData.append('files', file); });
                ajaxData.append('certSparkConf', $('#globalCertSpark').val());
                ajaxData.append('prodSparkConf', $('#globalProdSpark').val());

                const masterAutoCert = modeUC.checked ? document.getElementById('chkMasterAutocert').checked : false;
                ajaxData.append('masterAutocert', masterAutoCert);

                $('#spinner-fase1').removeClass('d-none');
                btnProcesarFase1.disabled = true;

                $.ajax({
                    url: '/JobConverter/PrepareStaging',
                    type: 'POST',
                    data: ajaxData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        $('#spinner-fase1').addClass('d-none');
                        btnProcesarFase1.disabled = false;
                        if (response.success) {
                            $('#staging-tbody').empty();
                            window.jobParametersMap = {};

                            if(modeUC.checked) {
                                $('#staging-table thead').html(`<tr><th style="width: 30%;">Archivo Cargado</th><th style="width: 70%;">Configuración Final del Job (DABs)</th></tr>`);
                            } else {
                                $('#staging-table thead').html(`<tr><th style="width: 28%;">Archivo Cargado</th><th style="width: 24%;">Nombre Desarrollo</th><th style="width: 24%;">Nombre Certificación</th><th style="width: 24%;">Nombre Producción</th></tr>`);
                            }

                            response.jobs.forEach((job, index) => {
                                window.jobParametersMap[index] = job.parameters || [];

                                var badgeType = job.isYaml ? '<span class="badge bg-warning text-dark me-1" style="font-size:0.6rem;">YAML BUNDLE</span>' : '<span class="badge bg-info text-dark me-1" style="font-size:0.6rem;">JSON PLANO</span>';
                                var mainRow = '';
                                var govRow = '';

                                const isGovRowHidden = (masterAutoCert && !job.isProvisioning) ? "" : "d-none";

                                let cleanBaseDesc = job.suggestedDevName.replace('.yml', '').replace('.yaml', '');
                                cleanBaseDesc = cleanBaseDesc.replace(/^\d{3}-(?:qa|noqa)-(?:run|norun)-/, '');

                                const runCheckedAttr = job.isProvisioning ? "checked" : "";
                                const noRunCheckedAttr = job.isProvisioning ? "" : "checked";

                                if (job.isYaml) {
                                    mainRow = `
                                    <tr class="main-job-row" data-row-idx="${index}" data-is-prov="${job.isProvisioning}" data-suggested-name="${cleanBaseDesc}" data-is-yaml="true" style="border-bottom: transparent !important;">
                                        <td class="small fw-bold text-wrap" style="color: #ffffff !important; max-width:240px; padding: 12px 6px;">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <span>${badgeType}${job.originalFileName}</span>
                                            </div>
                                            <input type="hidden" name="fileKeys" value="${job.fileKey}" />
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column gap-2 mb-2">
                                                <label class="text-white-50 mb-0 fw-bold" style="font-size: 0.65rem;">Descripción Base BCI (Sin prefijos/flags):</label>
                                                <input type="text" id="baseDesc_${index}" class="form-control form-control-sm font-monospace bg-dark text-warning border-secondary shadow-sm" value="${cleanBaseDesc}" style="font-size:0.75rem;" oninput="updateJobFileName(${index})" title="Edita el nombre base del Job." />

                                                <div class="d-flex align-items-center gap-3 p-2 border border-secondary rounded mt-1 shadow-inner" style="background-color: #111424;">
                                                    <div class="radio-dot-container">
                                                        <span class="text-warning fw-bold" style="font-size:0.68rem; letter-spacing:0.3px;">Autocert QA:</span>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="dev_radio_${index}" value="qa" checked onchange="updateJobFileName(${index})"> qa</label>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="dev_radio_${index}" value="noqa" onchange="updateJobFileName(${index})"> noqa</label>
                                                    </div>
                                                    <div class="radio-dot-container border-start border-secondary ps-3">
                                                        <span class="text-info fw-bold" style="font-size:0.68rem; letter-spacing:0.3px;">Producción:</span>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input run-check" name="radRunProd_${index}" value="norun" ${noRunCheckedAttr} onchange="updateJobFileName(${index})"> norun</label>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input run-check" name="radRunProd_${index}" value="run" ${runCheckedAttr} onchange="updateJobFileName(${index})"> run</label>
                                                    </div>
                                                </div>

                                                <div class="filename-live-badge text-warning d-inline-block px-3 py-1 mt-1 text-center" id="badgeDev_${index}" style="font-size: 0.8rem; font-weight: bold;">Calculando...</div>
                                            </div>

                                            <input type="hidden" id="devNames_${index}" name="devNames" value="" />
                                            <input type="hidden" id="certNames_${index}" name="certNames" value="" />
                                            <input type="hidden" id="prodNames_${index}" name="prodNames" value="" />

                                            <input type="hidden" id="devAutocert_${index}" name="devAutocert" value="true" />
                                            <input type="hidden" id="certAutocert_${index}" name="certAutocert" value="false" />
                                            <input type="hidden" id="prodAutocert_${index}" name="prodAutocert" value="false" />
                                        </td>
                                    </tr>`;

                                    govRow = `
                                    <tr id="govRow_${index}" class="${isGovRowHidden} gov-row">
                                        <td colspan="2" class="p-3 shadow-inner">
                                            <h6 class="text-warning fw-bold mb-3" style="font-size: 0.85rem;"><i class="bi bi-shield-check me-1"></i> Linaje de Tablas (Mapeo de Autocertificación)</h6>
                                            <div class="row g-3">
                                                <div class="col-md-6 border-end border-secondary border-opacity-25">
                                                    <label class="text-warning fw-bold small mb-2"><i class="bi bi-box-arrow-in-right me-1"></i> Orígenes (Insumos BCI)</label>
                                                    <div id="sourceTablesContainer_${index}" class="d-flex flex-column gap-2"></div>
                                                    <button type="button" class="btn btn-sm btn-outline-warning mt-2 py-1 w-100" onclick="addTableMappingRow(${index}, 'source')" style="font-size: 0.75rem;"><i class="bi bi-plus-lg"></i> Añadir Tabla Origen</button>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="text-success fw-bold small mb-2"><i class="bi bi-box-arrow-down-left me-1"></i> Destinos (Resultados)</label>
                                                    <div id="targetTablesContainer_${index}" class="d-flex flex-column gap-2"></div>
                                                    <button type="button" class="btn btn-sm btn-outline-success mt-2 py-1 w-100" onclick="addTableMappingRow(${index}, 'target')" style="font-size: 0.75rem;"><i class="bi bi-plus-lg"></i> Añadir Tabla Destino</button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>`;
                                } else {
                                    mainRow = `
                                    <tr class="main-job-row" data-row-idx="${index}" data-suggested-name="${job.suggestedDevName}" data-is-yaml="false">
                                        <td class="small fw-bold text-wrap" style="color: #ffffff !important; max-width:240px; padding: 12px 6px;">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <span>${badgeType}${job.originalFileName}</span>
                                                <button type="button" class="btn btn-outline-secondary btn-reset-row ms-2" title="Restablecer" style="padding:0px 4px; font-size:0.65rem;"><i class="bi bi-arrow-counterclockwise"></i></button>
                                            </div>
                                            <input type="hidden" name="fileKeys" value="${job.fileKey}" />
                                        </td>
                                        <td>
                                            <input type="text" name="devNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary dev-name-input" value="${job.suggestedDevName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                            <input type="hidden" name="devAutocert" value="false" />
                                        </td>
                                        <td>
                                            <input type="text" name="certNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary cert-name-input" value="${job.suggestedCertName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                            <input type="hidden" name="certAutocert" value="false" />
                                        </td>
                                        <td>
                                            <input type="text" name="prodNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary prod-name-input" value="${job.suggestedProdName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                            <input type="hidden" name="prodAutocert" value="false" />
                                        </td>
                                    </tr>`;
                                }
                                $('#staging-tbody').append(mainRow);
                                if(govRow) $('#staging-tbody').append(govRow);

                                if (job.isYaml) {
                                    updateJobFileName(index);
                                }

                                if (job.isYaml && masterAutoCert) {
                                    if (job.autoSources && job.autoSources.length > 0) {
                                        job.autoSources.forEach(src => addTableMappingRow(index, 'source', src.param, src.table));
                                    } else addTableMappingRow(index, 'source');

                                    if (job.autoTargets && job.autoTargets.length > 0) {
                                        job.autoTargets.forEach(tgt => addTableMappingRow(index, 'target', tgt.param, tgt.table));
                                    } else addTableMappingRow(index, 'target');
                                }
                            });
                            $('#panel-fase1').addClass('d-none');
                            $('#panel-fase2').removeClass('d-none');
                            toastr.success('Jobs analizados correctamente.');
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function() {
                        $('#spinner-fase1').addClass('d-none');
                        btnProcesarFase1.disabled = false;
                        toastr.error('Error de comunicación con el motor de empaquetado.');
                    }
                });
            });

            $(document).on('input', '.dev-name-input', function() {
                var parentRow = $(this).closest('tr');
                var currentVal = $(this).val();
                parentRow.find('.cert-name-input').val(currentVal);
                parentRow.find('.prod-name-input').val(currentVal);
            });

            $(document).on('click', '.btn-reset-row', function() {
                var parentRow = $(this).closest('tr');
                var baseSuggestedName = parentRow.data('suggested-name');
                parentRow.find('.dev-name-input').val(baseSuggestedName);
                parentRow.find('.cert-name-input').val(baseSuggestedName);
                parentRow.find('.prod-name-input').val(baseSuggestedName);
            });

            $('#btnVolverFase1').on('click', function() {
                $('#panel-fase2').addClass('d-none');
                $('#panel-fase1').removeClass('d-none');
            });

            $('#package-form').on('submit', function(e) {
                const hiddenContainer = document.getElementById('hidden-permissions-container');
                hiddenContainer.innerHTML = '';

                const bundleNameVal = modeUC.checked ? ($('#txtBundleName').val().trim() || "bundle") : "bundle";
                if (modeUC.checked && bundleNameVal === "bundle" && $('#txtBundleName').val().trim() === "") {
                    e.preventDefault();
                    toastr.warning("El campo 'Nombre del Repositorio' es obligatorio.");
                    return;
                }

                $(hiddenContainer).append(`<input type="hidden" name="bundleName" value="${bundleNameVal}" />`);

                $('#permissions-tbody tr').each(function() {
                    const level = $(this).find('select').val();
                    const userName = $(this).find('.perm-user-name').val().trim();
                    const userDomain = $(this).find('.perm-user-domain').val().trim();
                    if(userName) {
                        const fullUser = userName + (userDomain.startsWith('@@') ? userDomain : '@@' + userDomain);
                        $(hiddenContainer).append(`<input type="hidden" name="permLevels" value="${level}" />`);
                        $(hiddenContainer).append(`<input type="hidden" name="permUsers" value="${fullUser}" />`);
                    }
                });

                $('#staging-tbody > tr.main-job-row').each(function() {
                    const index = $(this).data('row-idx');
                    const isYaml = $(this).data('is-yaml') === true;

                    if (isYaml && modeUC.checked) {
                        const sourceRows = document.querySelectorAll(`#sourceTablesContainer_${index} .mapping-row`);
                        let sourceList = [];
                        sourceRows.forEach(row => {
                            const param = row.querySelector('select').value;
                            const table = row.querySelector('input').value.trim();
                            if(table) sourceList.push(`${param}|${table}`);
                        });

                        const targetRows = document.querySelectorAll(`#targetTablesContainer_${index} .mapping-row`);
                        let targetList = [];
                        targetRows.forEach(row => {
                            const param = row.querySelector('select').value;
                            const table = row.querySelector('input').value.trim();
                            if(table) targetList.push(`${param}|${table}`);
                        });

                        $(hiddenContainer).append(`<input type="hidden" name="sourceTables" value="${sourceList.join(';')}" />`);
                        $(hiddenContainer).append(`<input type="hidden" name="targetTables" value="${targetList.join(';')}" />`);
                    } else {
                        $(hiddenContainer).append(`<input type="hidden" name="sourceTables" value="" />`);
                        $(hiddenContainer).append(`<input type="hidden" name="targetTables" value="" />`);
                    }
                });

                return true;
            });
        });

        window.addTableMappingRow = function(index, type, prefillParam = '', prefillTable = '') {
            const container = document.getElementById(`${type}TablesContainer_${index}`);
            const params = window.jobParametersMap[index] || [];
            let optionsHtml = '<option value="">-- Sin Variable (Texto Libre) --</option>';
            params.forEach(p => {
                const isSelected = (p === prefillParam) ? "selected" : "";
                optionsHtml += `<option value="${p}" ${isSelected}>${p}</option>`;
            });
            const rowHtml = `
                <div class="d-flex align-items-center gap-2 mb-1 mapping-row">
                    <select class="form-select form-select-sm bg-dark text-white border-secondary font-monospace" style="width: 48%; font-size: 0.7rem;">
                        ${optionsHtml}
                    </select>
                    <span class="text-white-50" style="font-weight:bold;">.</span>
                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary font-monospace" placeholder="nombre_tabla" style="width: 48%; font-size: 0.7rem;" value="${prefillTable}" />
                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="this.parentElement.remove()" style="font-size: 0.75rem;"><i class="bi bi-trash"></i></button>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', rowHtml);
        }
    </script>
}

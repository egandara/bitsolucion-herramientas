@{
    ViewData["Title"] = "Generador de Jobs Multi-Ambiente";
}

<style>
    nav a, aside a, [class*="sidebar"] a, .nav-sidebar a, .main-sidebar a, .nav-link {
        padding-top: 0.18rem !important;
        padding-bottom: 0.18rem !important;
        font-size: 0.8rem !important;
        line-height: 1.2 !important;
    }

    nav li, aside li, [class*="sidebar"] li, .nav-sidebar li, .nav-item {
        margin-top: 0px !important;
        margin-bottom: 0px !important;
        padding-top: 0px !important;
        padding-bottom: 0px !important;
    }

    .custom-placeholder::placeholder {
        color: rgba(255, 255, 255, 0.35) !important;
        opacity: 1 !important;
    }

    .dashboard-xl-container {
        max-width: 1420px !important;
        margin: 0 auto;
    }

    #staging-table th {
        background-color: #111424 !important;
        color: rgba(255, 255, 255, 0.85) !important;
        font-size: 0.82rem;
        padding: 8px;
        border-bottom: 2px solid #ffc107 !important;
    }

    #staging-table td {
        background-color: #0d0f1d !important;
        padding: 10px 8px;
        border-color: rgba(255,255,255,0.06) !important;
    }

    .perm-table th {
        background-color: #161b22 !important;
        color: rgba(255,255,255,0.7) !important;
        font-size: 0.75rem;
        padding: 6px;
    }

    .perm-table td {
        background-color: #0b0d16 !important;
        padding: 4px;
        border-color: rgba(255,255,255,0.05) !important;
    }

    .perm-scroll-box {
        max-height: 220px !important;
        overflow-y: auto;
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 6px;
    }

    .radio-dot-container {
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

    .radio-dot-label {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.7rem;
        font-weight: bold;
        color: #ffffff !important;
        cursor: pointer;
        user-select: none;
    }

    .radio-dot-input {
        appearance: none;
        width: 11px;
        height: 11px;
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-radius: 50%;
        outline: none;
        background-color: transparent;
        cursor: pointer;
        transition: all 0.15s ease-in-out;
        position: relative;
    }

        .radio-dot-input:checked {
            border-color: #ffc107 !important;
            background-color: #ffc107 !important;
            box-shadow: 0 0 6px rgba(255, 193, 7, 0.6);
        }
</style>

<div class="container-fluid dashboard-xl-container">
    <div class="mb-3">
        <h1 class="h3 fw-bold mb-1" style="font-family: 'Poppins', sans-serif; color: #fff; font-size: 1.8rem;">Generador de Jobs Multi-Ambiente</h1>
        <p class="mb-0 small text-white-50" style="font-size: 0.85rem;">Transforma, parametriza y limpia configuraciones de tareas para Databricks (JSON Tradicional y Asset Bundles YAML) en lote.</p>
    </div>

    <div id="panel-fase1" class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card p-3 border-0 h-100" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">1</div>
                        <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Carga en lote de Jobs (Dev)</h6>
                    </div>
                    <button id="clear-jobs-btn" class="btn btn-xs btn-outline-secondary" style="display: none; border-radius: 4px; font-size: 0.7rem; padding: 2px 6px;">Limpiar Cola</button>
                </div>

                <div id="job-drop-zone" class="gemini-drop-zone my-2 p-4 text-center" style="border: 2px dashed rgba(255,255,255,0.1); border-radius: 8px; cursor: pointer; background: rgba(255,255,255,0.01);">
                    <div>
                        <i class="bi bi-folder-symlink fs-2 mb-1 d-block style_icon" style="opacity: 0.4; color: #ffc107;"></i>
                        <label for="job-file-upload" class="btn btn-xs btn-secondary px-3" style="cursor: pointer; border-radius: 4px; font-size: 0.75rem;">
                            <span>Elegir Archivos JSON / YAML</span>
                            <input id="job-file-upload" type="file" class="d-none" accept=".json,.yml,.yaml" multiple>
                        </label>
                        <p class="mt-1 small mb-0 text-white-50" style="font-size: 0.75rem;">o arrastra tus estructuras aquí</p>
                    </div>
                </div>

                <div id="job-file-list" class="mb-2 font-monospace" style="font-size: 0.75rem;"></div>

                <button type="button" id="btnProcesarFase1" class="btn btn-warning w-100 py-2 fw-bold mt-auto" style="border-radius: 6px; font-size: 0.85rem;" disabled>
                    <span id="spinner-fase1" class="spinner-border spinner-border-sm me-2 d-none"></span>
                    <i class="bi bi-arrow-right-circle me-1"></i>Procesar y Confirmar Gobernanza
                </button>
            </div>
        </div>

        <div class="col-12 col-lg-6 d-flex flex-column gap-3">
            <div class="card p-3 border-0" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">2</div>
                    <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Spark Configurations de Destino (Solo JSON)</h6>
                </div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label font-monospace small mb-1" style="color: rgba(255,255,255,0.7); font-size: 0.72rem;">Spark Config (Certificación)</label>
                        <span id="badge-json-cert" class="badge font-monospace mb-1 bg-secondary text-white-50" style="font-size: 0.6rem;">Vacío / Opcional</span>
                    </div>
                    <textarea class="form-control font-monospace small text-white custom-placeholder json-linter-input" id="globalCertSpark" rows="2" placeholder='{"spark.master": "local[*, 4]"}' style="background-color: #172a45; border-color: #233554; font-size: 0.72rem; border-radius: 4px;"></textarea>
                </div>

                <div class="mb-1">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label font-monospace small mb-1" style="color: rgba(255,255,255,0.7); font-size: 0.72rem;">Spark Config (Producción)</label>
                        <span id="badge-json-prod" class="badge font-monospace mb-1 bg-secondary text-white-50" style="font-size: 0.6rem;">Vacío / Opcional</span>
                    </div>
                    <textarea class="form-control font-monospace small text-white custom-placeholder json-linter-input" id="globalProdSpark" rows="2" placeholder='{"spark.databricks.cluster.profile": "serverless"}' style="background-color: #172a45; border-color: #233554; font-size: 0.72rem; border-radius: 4px;"></textarea>
                </div>
            </div>

            <div class="card p-3 border-0 flex-grow-1" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.2); display: flex; flex-direction: column;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 22px; height: 22px; font-size: 0.75rem;">3</div>
                    <h6 class="card-title fw-bold text-white mb-0" style="font-family: 'Poppins', sans-serif; font-size: 0.95rem;">Gobernanza de Permisos (Solo YAML Bundles)</h6>
                </div>

                <div class="table-responsive perm-scroll-box flex-grow-1">
                    <table class="table perm-table align-middle m-0" id="permissions-table">
                        <thead>
                            <tr>
                                <th>Nivel de Acceso</th>
                                <th>Usuario / Grupo Corporativo BCI</th>
                                <th style="width: 40px; text-align: center;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="permissions-tbody">
                            <tr>
                                <td>
                                    <select class="form-select form-select-sm font-monospace py-0 bg-dark text-white border-secondary" style="font-size: 0.72rem; height: 24px;">
                                        <option value="CAN_MANAGE" selected>Can Manage</option>
                                        <option value="IS_OWNER">Is Owner</option>
                                        <option value="CAN_MANAGE_RUN">Can Manage Run</option>
                                        <option value="CAN_VIEW">Can View</option>
                                    </select>
                                </td>
                                <td><input type="text" class="form-control form-control-sm font-monospace py-0 bg-dark text-white border-secondary" value="mcordof@bci.cl" style="font-size: 0.72rem; height: 24px;" /></td>
                                <td class="text-center"><button type="button" class="btn btn-xs btn-outline-danger py-0" onclick="$(this).closest('tr').remove()" style="height: 22px; line-height: 1;">&times;</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-xs btn-outline-warning mt-2 ms-auto" id="add-permission-row" style="font-size: 0.7rem; padding: 2px 8px; border-radius: 4px;"><i class="bi bi-plus-circle me-1"></i>Añadir Permiso</button>
            </div>
        </div>
    </div>

    <div id="panel-fase2" class="mt-3 d-none" style="animation: fadeIn 0.3s ease-in-out;">
        <form asp-action="DownloadPackage" method="post" id="package-form">
            <div id="hidden-permissions-container"></div>

            <div class="card p-3 border-0" style="background-color: #0b0d16; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3 border-bottom border-secondary border-opacity-10 pb-2">
                    <div>
                        <h5 class="fw-bold text-warning mb-0" style="font-family: 'Poppins', sans-serif; font-size: 1.1rem;"><i class="bi bi-shield-fill-exclamation me-2"></i>Fase de Confirmación de Nombres y Flujos</h5>
                        <p class="mb-0 small text-white-50" style="font-size: 0.75rem;">Modifica o confirma el nombre comercial del Job. Los prefijos e impurezas se limpian de manera automática.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" id="btnVolverFase1" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 4px; font-size: 0.75rem;">Modificar Carga</button>
                        <button type="submit" class="btn btn-sm btn-success px-4 fw-bold d-flex align-items-center gap-1" style="border-radius: 4px; font-size: 0.8rem;">
                            <i class="bi bi-cloud-arrow-down-fill"></i> Descargar Estructuras ZIP
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle m-0 font-monospace" id="staging-table" style="font-size: 0.75rem;">
                        <thead>
                            <tr>
                                <th style="width: 22%;">Archivo Cargado</th>
                                <th style="width: 26%;">Nombre Desarrollo (Limpio)</th>
                                <th style="width: 26%;">Nombre Certificación</th>
                                <th style="width: 26%;">Nombre Producción</th>
                            </tr>
                        </thead>
                        <tbody id="staging-tbody"></tbody>
                    </table>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileUpload = document.getElementById('job-file-upload');
            const dropZone = document.getElementById('job-drop zone');
            const fileListContainer = document.getElementById('job-file-list');
            const btnProcesarFase1 = document.getElementById('btnProcesarFase1');
            const clearJobsBtn = document.getElementById('clear-jobs-btn');

            let jobStore = new DataTransfer();
            let jsonConfigsValid = true;

            const validateFileStructure = (file) => {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const text = e.target.result;
                        if (file.name.endsWith('.json')) {
                            try { JSON.parse(text); resolve(); }
                            catch (err) { reject(new Error("Faltan llaves, comillas o comas finales.")); }
                        } else {
                            if (text.includes('resources:') || text.includes('tasks:')) { resolve(); }
                            else { reject(new Error("No se detectó una cabecera de recursos válida de Databricks.")); }
                        }
                    };
                    reader.onerror = () => reject(new Error("Error físico de lectura."));
                    reader.readAsText(file);
                });
            };

            const handleFiles = async (files) => {
                btnProcesarFase1.disabled = true;
                for (const file of files) {
                    const ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
                    if (ext !== '.json' && ext !== '.yml' && ext !== '.yaml') {
                        toastr.warning(`Archivo ${file.name} omitido. Formatos válidos: .json, .yml, .yaml`);
                        continue;
                    }

                    try {
                        await validateFileStructure(file);
                        jobStore.items.add(file);
                    } catch (error) {
                        toastr.error(`❌ Estructura Inválida en "${file.name}": ${error.message}`);
                    }
                }
                renderJobList();
            };

            if(fileUpload) fileUpload.addEventListener('change', (e) => handleFiles(e.target.files));
            if(dropZone) {
                dropZone.addEventListener('dragover', (e) => e.preventDefault());
                dropZone.addEventListener('drop', (e) => { e.preventDefault(); handleFiles(e.dataTransfer.files); });
            }

            function renderJobList() {
                fileListContainer.innerHTML = '';
                clearJobsBtn.style.display = 'none';
                evalProcesarBtnState();

                if (jobStore.files.length > 0) {
                    const list = document.createElement('ul');
                    list.className = 'list-group m-0 p-0';
                    Array.from(jobStore.files).forEach((file, index) => {
                        const listItem = document.createElement('li');
                        listItem.className = 'list-group-item d-flex justify-content-between align-items-center py-1 px-2 border-secondary bg-dark text-white-50';
                        listItem.textContent = file.name;

                        const removeBtn = document.createElement('button');
                        removeBtn.className = 'btn btn-danger btn-xs py-0 px-1';
                        removeBtn.innerHTML = '&times;';
                        removeBtn.type = 'button';
                        removeBtn.onclick = () => {
                            const newFiles = new DataTransfer();
                            Array.from(jobStore.files).forEach((f, i) => { if (i !== index) newFiles.items.add(f); });
                            jobStore = newFiles;
                            renderJobList();
                        };
                        listItem.appendChild(removeBtn);
                        list.appendChild(listItem);
                    });
                    fileListContainer.appendChild(list);
                    clearJobsBtn.style.display = 'block';
                    evalProcesarBtnState();
                }
            }

            if (clearJobsBtn) {
                clearJobsBtn.addEventListener('click', () => {
                    jobStore = new DataTransfer();
                    fileUpload.value = '';
                    renderJobList();
                });
            }

            document.getElementById('add-permission-row').addEventListener('click', function() {
                const rowHtml = `<tr>
                    <td>
                        <select class="form-select form-select-sm font-monospace py-0 bg-dark text-white border-secondary" style="font-size: 0.72rem; height: 24px;">
                            <option value="CAN_MANAGE" selected>Can Manage</option>
                            <option value="IS_OWNER">Is Owner</option>
                            <option value="CAN_MANAGE_RUN">Can Manage Run</option>
                            <option value="CAN_VIEW">Can View</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control form-control-sm font-monospace py-0 bg-dark text-white border-secondary" placeholder="usuario@bci.cl o grupo" style="font-size: 0.72rem; height: 24px;" /></td>
                    <td class="text-center"><button type="button" class="btn btn-xs btn-outline-danger py-0" onclick="$(this).closest('tr').remove()" style="height: 22px; line-height: 1;">&times;</button></td>
                </tr>`;
                $('#permissions-tbody').append(rowHtml);
            });

            function validateJsonInput(textareaId, badgeId) {
                const txtArea = document.getElementById(textareaId);
                const badge = document.getElementById(badgeId);
                const val = txtArea.value.trim();

                if (!val) {
                    badge.className = "badge font-monospace bg-secondary text-white-50";
                    badge.textContent = "Vacío / Opcional";
                    txtArea.style.borderColor = "#233554";
                    return true;
                }
                try {
                    JSON.parse(val);
                    badge.className = "badge font-monospace bg-success text-white";
                    badge.textContent = "✓ JSON Válido";
                    txtArea.style.borderColor = "#198754";
                    return true;
                } catch (e) {
                    badge.className = "badge font-monospace bg-danger text-white";
                    badge.textContent = "✗ JSON Inválido";
                    txtArea.style.borderColor = "#dc3545";
                    return false;
                }
            }

            function evalProcesarBtnState() {
                const isCertValid = validateJsonInput('globalCertSpark', 'badge-json-cert');
                const isProdValid = validateJsonInput('globalProdSpark', 'badge-json-prod');
                jsonConfigsValid = isCertValid && isProdValid;
                btnProcesarFase1.disabled = !(jobStore.files.length > 0 && jsonConfigsValid);
            }

            $('.json-linter-input').on('input', function() { evalProcesarBtnState(); });

            $('#btnProcesarFase1').on('click', function(e) {
                e.preventDefault();
                if (!jsonConfigsValid) return;

                var ajaxData = new FormData();
                Array.from(jobStore.files).forEach(file => { ajaxData.append('files', file); });
                ajaxData.append('certSparkConf', $('#globalCertSpark').val());
                ajaxData.append('prodSparkConf', $('#globalProdSpark').val());

                $('#spinner-fase1').removeClass('d-none');
                btnProcesarFase1.disabled = true;

                $.ajax({
                    url: '/JobConverter/PrepareStaging',
                    type: 'POST',
                    data: ajaxData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        $('#spinner-fase1').addClass('d-none');
                        btnProcesarFase1.disabled = false;
                        if (response.success) {
                            $('#staging-tbody').empty();
                            response.jobs.forEach((job, index) => {
                                var badgeType = job.isYaml ? '<span class="badge bg-warning text-dark me-1" style="font-size:0.6rem;">YAML BUNDLE</span>' : '<span class="badge bg-info text-dark me-1" style="font-size:0.6rem;">JSON PLANO</span>';

                                var rowHtml = '';
                                if (job.isYaml) {
                                    rowHtml = `
                                        <tr data-row-idx="${index}" data-suggested-name="${job.suggestedDevName}">
                                            <td class="small fw-bold text-wrap" style="color: #ffffff !important; max-width:180px; padding: 12px 6px;">
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <span>${badgeType}${job.originalFileName}</span>
                                                    <button type="button" class="btn btn-xs btn-outline-secondary btn-reset-row ms-2" title="Restablecer" style="padding:0px 4px; font-size:0.65rem;"><i class="bi bi-arrow-counterclockwise"></i></button>
                                                </div>
                                                <input type="hidden" name="fileKeys" value="${job.fileKey}" />
                                            </td>
                                            <td>
                                                <input type="text" name="devNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary dev-name-input" value="${job.suggestedDevName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <div class="d-flex align-items-center gap-2 mt-2 px-1">
                                                    <span class="text-warning fw-bold" style="font-size:0.68rem; letter-spacing:0.3px;">Autocert:</span>
                                                    <div class="radio-dot-container">
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="dev_radio_${index}" value="true" onclick="syncRadioToHidden(this, 'devAutocert', ${index})"> true</label>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="dev_radio_${index}" value="false" checked onclick="syncRadioToHidden(this, 'devAutocert', ${index})"> false</label>
                                                    </div>
                                                    <input type="hidden" id="devAutocert_${index}" name="devAutocert" value="false" />
                                                </div>
                                            </td>
                                            <td>
                                                <input type="text" name="certNames" class="form-control form-control-sm font-monospace fw-bold text-white-50 bg-dark border-secondary cert-name-input" value="${job.suggestedCertName}" readonly style="opacity:0.35; font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <div class="d-flex align-items-center gap-2 mt-2 px-1">
                                                    <span class="text-warning fw-bold" style="font-size:0.68rem; letter-spacing:0.3px;">Autocert:</span>
                                                    <div class="radio-dot-container">
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="cert_radio_${index}" value="true" onclick="syncRadioToHidden(this, 'certAutocert', ${index})"> true</label>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="cert_radio_${index}" value="false" checked onclick="syncRadioToHidden(this, 'certAutocert', ${index})"> false</label>
                                                    </div>
                                                    <input type="hidden" id="certAutocert_${index}" name="certAutocert" value="false" />
                                                </div>
                                            </td>
                                            <td>
                                                <input type="text" name="prodNames" class="form-control form-control-sm font-monospace fw-bold text-white-50 bg-dark border-secondary prod-name-input" value="${job.suggestedProdName}" readonly style="opacity:0.35; font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <div class="d-flex align-items-center gap-2 mt-2 px-1">
                                                    <span class="text-warning fw-bold" style="font-size:0.68rem; letter-spacing:0.3px;">Autocert:</span>
                                                    <div class="radio-dot-container">
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="prod_radio_${index}" value="true" onclick="syncRadioToHidden(this, 'prodAutocert', ${index})"> true</label>
                                                        <label class="radio-dot-label"><input type="radio" class="radio-dot-input" name="prod_radio_${index}" value="false" checked onclick="syncRadioToHidden(this, 'prodAutocert', ${index})"> false</label>
                                                    </div>
                                                    <input type="hidden" id="prodAutocert_${index}" name="prodAutocert" value="false" />
                                                </div>
                                            </td>
                                        </tr>`;
                                } else {
                                    rowHtml = `
                                        <tr data-row-idx="${index}" data-suggested-name="${job.suggestedDevName}">
                                            <td class="small fw-bold text-wrap" style="color: #ffffff !important; max-width:180px; padding: 12px 6px;">
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <span>${badgeType}${job.originalFileName}</span>
                                                    <button type="button" class="btn btn-xs btn-outline-secondary btn-reset-row ms-2" title="Restablecer" style="padding:0px 4px; font-size:0.65rem;"><i class="bi bi-arrow-counterclockwise"></i></button>
                                                </div>
                                                <input type="hidden" name="fileKeys" value="${job.fileKey}" />
                                            </td>
                                            <td>
                                                <input type="text" name="devNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary dev-name-input" value="${job.suggestedDevName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <input type="hidden" name="devAutocert" value="false" />
                                            </td>
                                            <td>
                                                <input type="text" name="certNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary cert-name-input" value="${job.suggestedCertName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <input type="hidden" name="certAutocert" value="false" />
                                            </td>
                                            <td>
                                                <input type="text" name="prodNames" class="form-control form-control-sm font-monospace fw-bold text-white bg-dark border-secondary prod-name-input" value="${job.suggestedProdName}" style="font-size:0.75rem; height:26px; padding:2px 4px;" />
                                                <input type="hidden" name="prodAutocert" value="false" />
                                            </td>
                                        </tr>`;
                                }
                                $('#staging-tbody').append(rowHtml);
                            });

                            $('#panel-fase1').addClass('d-none');
                            $('#panel-fase2').removeClass('d-none');
                            toastr.success('Jobs analizados correctamente.');
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function() {
                        $('#spinner-fase1').addClass('d-none');
                        btnProcesarFase1.disabled = false;
                        toastr.error('Error de comunicación con el motor de empaquetado.');
                    }
                });
            });

            $(document).on('input', '.dev-name-input', function() {
                var parentRow = $(this).closest('tr');
                var currentVal = $(this).val();
                if(parentRow.find('.cert-name-input').attr('readonly') === undefined) {
                    parentRow.find('.cert-name-input').val(currentVal);
                    parentRow.find('.prod-name-input').val(currentVal);
                }
            });

            $(document).on('click', '.btn-reset-row', function() {
                var parentRow = $(this).closest('tr');
                var baseSuggestedName = parentRow.data('suggested-name');
                parentRow.find('.dev-name-input').val(baseSuggestedName);
                if(parentRow.find('.cert-name-input').attr('readonly') === undefined) {
                    parentRow.find('.cert-name-input').val(baseSuggestedName);
                    parentRow.find('.prod-name-input').val(baseSuggestedName);
                }
            });

            $('#btnVolverFase1').on('click', function() {
                $('#panel-fase2').addClass('d-none');
                $('#panel-fase1').removeClass('d-none');
            });

            $('#package-form').on('submit', function() {
                const hiddenContainer = document.getElementById('hidden-permissions-container');
                hiddenContainer.innerHTML = '';

                $('#permissions-tbody tr').each(function() {
                    const level = $(this).find('select').val();
                    const user = $(this).find('input').val().trim();
                    if(user) {
                        $(hiddenContainer).append(`<input type="hidden" name="permLevels" value="${level}" />`);
                        $(hiddenContainer).append(`<input type="hidden" name="permUsers" value="${user}" />`);
                    }
                });
                return true;
            });
        });

        function syncRadioToHidden(radio, baseName, index) {
            document.getElementById(`${baseName}_${index}`).value = radio.value;
        }
    </script>
}

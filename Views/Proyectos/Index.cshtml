@model IEnumerable<NotebookValidator.Web.Models.GestorProyectos.Proyecto>
@{
    ViewData["Title"] = "Gestor de Proyectos";
}

<style>
    .project-card {
        background-color: #0b0d16;
        border: 1px solid rgba(255, 193, 7, 0.15);
        border-radius: 10px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .project-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            border-color: rgba(255, 193, 7, 0.4);
        }

    .avatar-circle {
        width: 28px;
        height: 28px;
        background-color: #172a45;
        color: #ffc107;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: bold;
        border: 1px solid rgba(255,193,7,0.3);
        margin-left: -8px;
    }

        .avatar-circle:first-child {
            margin-left: 0;
        }

    .hover-warning:hover {
        color: #ffc107 !important;
    }

    .progress-xl {
        height: 6px;
        background-color: #111424;
        border-radius: 4px;
        overflow: hidden;
    }

    /* ANIMACIÓN DE ALERTA PARA PROYECTOS ATRASADOS */
    @@keyframes heartbeat {
        0% {
            transform: scale(1);
        }

        14% {
            transform: scale(1.1);
        }

        28% {
            transform: scale(1);
        }

        42% {
            transform: scale(1.1);
        }

        70% {
            transform: scale(1);
        }
    }

    .heartbeat {
        animation: heartbeat 2s infinite;
        display: inline-block;
    }
</style>

<div class="container-fluid dashboard-xl-container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1 text-white" style="font-family: 'Poppins', sans-serif;">Gestor de Proyectos Multi-Cliente</h1>
            <p class="mb-0 small text-white-50">Hub central de orquestación, artefactos y gobernanza de la célula.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-warning fw-bold px-4" style="border-radius: 6px;">
                <i class="bi bi-plus-lg me-2"></i>Nuevo Proyecto
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-dark border-secondary text-center p-5" style="background-color: #07091e; border-radius: 10px;">
            <i class="bi bi-folder-x display-1 text-white-50 mb-3"></i>
            <h5 class="text-white fw-bold">No hay proyectos activos</h5>
            <p class="text-white-50 small">Comienza creando tu primer proyecto corporativo. El sistema generará automáticamente la estructura en Drive.</p>
            <a asp-action="Create" class="btn btn-outline-warning mt-2">Crear mi primer Proyecto</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var proyecto in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card project-card p-4 h-100 d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="pe-2">
                                <h5 class="fw-bold mb-0 text-truncate" style="font-family: 'Poppins', sans-serif;" title="@proyecto.Nombre">
                                    <a asp-action="Details" asp-route-id="@proyecto.Id" class="text-white text-decoration-none hover-warning" style="transition: color 0.2s;">
                                        @proyecto.Nombre
                                    </a>
                                </h5>
                                <span class="badge bg-secondary mt-1" style="font-size: 0.6rem;">
                                    <i class="bi bi-building me-1"></i>@(proyecto.Cliente?.Nombre ?? "Proyecto Interno")
                                </span>
                            </div>

                            <div class="d-flex flex-column align-items-end gap-1">
                                <span class="badge bg-dark border border-secondary text-light" style="font-size: 0.55rem;">@proyecto.Estado</span>

                                @{
                                    string badgeRiesgoCard = "bg-secondary text-white-50";
                                    if (proyecto.EstadoRiesgo == "A Tiempo" || proyecto.EstadoRiesgo == "Completado") { badgeRiesgoCard = "bg-success text-white"; }
                                    if (proyecto.EstadoRiesgo == "En Riesgo") { badgeRiesgoCard = "bg-warning text-dark"; }
                                    if (proyecto.EstadoRiesgo == "Atrasado") { badgeRiesgoCard = "bg-danger text-white heartbeat"; }
                                }
                                <span class="badge @badgeRiesgoCard" style="font-size: 0.6rem; text-transform: uppercase;">
                                    @if (proyecto.EstadoRiesgo == "Atrasado")
                                    {
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                    }
                                    @proyecto.EstadoRiesgo
                                </span>
                            </div>
                        </div>

                        <p class="text-white-50 small mb-3 flex-grow-1" style="font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @(string.IsNullOrEmpty(proyecto.Descripcion) ? "Sin descripción asignada." : proyecto.Descripcion)
                        </p>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1" style="font-size: 0.7rem;">
                                <span class="text-white-50 text-uppercase" style="letter-spacing: 0.5px;">Progreso Global</span>
                                <span class="text-info fw-bold font-monospace">@proyecto.PorcentajeProgreso%</span>
                            </div>
                            <div class="progress progress-xl mb-1">
                                <div class="progress-bar bg-info" role="progressbar" style="width: @proyecto.PorcentajeProgreso%; transition: width 0.4s ease;" aria-valuenow="@proyecto.PorcentajeProgreso" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>

                            @if (proyecto.FechaFinEstimada.HasValue)
                            {
                                <div class="text-end font-monospace" style="font-size: 0.65rem;">
                                    <span class="text-white-50">Cierre: </span>
                                    <span class="@(proyecto.EstadoRiesgo == "Atrasado" ? "text-danger fw-bold" : "text-white")">@proyecto.FechaFinEstimada.Value.ToString("dd MMM yyyy")</span>
                                    <span class="@(proyecto.EstadoRiesgo == "Atrasado" ? "text-danger" : "text-white-50") ms-1">(@proyecto.MensajeTiempo)</span>
                                </div>
                            }
                            else
                            {
                                <div class="text-end text-white-50 font-monospace" style="font-size: 0.65rem;">Sin fecha de cierre</div>
                            }
                        </div>

                        <div class="mb-3">
                            <span class="d-block text-white-50 mb-1" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px;">Equipo Asignado</span>
                            <div class="d-flex">
                                @foreach (var user in proyecto.UsuariosAsignados.Take(5))
                                {
                                    <div class="avatar-circle" title="@user.Usuario.Email">
                                        @user.Usuario.Email.Substring(0, 2).ToUpper()
                                    </div>
                                }
                                @if (proyecto.UsuariosAsignados.Count > 5)
                                {
                                    <div class="avatar-circle bg-secondary text-white border-secondary">+@(proyecto.UsuariosAsignados.Count - 5)</div>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-secondary border-opacity-25">
                            <span class="text-white-50" style="font-size: 0.7rem;"><i class="bi bi-calendar3 me-1"></i>Creado: @proyecto.FechaCreacion.ToString("dd MMM yyyy")</span>

                            @if (!string.IsNullOrEmpty(proyecto.DriveFolderUrl))
                            {
                                <a href="@proyecto.DriveFolderUrl" target="_blank" class="btn btn-sm btn-outline-info" style="font-size: 0.75rem;">
                                    <i class="bi bi-google me-1"></i>Abrir Drive
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary disabled" style="font-size: 0.75rem;">Sin Drive</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

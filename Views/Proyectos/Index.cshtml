@model IEnumerable<NotebookValidator.Web.Models.GestorProyectos.Proyecto>
@{
    ViewData["Title"] = "Gestor de Proyectos";
}

<style>
    .project-card {
        background-color: #0b0d16;
        border: 1px solid rgba(255, 193, 7, 0.15);
        border-radius: 10px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .project-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            border-color: rgba(255, 193, 7, 0.4);
        }

    .avatar-circle {
        width: 28px;
        height: 28px;
        background-color: #172a45;
        color: #ffc107;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: bold;
        border: 1px solid rgba(255,193,7,0.3);
        margin-left: -8px;
    }

        .avatar-circle:first-child {
            margin-left: 0;
        }

    .hover-warning:hover {
        color: #ffc107 !important;
    }

    .progress-xl {
        height: 6px;
        background-color: #111424;
        border-radius: 4px;
        overflow: hidden;
    }

    /* ANIMACIÓN DE ALERTA PARA PROYECTOS ATRASADOS */
    @@keyframes heartbeat {
        0% {
            transform: scale(1);
        }

        14% {
            transform: scale(1.1);
        }

        28% {
            transform: scale(1);
        }

        42% {
            transform: scale(1.1);
        }

        70% {
            transform: scale(1);
        }
    }

    .heartbeat {
        animation: heartbeat 2s infinite;
        display: inline-block;
    }
</style>

<div class="container-fluid dashboard-xl-container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1 text-white" style="font-family: 'Poppins', sans-serif;">Gestor de Proyectos Multi-Cliente</h1>
            <p class="mb-0 small text-white-50">Hub central de orquestación, artefactos y gobernanza de la célula.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-warning fw-bold px-4" style="border-radius: 6px;">
                <i class="bi bi-plus-lg me-2"></i>Nuevo Proyecto
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-dark border-secondary text-center p-5" style="background-color: #07091e; border-radius: 10px;">
            <i class="bi bi-folder-x display-1 text-white-50 mb-3"></i>
            <h5 class="text-white fw-bold">No hay proyectos activos</h5>
            <p class="text-white-50 small">Comienza creando tu primer proyecto corporativo. El sistema generará automáticamente la estructura en Drive.</p>
            <a asp-action="Create" class="btn btn-outline-warning mt-2">Crear mi primer Proyecto</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var proyecto in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <partial name="_ProyectoCard" model="proyecto" />
                </div>
            }
        </div>
    }
</div>

@model IEnumerable<NotebookValidator.Web.Models.AllowedParameter>
@{
    ViewData["Title"] = "Administrar Parámetros Permitidos";
}

<style>
    /* ESTILOS DE COLORES RESTAURADOS */
    .text-muted-light {
        color: #adb5bd !important;
    }

    .bg-dark-subtle {
        background-color: rgba(255,255,255,0.03) !important;
    }

    .form-control.bg-dark, .form-select.bg-dark {
        color: #fff !important;
        background-color: #212529 !important;
        border-color: #495057 !important;
    }

        .form-control.bg-dark:focus, .form-select.bg-dark:focus {
            background-color: #212529 !important;
            color: #fff !important;
            border-color: #ffc107 !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
        }

        .form-control.bg-dark::placeholder {
            color: rgba(255, 255, 255, 0.4) !important;
            opacity: 1;
        }
</style>

<div class="container-fluid mt-4">
    <h2 class="text-white mb-4"><i class="bi bi-tags text-warning me-2"></i> @ViewData["Title"]</h2>

    <div class="row">
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary shadow-sm">
                <div class="card-header bg-dark-subtle border-secondary">
                    <h5 class="mb-0 text-warning">Añadir Nuevo Parámetro</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label class="form-label small text-muted-light">Nombre del Parámetro (W o X)</label>
                            <input name="Name" class="form-control bg-dark text-white border-secondary" placeholder="Ej. fechaProcesoW o db_platinumX" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted-light">Valor por Defecto (Opcional)</label>
                            <input name="DefaultValue" class="form-control bg-dark text-white border-secondary" placeholder="Ej. 20260101" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted-light">Etiqueta Visual (Opcional)</label>
                            <input name="Label" class="form-control bg-dark text-white border-secondary" placeholder="Ej. Fecha de Proceso:" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted-light">Categoría</label>
                            <select name="Category" class="form-select bg-dark text-white border-secondary">
                                <option value="Widget">Widget de Entrada (W)</option>
                                <option value="Entorno">Variable de Entorno (X)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold shadow">Guardar Parámetro</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card bg-dark text-white border-secondary shadow-sm">
                <div class="card-header bg-dark-subtle border-secondary d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-warning">Base de Datos de Parámetros</h5>
                    <input type="text" id="parameterSearch" class="form-control form-control-sm w-50 bg-dark text-white border-secondary" placeholder="Buscar por nombre..." />
                </div>
                <div class="card-body p-0">
                    <table class="table table-dark table-hover mb-0" id="parametersTable">
                        <thead>
                            <tr class="text-muted-light small">
                                <th>Nombre</th>
                                <th>Valor Default</th>
                                <th>Etiqueta</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-monospace text-warning">@item.Name</td>
                                    <td class="text-white-50">@item.DefaultValue</td>
                                    <td class="text-white-50">@item.Label</td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <button class="btn btn-sm btn-outline-info border-0"
                                                    onclick="abrirModalEdicion(@item.Id, '@item.Name', '@item.DefaultValue', '@item.Label', '@item.Category')">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Eliminar parámetro?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary bg-dark-subtle">
                <h5 class="modal-title text-warning">Editar Parámetro</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Edit" method="post">
                <div class="modal-body">
                    <input type="hidden" id="editId" name="Id" />
                    <div class="mb-3">
                        <label class="form-label small text-muted-light">Nombre del Parámetro</label>
                        <input id="editName" name="Name" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted-light">Valor por Defecto</label>
                        <input id="editDefault" name="DefaultValue" class="form-control bg-dark text-white border-secondary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted-light">Etiqueta Visual</label>
                        <input id="editLabel" name="Label" class="form-control bg-dark text-white border-secondary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted-light">Categoría</label>
                        <select id="editCategory" name="Category" class="form-select bg-dark text-white border-secondary">
                            <option value="Widget">Widget de Entrada (W)</option>
                            <option value="Entorno">Variable de Entorno (X)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModalEdicion(id, name, def, label, cat) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editDefault').value = def;
            document.getElementById('editLabel').value = label;
            document.getElementById('editCategory').value = cat;
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }

        document.getElementById('parameterSearch').addEventListener('keyup', function () {
            const term = this.value.toLowerCase();
            document.querySelectorAll('#parametersTable tbody tr').forEach(row => {
                row.style.display = row.cells[0].textContent.toLowerCase().includes(term) ? "" : "none";
            });
        });
    </script>
}

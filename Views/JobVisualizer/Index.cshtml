        function createOrUpdateTab(taskKey, fileName, celdas, parentTaskKey) {
            const tabsUl = document.getElementById('notebookTabs'); const tabsContent = document.getElementById('notebookTabContent');
            const uniqueTabString = parentTaskKey ? `${parentTaskKey}-${taskKey}` : taskKey; const tabId = 'tab-' + uniqueTabString.replace(/[^a-zA-Z0-9]/g, '-'); const liId = 'li-' + tabId;

            window.globalCellsRawData[tabId] = window.globalCellsRawData[tabId] || {};
            document.getElementById('lineagePlaceholder').classList.add('d-none'); document.getElementById('lineagePanel').classList.remove('d-none');

            if (!document.getElementById(tabId)) {
                const li = document.createElement('li'); li.className = 'nav-item position-relative'; li.id = liId;
                li.innerHTML = `
                    <button class="nav-link text-white-50" id="${tabId}-btn" data-bs-toggle="tab" data-bs-target="#${tabId}" type="button" role="tab">
                        <i class="bi bi-journal-code me-2 text-primary"></i> <span class="tab-title-text" title="${taskKey}">${taskKey}</span>
                        <span class="close-tab-btn" onclick="closeNotebookTab(event, '${tabId}', '${liId}')" title="Cerrar pestaña">&times;</span>
                    </button>`;
                tabsUl.appendChild(li);
                const pane = document.createElement('div'); pane.className = 'tab-pane fade'; pane.id = tabId; pane.role = 'tabpanel'; tabsContent.appendChild(pane);
            }

            const paneEl = document.getElementById(tabId); const creationsMap = {};
            
            celdas.forEach(celda => {
                window.globalCellsRawData[tabId][celda.numeroCelda] = celda.codigoFuenteCrudo;
                celda.operaciones.forEach(op => { if (op.tipoOperacion.includes("CREATE") || op.tipoOperacion === "LIST DEFINITION") { const targetName = op.objetivo.split('\n')[0].trim(); creationsMap[targetName] = celda.numeroCelda; } });
            });

            let breadcrumbHtml = '';
            if (parentTaskKey) { breadcrumbHtml = `<div class="mb-3 d-flex align-items-center text-white-50 bg-dark p-2 rounded border border-secondary border-opacity-25" style="font-size: 0.75rem;"><i class="bi bi-diagram-3 me-2 text-info"></i> Origen: <span class="badge bg-secondary border border-secondary text-white-50 mx-2">${parentTaskKey}</span> <i class="bi bi-arrow-right-short text-white-50"></i> <span class="badge bg-primary ms-2">${taskKey}</span></div>`; }

            if (celdas.length === 0) {
                paneEl.innerHTML = `${breadcrumbHtml}<div class="text-center text-white-50 py-4"><i class="bi bi-emoji-frown d-block fs-3 mb-2"></i>No se detectaron comandos clave en este archivo (${fileName}).</div>`;
            } else {
                let html = breadcrumbHtml; html += `<div class="mb-3"><span class="badge bg-primary">Archivo: ${fileName}</span> <span class="badge bg-dark border border-secondary text-white-50">Celdas clave encontradas: ${celdas.length}</span></div><div class="timeline-container">`;
                celdas.forEach(celda => {
                    let actionButtons = ''; let detailsHtml = '';
                    celda.operaciones.forEach(op => {
                        if (op.tipoOperacion === "RUN NOTEBOOK") {
                            let subTaskName = op.objetivo.split('/').pop();
                            actionButtons += `<button type="button" class="btn btn-sm btn-primary badge me-2 border-0 shadow-sm" style="font-size:0.75rem; cursor:pointer;" onclick="fetchAndDrawNotebookLineage('${subTaskName}', '${op.objetivo}', document.getElementById('zipFileInput').files[0], '${taskKey}')" title="Clic para escanear este Sub-Notebook"><i class="bi bi-box-arrow-in-down-right me-1"></i>Escanear Sub-Notebook: ${op.objetivo}</button>`;
                        } 
                        else {
                            const translated = opTranslations[op.tipoOperacion] || op.tipoOperacion; const parts = op.objetivo.split('\n'); const targetName = parts[0].trim(); const extraInfo = parts.length > 1 ? '\n' + parts.slice(1).join('\n') : '';
                            let displayTarget = escapeHtml(targetName);
                            if (!op.tipoOperacion.includes("CREATE") && !op.tipoOperacion.includes("DEFINITION") && creationsMap[targetName] && creationsMap[targetName] !== celda.numeroCelda) {
                                const sourceCell = creationsMap[targetName];
                                displayTarget = `<a href="javascript:void(0)" onclick="scrollToCell('${tabId}', ${sourceCell})" class="link-origen-dato" title="Ir a la celda ${sourceCell} donde se declara/crea">${escapeHtml(targetName)} <i class="bi bi-link-45deg" style="font-size: 0.85rem;"></i></a>`;
                            }

                            let icon = "⚡"; 
                            if (op.tipoOperacion.includes("CREATE")) icon = "🔨"; else if (op.tipoOperacion.includes("INSERT") || op.tipoOperacion.includes("SPARK INSERT")) icon = "➕"; else if (op.tipoOperacion.includes("MERGE")) icon = "📝"; else if (op.tipoOperacion.includes("DELETE") || op.tipoOperacion.includes("DROP") || op.tipoOperacion.includes("TRUNCATE")) icon = "🗑️"; else if (op.tipoOperacion.includes("JOIN")) icon = "🔗"; else if (op.tipoOperacion.includes("READ") || op.tipoOperacion.includes("SPARK READ")) icon = "🔍"; else if (op.tipoOperacion.includes("WRITE") || op.tipoOperacion.includes("EXPORT") || op.tipoOperacion.includes("SAVE")) icon = "💾"; else if (op.tipoOperacion === "LIST DEFINITION") icon = "📦"; else if (op.tipoOperacion === "FOR LOOP") icon = "🔄"; else if (op.tipoOperacion === "WHERE FILTER") icon = "🎯"; else if (op.tipoOperacion === "GROUP BY") icon = "🗂️"; else if (op.tipoOperacion === "ORDER BY") icon = "⬇️"; else if (op.tipoOperacion.includes("PARAMETER")) icon = "🔑";

                            detailsHtml += `<div class="mb-2 p-2 rounded" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); font-family: monospace; font-size: 0.75rem;"><strong class="text-info">${icon} ${escapeHtml(translated)}:</strong> ${displayTarget}${extraInfo ? `<div class="mt-1 text-white-50 ms-4 ps-2 border-start border-secondary" style="white-space: pre-wrap;">${escapeHtml(extraInfo)}</div>` : ''}</div>`;
                        }
                    });

                    html += `
                    <div class="timeline-item" id="cell-${tabId}-${celda.numeroCelda}">
                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-secondary border-opacity-25">
                            <span class="fw-bold text-info small"><i class="bi bi-terminal me-1"></i>Celda #${celda.numeroCelda}</span>
                            <div><button type="button" class="btn btn-sm btn-outline-info py-0 px-2 me-2 border-0 shadow-none" onclick="viewRawCode('${tabId}', ${celda.numeroCelda})" title="Ver Código Fuente de la Celda"><i class="bi bi-code-slash me-1"></i> Ver Código</button>${actionButtons}</div>
                        </div>
                        <div>${detailsHtml}</div>
                    </div>`;
                });
                html += `</div>`; paneEl.innerHTML = html;
            }

            const tabEl = document.getElementById(`${tabId}-btn`); const tab = new bootstrap.Tab(tabEl); tab.show();
            const ul = document.getElementById('notebookTabs'); ul.scrollTo({ left: ul.scrollWidth, behavior: 'smooth' });
        }

        window.closeNotebookTab = function(event, tabId, liId) {
            event.stopPropagation(); const li = document.getElementById(liId); const pane = document.getElementById(tabId); const wasActive = li.querySelector('.nav-link').classList.contains('active');
            if (li) li.remove(); if (pane) pane.remove();
            if (wasActive) {
                const remainingTabs = document.querySelectorAll('#notebookTabs .nav-link');
                if (remainingTabs.length > 0) { new bootstrap.Tab(remainingTabs[remainingTabs.length - 1]).show(); } else { document.getElementById('lineagePanel').classList.add('d-none'); document.getElementById('lineagePlaceholder').classList.remove('d-none'); }
            } else { if (document.querySelectorAll('#notebookTabs .nav-link').length === 0) { document.getElementById('lineagePanel').classList.add('d-none'); document.getElementById('lineagePlaceholder').classList.remove('d-none'); } }
        };

        function escapeHtml(unsafe) { return (unsafe || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;"); }
    </script>
}

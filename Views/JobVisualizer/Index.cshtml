        function processDatabricksJobs(jobsArray, uploadedZipFileNames) {
            const totalTasks = jobsArray.reduce((acc, job) => acc + job.tasks.length, 0);
            document.getElementById('emptyStateMsg').classList.add('d-none'); document.getElementById('jobDetailsPanel').classList.remove('d-none');
            document.getElementById('lblTaskCount').textContent = totalTasks; document.getElementById('lblJobCount').textContent = jobsArray.length;
            document.getElementById('lineagePlaceholder').classList.remove('d-none'); document.getElementById('lineagePanel').classList.add('d-none');

            const jobListContainer = document.getElementById('jobListContainer'); jobListContainer.innerHTML = '';
            jobsArray.forEach((job, index) => {
                const item = document.createElement('div'); item.className = 'job-list-item mb-1';
                item.innerHTML = `
                    <a href="javascript:void(0)" class="job-title-link" onclick="focusOnJob(${index})" title="Ver Job: ${job.jobName}"> <i class="bi bi-box me-1"></i> ${job.jobName} </a>
                    <div class="job-actions text-nowrap"> <button class="btn btn-outline-info border-0" onclick="focusOnJob(${index})" title="Enfocar Cámara"><i class="bi bi-search"></i></button> <button class="btn btn-outline-success border-0 ms-1" onclick="openExportModal(${index})" title="Exportar a Excel"><i class="bi bi-file-earmark-excel"></i></button> </div>
                `;
                jobListContainer.appendChild(item);
            });

            const nodes = new vis.DataSet(); const edges = new vis.DataSet(); globalNodesData = nodes; 

            jobsArray.forEach((job, index) => {
                const jobRootId = `ROOT_JOB_${index}`;
                nodes.add({ id: jobRootId, label: `🏁 INICIO\n${job.jobName}`, title: `Punto de entrada del Job: ${job.jobName}`, shape: 'box', color: { background: '#6d28d9', border: '#c084fc', highlight: { background: '#9333ea', border: '#e9d5ff' } }, font: { color: '#ffffff', size: 14, bold: true }, margin: 15, isRoot: true });

                job.tasks.forEach(task => {
                    const taskKey = task.task_key; const uniqueNodeId = `${jobRootId}_${taskKey}`; 
                    let icon = "⚙️"; let bgColor = "#192231";
                    if (task.notebook_task) { icon = "📓"; bgColor = "#1e3a8a"; } else if (task.spark_python_task) { icon = "🐍"; bgColor = "#14532d"; } else if (task.sql_task) { icon = "💾"; bgColor = "#701a75"; } 

                    let borderColor = '#3b82f6'; let shadowColor = 'rgba(0,0,0,0.5)'; let tooltipStatus = 'Clic para ver linaje interno.';

                    if (task.notebook_task && task.notebook_task.notebook_path && uploadedZipFileNames.length > 0) {
                        const baseName = task.notebook_task.notebook_path.split('/').pop().toLowerCase();
                        const hasSourceCode = uploadedZipFileNames.some(f => { const fL = f.toLowerCase(); return fL.endsWith(baseName + '.py') || fL.endsWith(baseName + '.sql') || fL.endsWith(baseName + '.ipynb'); });
                        if (hasSourceCode) { borderColor = '#10b981'; shadowColor = 'rgba(16, 185, 129, 0.8)'; tooltipStatus = '✅ CÓDIGO ENCONTRADO EN EL ZIP.\nClic para escanear.'; } 
                        else { borderColor = '#ef4444'; shadowColor = 'rgba(239, 68, 68, 0.8)'; tooltipStatus = '❌ ALERTA: Código NO encontrado en el ZIP subido.'; }
                    }

                    nodes.add({ 
                        id: uniqueNodeId, label: `${icon} ${taskKey}`, title: `Tarea: ${taskKey}\n${tooltipStatus}`, shape: 'box', widthConstraint: { maximum: 220 }, 
                        color: { background: bgColor, border: borderColor, highlight: { background: bgColor, border: borderColor } }, shadow: { enabled: true, color: shadowColor, size: 15, x: 0, y: 0 }, borderWidth: 2, taskData: task, originalTaskKey: taskKey,
                        originalBg: bgColor, originalBorder: borderColor, originalShadow: shadowColor 
                    });

                    if (task.depends_on && task.depends_on.length > 0) { task.depends_on.forEach(dep => edges.add({ from: `${jobRootId}_${dep.task_key}`, to: uniqueNodeId })); } else { edges.add({ from: jobRootId, to: uniqueNodeId, dashes: true, color: { color: '#475569', opacity: 0.7 }, arrows: '' }); }
                });
            });

            const container = document.getElementById('network-container');
            const dataGraph = { nodes: nodes, edges: edges };
            
            const options = {
                layout: { hierarchical: { direction: "UD", sortMethod: "directed", nodeSpacing: 250, levelSeparation: 150, treeSpacing: 400 } }, physics: false, 
                edges: { arrows: { to: { enabled: true, scaleFactor: 0.8, type: 'arrow' } }, color: { color: '#64748b', highlight: '#94a3b8' }, smooth: { type: 'cubicBezier', forceDirection: 'vertical', roundness: 0.4 } },
                nodes: { margin: { top: 12, bottom: 12, left: 15, right: 15 }, font: { color: '#e2e8f0', face: 'monospace', size: 13 } }, interaction: { hover: true, dragNodes: true, navigationButtons: false, keyboard: true } 
            };

            if (network !== null) { network.destroy(); }
            network = new vis.Network(container, dataGraph, options);
            
            network.on("beforeDrawing", function (ctx) {
                currentLoadedJobs.forEach((job, index) => {
                    const jobRootId = `ROOT_JOB_${index}`; let nodeIds = [jobRootId]; job.tasks.forEach(t => nodeIds.push(`${jobRootId}_${t.task_key}`));
                    let positions = network.getPositions(nodeIds); let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity; let hasNodes = false;
                    for (let id in positions) { if (!positions[id]) continue; hasNodes = true; let p = positions[id]; minX = Math.min(minX, p.x - 140); maxX = Math.max(maxX, p.x + 140); minY = Math.min(minY, p.y - 60); maxY = Math.max(maxY, p.y + 60); }
                    if (hasNodes) {
                        const x = minX - 30; const y = minY - 70; const w = (maxX - minX) + 60; const h = (maxY - minY) + 100; const r = 15; 
                        ctx.fillStyle = "rgba(255, 255, 255, 0.02)"; ctx.strokeStyle = "rgba(13, 202, 240, 0.25)"; ctx.lineWidth = 2; ctx.setLineDash([8, 8]); 
                        ctx.beginPath(); ctx.moveTo(x + r, y); ctx.lineTo(x + w - r, y); ctx.quadraticCurveTo(x + w, y, x + w, y + r); ctx.lineTo(x + w, y + h - r); ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h); ctx.lineTo(x + r, y + h); ctx.quadraticCurveTo(x, y + h, x, y + h - r); ctx.lineTo(x, y + r); ctx.quadraticCurveTo(x, y, x + r, y); ctx.closePath();
                        ctx.fill(); ctx.stroke(); ctx.setLineDash([]); 
                        ctx.font = "bold 18px 'Poppins', sans-serif"; ctx.fillStyle = "#0dcaf0"; ctx.textAlign = "left"; ctx.fillText("📦 Grupo: " + job.jobName, x + 20, y + 35);
                    }
                });
            });

            network.on("click", function (params) {
                if (params.nodes.length > 0) {
                    const nodeId = params.nodes[0]; const nodeInfo = globalNodesData.get(nodeId);
                    if (nodeInfo && nodeInfo.isRoot) return;
                    if (nodeInfo && nodeInfo.taskData) {
                        const task = nodeInfo.taskData; const originalKey = nodeInfo.originalTaskKey;
                        if (task.notebook_task && task.notebook_task.notebook_path) {
                            const zipInput = document.getElementById('zipFileInput');
                            if (zipInput.files.length > 0) { fetchAndDrawNotebookLineage(originalKey, task.notebook_task.notebook_path, zipInput.files[0], null); } else { toastr.info(`Para ver el linaje de '${originalKey}', sube el ZIP con el código fuente.`); }
                        } else { toastr.warning(`La tarea '${originalKey}' no es un Notebook estándar con ruta.`); }
                    }
                }
            });
        }

        function fetchAndDrawNotebookLineage(taskKey, notebookPath, zipFile, parentTaskKey) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const formData = new FormData(); formData.append('fileZip', zipFile); formData.append('notebookPath', notebookPath);
            toastr.info(`Escaneando celdas de ${taskKey}...`, '', {timeOut: 2000});

            fetch('/JobVisualizer/EscanearNotebookDesdeZip', { method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData })
            .then(r => r.json())
            .then(data => { if (data.success) { createOrUpdateTab(taskKey, data.fileName, data.celdas, parentTaskKey); } else { toastr.error(data.message); } })
            .catch(() => toastr.error('Error de conexión al escanear el ZIP.'));
        }


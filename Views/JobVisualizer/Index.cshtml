                        });
                    }

                    let icon = "⚙️"; let bg = "FF192231";
                    if (t.notebook_task) { icon = "📓"; bg = "FF1E3A8A"; } else if (t.spark_python_task) { icon = "🐍"; bg = "FF14532D"; } else if (t.sql_task) { icon = "💾"; bg = "FF701A75"; } 
                    
                    let borderColor = isZipOk ? 'FF10B981' : 'FFEF4444'; 
                    if (!t.notebook_task) borderColor = 'FF3B82F6'; 

                    const c = sheet.getCell(currentRow, currentCol);
                    c.value = `${icon} ${t.task_key}`;
                    c.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: bg } };
                    c.font = { color: { argb: 'FFFFFFFF' }, bold: true };
                    c.alignment = { horizontal: 'center', vertical: 'middle', wrapText: true };
                    c.border = { top:{style:'medium',color:{argb:borderColor}}, left:{style:'medium',color:{argb:borderColor}}, bottom:{style:'medium',color:{argb:borderColor}}, right:{style:'medium',color:{argb:borderColor}} };
                    
                    sheet.getRow(currentRow).height = 40;

                    if(i < maxLevel) {
                        const arrowCell = sheet.getCell(currentRow + 1, currentCol);
                        arrowCell.value = '⬇️'; arrowCell.alignment = { horizontal: 'center', vertical: 'middle' };
                    }
                    currentCol += 2; 
                });
                currentRow += 2; 
            }
            return currentRow + 2; 
        }

        document.getElementById('btnProcess').addEventListener('click', async function() {
            const fileInput = document.getElementById('jobFileInput');
            if (fileInput.files.length === 0) { toastr.warning('Por favor selecciona al menos una Configuración de Job (.json o .yml).'); return; }

            currentUploadedZipFileNames = [];
            const zipInput = document.getElementById('zipFileInput');
            if (zipInput.files.length > 0) {
                try {
                    const jszip = new JSZip();
                    const zipContent = await jszip.loadAsync(zipInput.files[0]);
                    currentUploadedZipFileNames = Object.keys(zipContent.files); 
                } catch (e) {
                    console.error("Error leyendo ZIP:", e); toastr.error("No se pudo leer el archivo ZIP para validación visual.");
                }
            }

            let allJobs = [];

            try {
                for (let i = 0; i < fileInput.files.length; i++) {
                    const file = fileInput.files[i];
                    const content = await file.text();
                    let parsedData;
                    if (file.name.endsWith('.yml') || file.name.endsWith('.yaml')) { parsedData = jsyaml.load(content); } else { parsedData = JSON.parse(content); }

                    if (parsedData.tasks) {
                        allJobs.push({ jobName: parsedData.name || `Job_${i+1}`, tasks: parsedData.tasks });
                    } else if (parsedData.resources && parsedData.resources.jobs) {
                        for(const jobKey in parsedData.resources.jobs) {
                            const jobObj = parsedData.resources.jobs[jobKey];
                            if(jobObj.tasks) { allJobs.push({ jobName: jobObj.name || jobKey, tasks: jobObj.tasks }); }
                        }
                    }
                }

                if (allJobs.length === 0) { toastr.warning('Los archivos no contienen tareas válidas para graficar.'); return; }

                currentLoadedJobs = allJobs;
                processDatabricksJobs(allJobs, currentUploadedZipFileNames); 
                document.getElementById('customNavControls').classList.remove('d-none');
            } catch (err) {
                console.error(err); toastr.error('Error al parsear los archivos. Asegúrate de que sean JSON o YAML válidos.');
            }
        });


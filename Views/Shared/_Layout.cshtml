<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bit Solución</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        .main-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            min-height: 100vh;
            background-color: #0f111a;
        }

        .content-body {
            flex: 1 0 auto;
        }

        .footer-custom {
            flex-shrink: 0;
            background-color: rgba(0, 0, 0, 0.3);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 1.2rem 2rem;
            color: #888;
            font-size: 0.85rem;
        }

        /* Estilos para Módulo Activo */
        .sidebar-nav .nav-link {
            position: relative;
            transition: all 0.2s ease;
            color: rgba(255,255,255,0.6);
            border-left: 4px solid transparent;
            padding-left: 1.2rem;
        }

            .sidebar-nav .nav-link:hover {
                color: #fff;
                background-color: rgba(255,255,255,0.05);
            }

            .sidebar-nav .nav-link.active {
                color: #fff !important;
                background-color: rgba(255, 193, 7, 0.1);
                border-left: 4px solid #ffc107 !important;
                font-weight: 600;
            }

                .sidebar-nav .nav-link.active i {
                    color: #ffc107 !important;
                }

        .nav-header {
            font-size: 0.7rem;
            letter-spacing: 1.2px;
            font-weight: 700;
            color: #4b5162;
            padding: 1.5rem 1.2rem 0.5rem;
            text-transform: uppercase;
        }
    </style>
</head>
<body>
    <div class="main-wrapper">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a class="d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/img/Bit-solucion-logo-menu.png" alt="Bit Solución Logo" />
                </a>
            </div>

            <nav class="sidebar-nav mt-4">
                <ul class="nav flex-column">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    }

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-2"></i> Inicio
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Validador" ? "active" : "")" asp-controller="Home" asp-action="Validador">
                                <i class="bi bi-journal-code me-2"></i> Validador Notebooks
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DataProfiling" ? "active" : "")" asp-controller="DataProfiling" asp-action="Index">
                                <i class="bi bi-bar-chart-steps me-2"></i> Perfilamiento Datos
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Cuadratura" ? "active" : "")" asp-controller="Cuadratura" asp-action="Index">
                                <i class="bi bi-table me-2"></i> Cuadratura Datos
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "NotebookGenerator" ? "active" : "")" asp-controller="NotebookGenerator" asp-action="Index">
                                <i class="bi bi-file-earmark-plus me-2"></i> Generador Notebooks
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ParameterValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ParameterValidator" ? "active" : "")" asp-controller="ParameterValidator" asp-action="Index">
                                <i class="bi bi-filetype-py me-2"></i> Validador Parámetros
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "JobConverter" ? "active" : "")" asp-controller="JobConverter" asp-action="Index">
                            <i class="bi bi-wrench-adjustable-circle-fill me-2"></i> Generador de Jobs
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("TempCleanerUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "TempTable" ? "active" : "")" asp-controller="TempTable" asp-action="Index">
                                <i class="bi bi-trash3 me-2"></i> Limpieza Tmp
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item mt-2">
                            <a class="nav-link @(currentController == "AdminDashboard" || currentController == "Admin" || currentController == "ValidationRuleAdmin" || currentController == "AuditLog" || currentController == "ParameterAdmin" ? "active" : "text-warning fw-bold")"
                               data-bs-toggle="collapse" href="#adminCollapse" role="button" aria-expanded="false" aria-controls="adminCollapse">
                                <i class="bi bi-shield-lock-fill me-2"></i> Administración
                                <i class="bi bi-chevron-down ms-auto small"></i>
                            </a>
                            <div class="collapse @(currentController == "AdminDashboard" || currentController == "Admin" || currentController == "ValidationRuleAdmin" || currentController == "AuditLog" || currentController == "ParameterAdmin" ? "show" : "")" id="adminCollapse">
                                <ul class="nav flex-column ms-3 mt-1 border-start border-secondary" style="border-width: 2px !important;">
                                    <li class="nav-item">
                                        <a class="nav-link py-1 @(currentController == "AdminDashboard" ? "active" : "")" asp-controller="AdminDashboard" asp-action="Index">
                                            <i class="bi bi-speedometer2 me-2"></i> Dashboard Global
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-1 @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                                            <i class="bi bi-people me-2"></i> Gestionar Usuarios
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-1 @(currentController == "ValidationRuleAdmin" ? "active" : "")" asp-controller="ValidationRuleAdmin" asp-action="Index">
                                            <i class="bi bi-list-check me-2"></i> Reglas Validador
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-1 @(currentController == "AuditLog" ? "active" : "")" asp-controller="AuditLog" asp-action="Index">
                                            <i class="bi bi-shield-check me-2"></i> Log de Auditoría
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-1 @(currentController == "ParameterAdmin" ? "active" : "")" asp-controller="ParameterAdmin" asp-action="Index">
                                            <i class="bi bi-tags-fill me-2"></i> Admin. Parámetros
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    }
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar px-4 d-flex justify-content-between align-items-center">
                <button class="btn text-white d-md-none" id="sidebar-toggle"><i class="bi bi-list"></i></button>
                <div class="ms-auto">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <div class="content-body container-fluid py-4">
                @RenderBody()
            </div>

            @*<footer class="footer-custom d-flex justify-content-between align-items-center">
                <div>&copy; @DateTime.Now.Year - <span class="text-warning">Bit Solución</span></div>
                <div><span class="badge bg-dark text-muted" style="border: 1px solid rgba(255,255,255,0.1)">v @System.Reflection.Assembly.GetEntryAssembly()?.GetName().Version?.ToString(3)</span></div>
            </footer>*@
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/lib/qrcode/qrcode.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    @{
        var buildDate = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    }

    <footer class="border-top py-2 fixed-bottom"
            style="border-color: rgba(255,255,255,0.1) !important; background-color: #0b0b0b;">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center small">
            <div class="mb-1 mb-md-0 d-flex align-items-center">
                <span class="me-2" style="color:#FFD43B;">⚡</span>
                <strong style="color:#FFD43B;">Bitsolución Herramientas</strong>
                <span class="text-secondary ms-1">© @DateTime.Now.Year</span>
            </div>

            <div class="d-flex align-items-center"
                 data-bs-toggle="tooltip"
                 title="Versión completa: @VersionHelper.GetVersion() | Compilado el @buildDate">
                <span class="text-secondary me-2">Versión</span>
                <span class="px-2 py-1 rounded"
                      style="background-color:#FFD43B; color:#000; font-family: monospace; font-weight: bold;">
                    @{
                        var fullVersion = VersionHelper.GetVersion();
                        // 3. Acortar a los primeros 7 caracteres
                        var shortVersion = fullVersion.Length > 7 ? fullVersion.Substring(0, 7) : fullVersion;
                    }
                    @shortVersion
                </span>
            </div>
        </div>
    </footer>
</body>
</html>

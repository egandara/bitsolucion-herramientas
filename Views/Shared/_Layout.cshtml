<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bit Solución</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

            /* ==========================================================================
                                                           ESTANDARIZACIÓN GLOBAL DE SIDEBAR AL ALTO IMPACTO (COMPACTO AL 75%)
                                                           ========================================================================== */
            :root {
                --sidebar-width: 260px !important;
                --topbar-height: 60px !important;
            }

            #worldCupWidget, #worldCupWidget * {
                font-family: 'Twemoji Country Flags', 'Montserrat', 'Poppins', 'Segoe UI Emoji', sans-serif !important;
            }

            html, body {
                height: 100% !important;
                margin: 0 !important;
                background-color: #0f111a !important;
                overflow-x: hidden !important;
            }

            /* BARRA LATERAL CONTENIDA */
            .sidebar {
                width: var(--sidebar-width) !important;
                background-color: #0b0d16 !important;
                border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
                display: flex !important;
                flex-direction: column !important;
                overflow-y: hidden !important;
                overflow-x: hidden !important;
                height: 100vh !important;
            }

            .sidebar-brand {
                display: flex !important;
                flex-direction: column !important;
                justify-content: center !important;
                align-items: center !important;
                padding: 0.8rem 1rem 0.4rem !important;
                height: 80px !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
                background-color: #0b0d16 !important;
                flex-shrink: 0 !important;
                z-index: 10 !important;
            }

            .sidebar-nav {
                overflow-y: auto !important;
                overflow-x: hidden !important;
                flex-grow: 1 !important;
                padding: 0 0.5rem !important;
            }

                .sidebar-nav .nav {
                    gap: 2px !important;
                }

                .sidebar-nav .nav-link {
                    color: rgba(255, 255, 255, 0.6) !important;
                    border-left: 4px solid transparent !important;
                    padding: 0.16rem 0.8rem !important;
                    border-radius: 4px !important;
                    font-weight: 500 !important;
                    transition: all 0.2s ease !important;
                    display: flex !important;
                    align-items: center !important;
                    background-color: transparent !important;
                    text-decoration: none;
                    margin-bottom: 0 !important;
                    white-space: nowrap !important;
                    font-size: 0.78rem !important;
                    line-height: 1.2 !important;
                }

                    .sidebar-nav .nav-link i,
                    .sidebar-nav .nav-link i.bi {
                        font-size: 1.05rem !important;
                        margin-right: 0.65rem !important;
                        width: 18px !important;
                        text-align: center !important;
                        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
                    }

                    .sidebar-nav .nav-link:hover {
                        color: #fff !important;
                        background-color: rgba(255, 255, 255, 0.04) !important;
                    }

                        .sidebar-nav .nav-link:hover i,
                        .sidebar-nav .nav-link:hover i.bi {
                            transform: translateX(2px) !important;
                        }

                    .sidebar-nav .nav-link.active {
                        color: #fff !important;
                        background-color: rgba(255, 193, 7, 0.08) !important;
                        border-left: 4px solid #ffc107 !important;
                        font-weight: 600 !important;
                    }

                        .sidebar-nav .nav-link.active i,
                        .sidebar-nav .nav-link.active i.bi {
                            color: #ffc107 !important;
                        }

            .nav-header-custom {
                font-size: 0.60rem !important;
                letter-spacing: 1.3px !important;
                font-weight: 700 !important;
                color: rgba(255, 255, 255, 0.28) !important;
                padding: 0.75rem 0.8rem 0.25rem !important;
                text-transform: uppercase !important;
                white-space: nowrap;
                margin-top: 0px !important;
                margin-bottom: 0px !important;
                display: flex !important;
                align-items: center !important;
                gap: 6px !important;
            }

                .nav-header-custom:first-child {
                    padding-top: 0.5rem !important;
                }

                /* Línea separadora integrada en el header */
                .nav-header-custom::after {
                    content: '' !important;
                    flex: 1 !important;
                    height: 1px !important;
                    background: rgba(255, 255, 255, 0.06) !important;
                    display: block !important;
                }

            .sidebar-nav hr {
                display: none !important; /* Reemplazados por ::after en nav-header-custom */
            }

            /* Área de perfil de usuario al pie del sidebar */
            .sidebar-user-footer {
                flex-shrink: 0 !important;
                padding: 0.6rem 0.75rem !important;
                border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
                display: flex !important;
                align-items: center !important;
                gap: 0.6rem !important;
                background-color: #0b0d16 !important;
                cursor: default !important;
            }

            .sidebar-user-avatar {
                width: 28px !important;
                height: 28px !important;
                border-radius: 50% !important;
                background: rgba(255, 193, 7, 0.15) !important;
                border: 1px solid rgba(255, 193, 7, 0.25) !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                font-size: 0.65rem !important;
                font-weight: 700 !important;
                color: #ffc107 !important;
                flex-shrink: 0 !important;
                text-transform: uppercase !important;
            }

            .sidebar-user-info {
                flex: 1 !important;
                min-width: 0 !important;
                overflow: hidden !important;
            }

                .sidebar-user-info .user-name {
                    font-size: 0.75rem !important;
                    font-weight: 600 !important;
                    color: rgba(255, 255, 255, 0.85) !important;
                    white-space: nowrap !important;
                    overflow: hidden !important;
                    text-overflow: ellipsis !important;
                    line-height: 1.2 !important;
                }

                .sidebar-user-info .user-role {
                    font-size: 0.62rem !important;
                    color: rgba(255, 255, 255, 0.3) !important;
                    white-space: nowrap !important;
                    overflow: hidden !important;
                    text-overflow: ellipsis !important;
                    line-height: 1.3 !important;
                }

            /* Ocultar user footer al colapsar */
            .sidebar.collapsed .sidebar-user-footer {
                padding: 0.6rem 0 !important;
                justify-content: center !important;
            }

            .sidebar.collapsed .sidebar-user-info,
            .sidebar.collapsed .sidebar-user-role-badge {
                display: none !important;
            }

            .sidebar.collapsed .sidebar-user-avatar {
                width: 30px !important;
                height: 30px !important;
            }

            .sidebar-nav .nav-link[aria-expanded="true"] .transition-icon {
                transform: rotate(180deg) !important;
                color: #ffc107 !important;
            }

            .transition-icon {
                transition: transform 0.2s ease !important;
            }

            .sidebar-nav .collapse .nav-link {
                border-left: none !important;
                padding: 0.14rem 0.8rem 0.14rem 1.8rem !important;
                color: rgba(255, 255, 255, 0.45) !important;
                font-size: 0.74rem !important;
            }

            .logo-full {
                display: block !important;
                height: 32px;
            }

            .main-content {
                background-color: #0f111a !important;
                min-width: 0;
            }

            .top-bar {
                background-color: #0f111a !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
                height: 60px !important;
            }

            .sidebar-nav::-webkit-scrollbar {
                width: 4px !important;
            }

            .sidebar-nav::-webkit-scrollbar-track {
                background: transparent !important;
            }

            .sidebar-nav::-webkit-scrollbar-thumb {
                background: transparent !important;
                border-radius: 10px !important;
                transition: background 0.3s ease !important;
            }

            .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.08) !important;
            }

                .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 193, 7, 0.25) !important;
                }

            /* ==========================================================================
                                                           OMNI-SEARCH GLOBAL (ATLASSIAN / JIRA STYLE)
                                                           ========================================================================== */
            .global-search-container {
                position: relative;
                width: 100%;
                max-width: 450px;
                z-index: 1050;
            }

            .global-search-input {
                background-color: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: #fff;
                border-radius: 6px;
                padding: 8px 16px 8px 36px;
                width: 100%;
                transition: all 0.2s ease;
                font-size: 0.85rem;
                font-family: monospace;
            }

                .global-search-input:focus {
                    background-color: rgba(0, 0, 0, 0.3);
                    border-color: #0dcaf0;
                    box-shadow: 0 0 0 3px rgba(13, 202, 240, 0.2);
                    outline: none;
                }

            .global-search-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255, 255, 255, 0.4);
                pointer-events: none;
            }

            .global-search-results {
                position: absolute;
                top: 100%;
                left: 0;
                width: 550px;
                max-width: 90vw;
                margin-top: 8px;
                background-color: #111424;
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 8px;
                box-shadow: 0 10px 40px rgba(0,0,0,0.6);
                z-index: 1051;
                display: none;
                max-height: 450px;
                overflow-y: auto;
                overflow-x: hidden;
            }

            .search-category-header {
                font-size: 0.65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: rgba(255,255,255,0.3);
                padding: 8px 12px;
                background-color: #07091e;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                border-top: 1px solid rgba(255,255,255,0.05);
                margin: 0;
            }

                .search-category-header:first-child {
                    border-top: none;
                    border-top-left-radius: 8px;
                    border-top-right-radius: 8px;
                }

            .search-result-item {
                display: flex;
                align-items: center;
                padding: 10px 12px;
                text-decoration: none !important;
                color: #fff;
                transition: background-color 0.2s;
                border-bottom: 1px solid rgba(255,255,255,0.03);
            }

                .search-result-item:last-child {
                    border-bottom: none;
                }

                .search-result-item:hover, .search-result-item.active {
                    background-color: rgba(13, 202, 240, 0.1);
                    color: #fff;
                }

            .search-result-icon {
                width: 32px;
                height: 32px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background-color: rgba(255,255,255,0.05);
                border-radius: 6px;
                margin-right: 12px;
                font-size: 1rem;
            }

            .search-result-text {
                display: flex;
                flex-direction: column;
                overflow: hidden;
                width: 100%;
            }

            .search-result-title {
                font-weight: 600;
                font-size: 0.85rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .search-result-desc {
                font-size: 0.7rem;
                color: rgba(255,255,255,0.5);
                font-family: monospace;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .search-loading {
                padding: 25px;
                text-align: center;
                color: rgba(255,255,255,0.5);
                font-size: 0.85rem;
                font-family: monospace;
            }

            .global-search-results::-webkit-scrollbar {
                width: 6px;
            }

            .global-search-results::-webkit-scrollbar-track {
                background: rgba(0,0,0,0.1);
            }

            .global-search-results::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.1);
                border-radius: 10px;
            }

            /* ── HOJA DE ESTILOS TIMELINE HORIZONTAL COPA MUNDIAL ── */
            .wc-timeline-container {
                display: flex;
                align-items: center;
                gap: 6px;
                max-width: 820px; /* 💡 CORREGIDO: De 580px subimos a 820px para conquistar el espacio vacío */
                width: 100%;
                position: relative;
            }

            .wc-timeline-viewport {
                display: flex;
                align-items: center;
                gap: 12px;
                overflow-x: hidden;
                scroll-behavior: smooth;
                width: 100%;
                padding: 4px 0;
            }

            .wc-day-group-node {
                display: flex;
                align-items: center;
                gap: 8px;
                border-left: 2px dashed rgba(255, 193, 7, 0.35);
                padding-left: 10px;
                margin-left: 4px;
                flex-shrink: 0;
            }

            .wc-day-column-label {
                display: flex;
                flex-direction: column;
                justify-content: center;
                line-height: 1.1;
                flex-shrink: 0;
                margin-right: 6px;
            }

                .wc-day-column-label .day-name-txt {
                    font-size: 0.52rem;
                    color: rgba(255, 255, 255, 0.4);
                    text-transform: uppercase;
                    font-weight: 700;
                    letter-spacing: 0.3px;
                }

                .wc-day-column-label .day-date-txt {
                    font-size: 0.68rem;
                    color: #ffc107;
                    font-weight: 800;
                    white-space: nowrap;
                }

            .wc-time-match-segment {
                display: flex;
                align-items: center;
                gap: 6px;
                flex-shrink: 0;
            }

            .wc-time-sub {
                color: #0dcaf0;
                font-weight: 700;
                font-size: 0.65rem;
                background: rgba(13, 202, 240, 0.08);
                padding: 2px 5px;
                border-radius: 4px;
                border: 1px solid rgba(13, 202, 240, 0.25);
                white-space: nowrap;
            }

            .wc-match-interactive-pill {
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.08);
                color: #fff;
                padding: 3px 8px;
                border-radius: 5px;
                cursor: pointer;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-size: 0.72rem;
                white-space: nowrap !important;
            }

                .wc-match-interactive-pill:hover, .wc-match-interactive-pill.popover-active {
                    background: rgba(255, 255, 255, 0.08);
                    border-color: rgba(255, 193, 7, 0.5);
                    box-shadow: 0 0 8px rgba(255, 193, 7, 0.15);
                }

            .wc-fin-badge {
                background: rgba(255, 255, 255, 0.06);
                color: rgba(255, 255, 255, 0.45);
                border: 1px solid rgba(255, 255, 255, 0.12);
                font-size: 0.55rem;
                padding: 0px 3px;
                border-radius: 3px;
                font-weight: bold;
            }

            .wc-live-pulse-badge {
                background: rgba(220, 53, 69, 0.15);
                color: #ff4a5a;
                border: 1px solid rgba(220, 53, 69, 0.45);
                font-size: 0.58rem;
                padding: 0px 4px;
                border-radius: 3px;
                font-weight: bold;
            }

            .wc-future-badge {
                background: rgba(13, 202, 240, 0.12);
                color: #0dcaf0;
                border: 1px solid rgba(13, 202, 240, 0.3);
                font-size: 0.55rem;
                padding: 0px 3px;
                border-radius: 3px;
                font-weight: bold;
            }

            .wc-score-live-highlight {
                background: #ffc107;
                color: #000;
                font-weight: 800;
                padding: 0px 5px;
                border-radius: 3px;
            }

            .wc-score-finished-badge {
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.15);
                color: #ffffff !important;
                font-weight: 800;
                padding: 0px 5px;
                border-radius: 4px;
                margin: 0 2px;
                font-size: 0.72rem;
            }

            .wc-score-vs-text {
                color: rgba(255, 255, 255, 0.35) !important;
                font-weight: 600;
                font-size: 0.65rem;
                margin: 0 4px;
            }
            /* CORECTOR FIXED PARA GOLEADORES (INMUNES AL CLIPPING HORIZONTAL) */
            .wc-scorers-popover {
                position: fixed;
                transform: translateX(-50%);
                background: #111424;
                border: 1px solid rgba(255, 193, 7, 0.4);
                border-radius: 6px;
                min-width: 240px;
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.85);
                z-index: 9999;
                padding: 8px 12px;
                font-family: monospace;
                font-size: 0.7rem;
            }

            .wc-scorer-home-text {
                color: #3bf79c !important;
            }

            .wc-scorer-away-text {
                color: #4adcff !important;
            }

            .wc-nav-arrow {
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.08);
                color: #ffc107;
                border-radius: 50%;
                width: 22px;
                height: 22px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: all 0.2s;
                font-size: 0.65rem;
                flex-shrink: 0;
            }

                .wc-nav-arrow:hover {
                    background: rgba(255,193,7,0.15);
                    color: #fff;
                    border-color: #ffc107;
                }

            /* BOTÓN PREMIUM DE RETORNO AL PRESENTE */
            .wc-btn-today {
                background: rgba(255, 193, 7, 0.1);
                border: 1px solid rgba(255, 193, 7, 0.35);
                color: #ffc107;
                font-size: 0.58rem;
                font-weight: 700;
                padding: 1px 8px;
                border-radius: 12px;
                cursor: pointer;
                transition: all 0.2s ease;
                display: flex;
                align-items: center;
                gap: 4px;
                text-transform: uppercase;
                letter-spacing: 0.3px;
                height: 18px;
            }

                .wc-btn-today:hover {
                    background: rgba(255, 193, 7, 0.25);
                    color: #fff;
                    border-color: #ffc107;
                    box-shadow: 0 0 8px rgba(255, 193, 7, 0.2);
                }

            /* Banderas Twemoji: tamaño compacto para la barra del widget */
            #worldCupWidget img.emoji {
                width: 16px !important;
                height: 16px !important;
                display: inline !important;
                vertical-align: middle !important;
                margin: 0 2px !important;
            }

            /* NUEVAS CLASES PARA DARLE PODER A LOS GOLES */
            .wc-score-finished-badge {
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.15);
                color: #ffffff !important;
                font-weight: 800; /* Super negrita */
                padding: 0px 6px;
                border-radius: 4px;
                margin: 0 3px;
                font-size: 0.72rem;
                letter-spacing: 0.5px;
                display: inline-block;
            }

            .wc-score-vs-text {
                color: rgba(255, 255, 255, 0.35) !important;
                font-weight: 600;
                font-size: 0.65rem;
                margin: 0 5px;
            }
    </style>

    <style>
            /* ── SIDEBAR COLAPSABLE ────────────────────────────────── */
            :root {
                --sidebar-collapsed-width: 56px;
            }

            .sidebar {
                transition: width 0.25s cubic-bezier(0.4,0,0.2,1) !important;
                overflow: visible !important; /* necesario para que los tooltips no se corten */
            }

                .sidebar.collapsed {
                    width: var(--sidebar-collapsed-width) !important;
                    overflow: visible !important;
                }

            /* El scroll va en sidebar-nav, no en sidebar */
            .sidebar-nav {
                overflow-y: auto !important;
                overflow-x: visible !important; /* permite que los tooltips salgan */
            }

            /* Logo y Brand Header */
            .sidebar-brand {
                height: auto !important;
                min-height: 70px !important;
                flex-direction: row !important; /* Fila cuando está expandido */
                justify-content: space-between !important;
                padding: 12px 16px !important;
            }

            .brand-left {
                align-items: flex-start !important;
            }

            .logo-full {
                transition: opacity 0.2s;
                max-height: 28px;
                width: auto;
            }

            .logo-mini {
                display: none;
                height: 26px;
                width: auto;
                transition: opacity 0.2s;
            }

            /* Comportamiento al colapsar */
            .sidebar.collapsed .sidebar-brand {
                flex-direction: column !important; /* Apila logo, badge y botón */
                padding: 12px 0 !important;
                gap: 12px !important;
            }

            .sidebar.collapsed .brand-left {
                align-items: center !important; /* Centra logo y badge */
                gap: 4px !important;
            }

            .sidebar.collapsed .logo-full {
                display: none !important;
            }

            .sidebar.collapsed .logo-mini {
                display: block !important;
            }

            .sidebar.collapsed #btnToggleSidebar {
                margin: 0 auto;
            }

            /* Textos y cabeceras ocultos al colapsar */
            .sidebar.collapsed .nav-header-custom,
            .sidebar.collapsed hr,
            .sidebar.collapsed .nav-link span,
            .sidebar.collapsed .transition-icon {
                display: none !important;
            }

            /* Badge de entorno: Oculta solo la palabra LOCAL/CLOUD, deja el icono */
            .sidebar.collapsed .env-text {
                display: none !important;
            }

            /* Iconos centrados */
            .sidebar.collapsed .nav-link {
                justify-content: center !important;
                padding: 0.45rem 0 !important;
                border-left: none !important;
                border-radius: 6px !important;
                margin: 1px 4px !important;
                position: relative;
            }

                .sidebar.collapsed .nav-link i {
                    margin-right: 0 !important;
                    font-size: 1.15rem !important;
                }

                .sidebar.collapsed .nav-link.active {
                    background-color: rgba(255,193,7,0.12) !important;
                    border-left: none !important;
                }

                /* Tooltip nativo al hacer hover */
                .sidebar.collapsed .nav-link[data-sidebar-label] {
                    overflow: visible !important;
                }

                    .sidebar.collapsed .nav-link[data-sidebar-label]:hover::after {
                        content: attr(data-sidebar-label);
                        position: fixed;
                        left: calc(var(--sidebar-collapsed-width) + 8px);
                        top: var(--tooltip-top, 50%);
                        transform: translateY(-50%);
                        background: #1a1d2e;
                        color: #fff;
                        font-size: 0.75rem;
                        font-weight: 600;
                        padding: 5px 12px;
                        border-radius: 6px;
                        white-space: nowrap;
                        z-index: 9999;
                        border: 1px solid rgba(255,255,255,0.15);
                        box-shadow: 0 4px 16px rgba(0,0,0,0.5);
                        pointer-events: none;
                    }

            /* Botón toggle */
            #btnToggleSidebar {
                background: none;
                border: none;
                color: rgba(255,255,255,0.4);
                cursor: pointer;
                padding: 4px 6px;
                border-radius: 5px;
                font-size: 1rem;
                transition: color 0.2s, background 0.2s;
                flex-shrink: 0;
            }

                #btnToggleSidebar:hover {
                    color: #ffc107;
                    background: rgba(255,193,7,0.08);
                }

            /* main-content se expande al colapsar sidebar */
            .main-wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            .main-content {
                flex: 1;
                min-width: 0;
                overflow-y: auto;
                display: flex;
                flex-direction: column;
            }

            /* === WIDGET MUNDIAL === */
            @@keyframes heartbeat {
                0% {
                    transform: scale(1);
                }

                14% {
                    transform: scale(1.15);
                }

                28% {
                    transform: scale(1);
                }

                42% {
                    transform: scale(1.15);
                }

                70% {
                    transform: scale(1);
                }
            }

            .heartbeat {
                animation: heartbeat 2s infinite;
                display: inline-block;
            }
    </style>

    @RenderSection("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/twemoji@14.0.2/dist/twemoji.min.js" crossorigin="anonymous"></script>
</head>
<body>

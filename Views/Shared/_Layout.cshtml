<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bit Solución</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

            /* ==========================================================================
                                   ESTANDARIZACIÓN GLOBAL DE SIDEBAR AL ALTO IMPACTO (COMPACTO AL 75%)
                                   ========================================================================== */
            :root {
                --sidebar-width: 260px !important;
                --topbar-height: 60px !important;
            }

            html, body {
                height: 100% !important;
                margin: 0 !important;
                background-color: #0f111a !important;
                overflow-x: hidden !important;
            }

            /* BARRA LATERAL CONTENIDA */
            .sidebar {
                width: var(--sidebar-width) !important;
                background-color: #0b0d16 !important;
                border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
                display: flex !important;
                flex-direction: column !important;
                overflow-y: hidden !important;
                overflow-x: hidden !important;
                height: 100vh !important;
            }

            .sidebar-brand {
                display: flex !important;
                flex-direction: column !important;
                justify-content: center !important;
                align-items: center !important;
                padding: 0.8rem 1rem 0.4rem !important;
                height: 80px !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
                background-color: #0b0d16 !important;
                flex-shrink: 0 !important;
                z-index: 10 !important;
            }

            .sidebar-nav {
                overflow-y: auto !important;
                overflow-x: hidden !important;
                flex-grow: 1 !important;
                padding: 0 0.5rem !important;
            }

                .sidebar-nav .nav {
                    gap: 2px !important;
                }

                .sidebar-nav .nav-link {
                    color: rgba(255, 255, 255, 0.6) !important;
                    border-left: 4px solid transparent !important;
                    padding: 0.16rem 0.8rem !important;
                    border-radius: 4px !important;
                    font-weight: 500 !important;
                    transition: all 0.2s ease !important;
                    display: flex !important;
                    align-items: center !important;
                    background-color: transparent !important;
                    text-decoration: none;
                    margin-bottom: 0 !important;
                    white-space: nowrap !important;
                    font-size: 0.78rem !important;
                    line-height: 1.2 !important;
                }

                    .sidebar-nav .nav-link i,
                    .sidebar-nav .nav-link i.bi {
                        font-size: 1.05rem !important;
                        margin-right: 0.65rem !important;
                        width: 18px !important;
                        text-align: center !important;
                        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
                    }

                    .sidebar-nav .nav-link:hover {
                        color: #fff !important;
                        background-color: rgba(255, 255, 255, 0.04) !important;
                    }

                        .sidebar-nav .nav-link:hover i,
                        .sidebar-nav .nav-link:hover i.bi {
                            transform: translateX(2px) !important;
                        }

                    .sidebar-nav .nav-link.active {
                        color: #fff !important;
                        background-color: rgba(255, 193, 7, 0.08) !important;
                        border-left: 4px solid #ffc107 !important;
                        font-weight: 600 !important;
                    }

                        .sidebar-nav .nav-link.active i,
                        .sidebar-nav .nav-link.active i.bi {
                            color: #ffc107 !important;
                        }

            .nav-header-custom {
                font-size: 0.62rem !important;
                letter-spacing: 1.2px !important;
                font-weight: 700 !important;
                color: rgba(255, 255, 255, 0.28) !important;
                padding: 0.8rem 0.8rem 0.2rem !important;
                text-transform: uppercase !important;
                white-space: nowrap;
                margin-top: 0px !important;
                margin-bottom: 0px !important;
            }

                .nav-header-custom:first-child {
                    padding-top: 0.5rem !important;
                }

            .sidebar-nav hr {
                margin: 0.25rem 0.75rem !important;
                border-color: rgba(255, 255, 255, 0.05) !important;
                opacity: 0.15 !important;
            }

            .sidebar-nav .nav-link[aria-expanded="true"] .transition-icon {
                transform: rotate(180deg) !important;
                color: #ffc107 !important;
            }

            .transition-icon {
                transition: transform 0.2s ease !important;
            }

            .sidebar-nav .collapse .nav-link {
                border-left: none !important;
                padding: 0.14rem 0.8rem 0.14rem 1.8rem !important;
                color: rgba(255, 255, 255, 0.45) !important;
                font-size: 0.74rem !important;
            }

            .logo-full {
                display: block !important;
                height: 32px;
            }

            .main-content {
                background-color: #0f111a !important;
                min-width: 0;
            }

            .top-bar {
                background-color: #0f111a !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
                height: 60px !important;
            }

            .sidebar-nav::-webkit-scrollbar {
                width: 4px !important;
            }

            .sidebar-nav::-webkit-scrollbar-track {
                background: transparent !important;
            }

            .sidebar-nav::-webkit-scrollbar-thumb {
                background: transparent !important;
                border-radius: 10px !important;
                transition: background 0.3s ease !important;
            }

            .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.08) !important;
            }

                .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 193, 7, 0.25) !important;
                }

            /* ==========================================================================
                                   OMNI-SEARCH GLOBAL (ATLASSIAN / JIRA STYLE)
                                   ========================================================================== */
            .global-search-container {
                position: relative;
                width: 100%;
                max-width: 450px;
                z-index: 1050;
            }

            .global-search-input {
                background-color: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: #fff;
                border-radius: 6px;
                padding: 8px 16px 8px 36px;
                width: 100%;
                transition: all 0.2s ease;
                font-size: 0.85rem;
                font-family: monospace;
            }

                .global-search-input:focus {
                    background-color: rgba(0, 0, 0, 0.3);
                    border-color: #0dcaf0;
                    box-shadow: 0 0 0 3px rgba(13, 202, 240, 0.2);
                    outline: none;
                }

            .global-search-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255, 255, 255, 0.4);
                pointer-events: none;
            }

            .global-search-results {
                position: absolute;
                top: 100%;
                left: 0;
                width: 550px;
                max-width: 90vw;
                margin-top: 8px;
                background-color: #111424;
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 8px;
                box-shadow: 0 10px 40px rgba(0,0,0,0.6);
                z-index: 1051;
                display: none;
                max-height: 450px;
                overflow-y: auto;
                overflow-x: hidden;
            }

            .search-category-header {
                font-size: 0.65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: rgba(255,255,255,0.3);
                padding: 8px 12px;
                background-color: #07091e;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                border-top: 1px solid rgba(255,255,255,0.05);
                margin: 0;
            }

                .search-category-header:first-child {
                    border-top: none;
                    border-top-left-radius: 8px;
                    border-top-right-radius: 8px;
                }

            .search-result-item {
                display: flex;
                align-items: center;
                padding: 10px 12px;
                text-decoration: none !important;
                color: #fff;
                transition: background-color 0.2s;
                border-bottom: 1px solid rgba(255,255,255,0.03);
            }

                .search-result-item:last-child {
                    border-bottom: none;
                }

                .search-result-item:hover, .search-result-item.active {
                    background-color: rgba(13, 202, 240, 0.1);
                    color: #fff;
                }

            .search-result-icon {
                width: 32px;
                height: 32px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background-color: rgba(255,255,255,0.05);
                border-radius: 6px;
                margin-right: 12px;
                font-size: 1rem;
            }

            .search-result-text {
                display: flex;
                flex-direction: column;
                overflow: hidden;
                width: 100%;
            }

            .search-result-title {
                font-weight: 600;
                font-size: 0.85rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .search-result-desc {
                font-size: 0.7rem;
                color: rgba(255,255,255,0.5);
                font-family: monospace;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .search-loading {
                padding: 25px;
                text-align: center;
                color: rgba(255,255,255,0.5);
                font-size: 0.85rem;
                font-family: monospace;
            }

            .global-search-results::-webkit-scrollbar {
                width: 6px;
            }

            .global-search-results::-webkit-scrollbar-track {
                background: rgba(0,0,0,0.1);
            }

            .global-search-results::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.1);
                border-radius: 10px;
            }
    </style>


    <style>
            /* ── SIDEBAR COLAPSABLE ────────────────────────────────── */
            :root {
                --sidebar-collapsed-width: 56px;
            }

            .sidebar {
                transition: width 0.25s cubic-bezier(0.4,0,0.2,1) !important;
                overflow: visible !important; /* necesario para que los tooltips no se corten */
            }

                .sidebar.collapsed {
                    width: var(--sidebar-collapsed-width) !important;
                    overflow: visible !important;
                }

            /* El scroll va en sidebar-nav, no en sidebar */
            .sidebar-nav {
                overflow-y: auto !important;
                overflow-x: visible !important; /* permite que los tooltips salgan */
            }

            /* Logo y Brand Header */
            .sidebar-brand {
                height: auto !important;
                min-height: 70px !important;
                flex-direction: row !important; /* Fila cuando está expandido */
                justify-content: space-between !important;
                padding: 12px 16px !important;
            }

            .brand-left {
                align-items: flex-start !important;
            }

            .logo-full {
                transition: opacity 0.2s;
                max-height: 28px;
                width: auto;
            }

            .logo-mini {
                display: none;
                height: 26px;
                width: auto;
                transition: opacity 0.2s;
            }

            /* Comportamiento al colapsar */
            .sidebar.collapsed .sidebar-brand {
                flex-direction: column !important; /* Apila logo, badge y botón */
                padding: 12px 0 !important;
                gap: 12px !important;
            }

            .sidebar.collapsed .brand-left {
                align-items: center !important; /* Centra logo y badge */
                gap: 4px !important;
            }

            .sidebar.collapsed .logo-full {
                display: none !important;
            }

            .sidebar.collapsed .logo-mini {
                display: block !important;
            }

            .sidebar.collapsed #btnToggleSidebar {
                margin: 0 auto;
            }

            /* Textos y cabeceras ocultos al colapsar */
            .sidebar.collapsed .nav-header-custom,
            .sidebar.collapsed hr,
            .sidebar.collapsed .nav-link span,
            .sidebar.collapsed .transition-icon {
                display: none !important;
            }

            /* Badge de entorno: Oculta solo la palabra LOCAL/CLOUD, deja el icono */
            .sidebar.collapsed .env-text {
                display: none !important;
            }

            /* Iconos centrados */
            .sidebar.collapsed .nav-link {
                justify-content: center !important;
                padding: 0.45rem 0 !important;
                border-left: none !important;
                border-radius: 6px !important;
                margin: 1px 4px !important;
                position: relative;
            }

                .sidebar.collapsed .nav-link i {
                    margin-right: 0 !important;
                    font-size: 1.15rem !important;
                }

                .sidebar.collapsed .nav-link.active {
                    background-color: rgba(255,193,7,0.12) !important;
                    border-left: none !important;
                }

                /* Tooltip nativo al hacer hover */
                .sidebar.collapsed .nav-link[data-sidebar-label] {
                    overflow: visible !important;
                }

                    .sidebar.collapsed .nav-link[data-sidebar-label]:hover::after {
                        content: attr(data-sidebar-label);
                        position: fixed;
                        left: calc(var(--sidebar-collapsed-width) + 8px);
                        top: var(--tooltip-top, 50%);
                        transform: translateY(-50%);
                        background: #1a1d2e;
                        color: #fff;
                        font-size: 0.75rem;
                        font-weight: 600;
                        padding: 5px 12px;
                        border-radius: 6px;
                        white-space: nowrap;
                        z-index: 9999;
                        border: 1px solid rgba(255,255,255,0.15);
                        box-shadow: 0 4px 16px rgba(0,0,0,0.5);
                        pointer-events: none;
                    }

            /* Administración colapsada: panel flotante al hover */
            .sidebar.collapsed .admin-collapse-wrapper {
                position: static;
            }

            .sidebar.collapsed #adminCollapse {
                display: none !important;
            }

            /* FIX 1: Ocultar el flyout SIEMPRE por defecto para que no manche la vista expandida */
            .admin-flyout {
                display: none;
            }

            /* Estilos del flyout cuando el sidebar está colapsado */
            .sidebar.collapsed .admin-flyout {
                position: fixed;
                left: var(--sidebar-collapsed-width);
                top: 0; /* se ajusta via JS */
                background: #111424;
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 0 8px 8px 0;
                min-width: 210px;
                z-index: 9999;
                box-shadow: 4px 0 20px rgba(0,0,0,0.4);
                padding: 6px 0;
            }

                /* FIX 2: Puente invisible para que el mouse no pierda el hover al moverse hacia el panel */
                .sidebar.collapsed .admin-flyout::before {
                    content: '';
                    position: absolute;
                    left: -20px; /* Cubre el espacio vacío hacia la izquierda */
                    top: 0;
                    bottom: 0;
                    width: 20px;
                    background: transparent;
                }

            /* Mostrar el panel al hacer hover */
            .sidebar.collapsed .admin-collapse-wrapper:hover .admin-flyout {
                display: block !important;
            }

            .sidebar.collapsed .admin-flyout a {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 14px;
                font-size: 0.78rem;
                color: rgba(255,255,255,0.7);
                text-decoration: none;
                white-space: nowrap;
            }

                .sidebar.collapsed .admin-flyout a:hover {
                    background: rgba(255,193,7,0.08);
                    color: #fff;
                }

                .sidebar.collapsed .admin-flyout a i {
                    font-size: 0.9rem;
                    width: 16px;
                    text-align: center;
                }

            .sidebar.collapsed .admin-flyout-title {
                font-size: 0.62rem;
                font-weight: 700;
                color: rgba(255,255,255,0.28);
                letter-spacing: 1.2px;
                text-transform: uppercase;
                padding: 4px 14px 6px;
            }

            /* Botón toggle */
            #btnToggleSidebar {
                background: none;
                border: none;
                color: rgba(255,255,255,0.4);
                cursor: pointer;
                padding: 4px 6px;
                border-radius: 5px;
                font-size: 1rem;
                transition: color 0.2s, background 0.2s;
                flex-shrink: 0;
            }

                #btnToggleSidebar:hover {
                    color: #ffc107;
                    background: rgba(255,193,7,0.08);
                }

            /* main-content se expande al colapsar sidebar */
            .main-wrapper {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            .main-content {
                flex: 1;
                min-width: 0;
                overflow-y: auto;
                display: flex;
                flex-direction: column;
            }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isHomePage = currentController == "Home" && currentAction == "Index";
        var isAdminActive = currentController == "AdminDashboard" ||
        currentController == "Admin" ||
        currentController == "ValidationRuleAdmin" ||
        currentController == "AuditLog" ||
        currentController == "ParameterAdmin" ||
        currentController == "FunctionsAdmin";

        var buildDate = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    }

    <div class="main-wrapper">
        <aside class="sidebar">
            <div class="sidebar-brand w-100 d-flex align-items-center">
                <div class="brand-left d-flex flex-column gap-1">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <img src="~/img/Bit-solucion-logo-menu.png" alt="Bit Solución Logo" class="logo-full" />
                        <img src="~/img/B-logo-menu.png" alt="B" class="logo-mini" />
                    </a>
                    <div class="environment-badge text-uppercase font-monospace" style="font-size: 0.65rem; letter-spacing: 1px; opacity: 0.85;">
                        @if (Context.Request.Host.Host.Contains("localhost") || Context.Request.Host.Host.Contains("127.0.0.1"))
                        {
                            <span style="color: #ffc107;" title="LOCAL"><i class="bi bi-lightning-fill"></i><span class="env-text fw-bold ms-1">LOCAL</span></span>
                        }
                        else
                        {
                            <span style="color: #0ddb78;" title="CLOUD"><i class="bi bi-shield-fill-check"></i><span class="env-text fw-bold ms-1">CLOUD</span></span>
                        }
                    </div>
                </div>

                <button id="btnToggleSidebar" title="Colapsar/Expandir menú" class="ms-auto flex-shrink-0">
                    <i class="bi bi-layout-sidebar-reverse"></i>
                </button>
            </div>

            <nav class="sidebar-nav mt-2">
                <ul class="nav flex-column">
                    <li class="nav-header-custom">General</li>

                    <li class="nav-item">
                        <a class="nav-link @(isHomePage ? "active" : "")" asp-controller="Home" asp-action="Index"
                           data-sidebar-label="Inicio">
                            <i class="bi bi-house-door"></i> <span>Inicio</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Proyectos" ? "active" : "")" asp-controller="Proyectos" asp-action="Index"
                           data-sidebar-label="Gestor de Proyectos">
                            <i class="bi bi-kanban"></i> <span>Gestor de Proyectos</span>
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Clientes" ? "active" : "")" asp-controller="Clientes" asp-action="Index"
                               data-sidebar-label="Empresas / Clientes">
                                <i class="bi bi-buildings"></i> <span>Empresas / Clientes</span>
                            </a>
                        </li>
                    }

                    <li><hr></li>

                    <li class="nav-header-custom">Motor de Validación</li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Validador" ? "active" : "")" asp-controller="Home" asp-action="Validador"
                               data-sidebar-label="Validador de Notebooks">
                                <i class="bi bi-journal-code"></i> <span>Validador de Notebooks</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ParameterValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ParameterValidator" ? "active" : "")" asp-controller="ParameterValidator" asp-action="Index"
                               data-sidebar-label="Validador de Parámetros">
                                <i class="bi bi-filetype-py"></i> <span>Validador de Parámetros</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "RegexSandbox" ? "active" : "")" asp-controller="RegexSandbox" asp-action="Index"
                               data-sidebar-label="Sandbox de Reglas">
                                <i class="bi bi-shield-shaded"></i> <span>Sandbox de Reglas</span>
                            </a>
                        </li>
                    }

                    <li><hr></li>

                    <li class="nav-header-custom">Datos y Procesamiento</li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DataProfiling" ? "active" : "")" asp-controller="DataProfiling" asp-action="Index"
                               data-sidebar-label="Perfilamiento de Datos">
                                <i class="bi bi-bar-chart-steps"></i> <span>Perfilamiento de Datos</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Cuadratura" ? "active" : "")" asp-controller="Cuadratura" asp-action="Index"
                               data-sidebar-label="Cuadratura de Datos">
                                <i class="bi bi-table"></i> <span>Cuadratura de Datos</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "NotebookGenerator" ? "active" : "")" asp-controller="NotebookGenerator" asp-action="Index"
                               data-sidebar-label="Generador de Notebooks">
                                <i class="bi bi-file-earmark-plus"></i> <span>Generador de Notebooks</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DocGen" ? "active" : "")" asp-controller="DocGen" asp-action="Index"
                               data-sidebar-label="Documentador Técnico">
                                <i class="bi bi-journal-text"></i> <span>Documentador Técnico</span>
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "JobConverter" ? "active" : "")" asp-controller="JobConverter" asp-action="Index"
                           data-sidebar-label="Generador de Jobs">
                            <i class="bi bi-wrench-adjustable-circle-fill"></i> <span>Generador de Jobs</span>
                        </a>
                    </li>

                    @* ── NUEVO MÓDULO AGREGADO AQUÍ ── *@
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "JobVisualizer" ? "active" : "")" asp-controller="JobVisualizer" asp-action="Index"
                           data-sidebar-label="Ingeniería Inversa">
                            <i class="bi bi-diagram-3-fill"></i> <span>Ingeniería Inversa</span>
                        </a>
                    </li>

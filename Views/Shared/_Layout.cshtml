<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bit Solución</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ==========================================================================
           ESTANDARIZACIÓN GLOBAL DE SIDEBAR AL ALTO IMPACTO (COMPACTO AL 75%)
           ========================================================================== */
        :root {
            --sidebar-width: 260px !important;
            --topbar-height: 60px !important;
        }

        html, body {
            height: 100% !important;
            margin: 0 !important;
            background-color: #0f111a !important;
            overflow-x: hidden !important;
        }

        /* BARRA LATERAL CONTENIDA */
        .sidebar {
            width: var(--sidebar-width) !important;
            background-color: #0b0d16 !important;
            border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
            display: flex !important;
            flex-direction: column !important;
            overflow-y: hidden !important;
            overflow-x: hidden !important;
            height: 100vh !important;
        }

        .sidebar-brand {
            display: flex !important;
            flex-direction: column !important;
            justify-content: center !important;
            align-items: center !important;
            padding: 0.8rem 1rem 0.4rem !important;
            height: 80px !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
            background-color: #0b0d16 !important;
            flex-shrink: 0 !important;
            z-index: 10 !important;
        }

        .sidebar-nav {
            overflow-y: auto !important;
            overflow-x: hidden !important;
            flex-grow: 1 !important;
            padding: 0 0.5rem !important;
        }

        .sidebar-nav .nav {
            gap: 2px !important;
        }

        .sidebar-nav .nav-link {
            color: rgba(255, 255, 255, 0.6) !important;
            border-left: 4px solid transparent !important;
            padding: 0.16rem 0.8rem !important;
            border-radius: 4px !important;
            font-weight: 500 !important;
            transition: all 0.2s ease !important;
            display: flex !important;
            align-items: center !important;
            background-color: transparent !important;
            text-decoration: none;
            margin-bottom: 0 !important;
            white-space: nowrap !important;
            font-size: 0.78rem !important;
            line-height: 1.2 !important;
        }

        .sidebar-nav .nav-link i,
        .sidebar-nav .nav-link i.bi {
            font-size: 1.05rem !important;
            margin-right: 0.65rem !important;
            width: 18px !important;
            text-align: center !important;
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }

        .sidebar-nav .nav-link:hover {
            color: #fff !important;
            background-color: rgba(255, 255, 255, 0.04) !important;
        }

        .sidebar-nav .nav-link:hover i,
        .sidebar-nav .nav-link:hover i.bi {
            transform: translateX(2px) !important;
        }

        .sidebar-nav .nav-link.active {
            color: #fff !important;
            background-color: rgba(255, 193, 7, 0.08) !important;
            border-left: 4px solid #ffc107 !important;
            font-weight: 600 !important;
        }

        .sidebar-nav .nav-link.active i,
        .sidebar-nav .nav-link.active i.bi {
            color: #ffc107 !important;
        }

        .nav-header-custom {
            font-size: 0.62rem !important;
            letter-spacing: 1.2px !important;
            font-weight: 700 !important;
            color: rgba(255, 255, 255, 0.28) !important;
            padding: 0.8rem 0.8rem 0.2rem !important;
            text-transform: uppercase !important;
            white-space: nowrap;
            margin-top: 0px !important;
            margin-bottom: 0px !important;
        }

        .nav-header-custom:first-child {
            padding-top: 0.5rem !important;
        }

        .sidebar-nav hr {
            margin: 0.25rem 0.75rem !important;
            border-color: rgba(255, 255, 255, 0.05) !important;
            opacity: 0.15 !important;
        }

        .sidebar-nav .nav-link[aria-expanded="true"] .transition-icon {
            transform: rotate(180deg) !important;
            color: #ffc107 !important;
        }

        .transition-icon {
            transition: transform 0.2s ease !important;
        }

        .sidebar-nav .collapse .nav-link {
            border-left: none !important;
            padding: 0.14rem 0.8rem 0.14rem 1.8rem !important;
            color: rgba(255, 255, 255, 0.45) !important;
            font-size: 0.74rem !important;
        }

        .logo-full {
            display: block !important;
            height: 32px;
        }

        .main-content {
            background-color: #0f111a !important;
            min-width: 0;
        }

        .top-bar {
            background-color: #0f111a !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03) !important;
            height: 60px !important;
        }

        .sidebar-nav::-webkit-scrollbar { width: 4px !important; }
        .sidebar-nav::-webkit-scrollbar-track { background: transparent !important; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: transparent !important; border-radius: 10px !important; transition: background 0.3s ease !important; }
        .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.08) !important; }
        .sidebar:hover .sidebar-nav::-webkit-scrollbar-thumb:hover { background: rgba(255, 193, 7, 0.25) !important; }

        /* ==========================================================================
           OMNI-SEARCH GLOBAL (ATLASSIAN / JIRA STYLE)
           ========================================================================== */
        .global-search-container { position: relative; width: 100%; max-width: 450px; z-index: 1050; }
        .global-search-input {
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 6px;
            padding: 8px 16px 8px 36px;
            width: 100%;
            transition: all 0.2s ease;
            font-size: 0.85rem;
            font-family: monospace;
        }
        .global-search-input:focus {
            background-color: rgba(0, 0, 0, 0.3);
            border-color: #0dcaf0;
            box-shadow: 0 0 0 3px rgba(13, 202, 240, 0.2);
            outline: none;
        }
        .global-search-icon {
            position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.4); pointer-events: none;
        }
        .global-search-results {
            position: absolute; top: 100%; left: 0; width: 550px; max-width: 90vw; margin-top: 8px;
            background-color: #111424; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6); z-index: 1051; display: none;
            max-height: 450px; overflow-y: auto; overflow-x: hidden;
        }
        .search-category-header {
            font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
            color: rgba(255,255,255,0.3); padding: 8px 12px; background-color: #07091e;
            border-bottom: 1px solid rgba(255,255,255,0.05); border-top: 1px solid rgba(255,255,255,0.05); margin: 0;
        }
        .search-category-header:first-child { border-top: none; border-top-left-radius: 8px; border-top-right-radius: 8px; }
        .search-result-item {
            display: flex; align-items: center; padding: 10px 12px; text-decoration: none !important;
            color: #fff; transition: background-color 0.2s; border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover, .search-result-item.active { background-color: rgba(13, 202, 240, 0.1); color: #fff; }
        .search-result-icon {
            width: 32px; height: 32px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            background-color: rgba(255,255,255,0.05); border-radius: 6px; margin-right: 12px; font-size: 1rem;
        }
        .search-result-text { display: flex; flex-direction: column; overflow: hidden; width: 100%; }
        .search-result-title { font-weight: 600; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .search-result-desc { font-size: 0.7rem; color: rgba(255,255,255,0.5); font-family: monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .search-loading { padding: 25px; text-align: center; color: rgba(255,255,255,0.5); font-size: 0.85rem; font-family: monospace; }
        .global-search-results::-webkit-scrollbar { width: 6px; }
        .global-search-results::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); }
        .global-search-results::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isHomePage = currentController == "Home" && currentAction == "Index";
        var isAdminActive = currentController == "AdminDashboard" ||
        currentController == "Admin" ||
        currentController == "ValidationRuleAdmin" ||
        currentController == "AuditLog" ||
        currentController == "ParameterAdmin" ||
        currentController == "FunctionsAdmin";

        var buildDate = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    }

    <div class="main-wrapper">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a class="d-flex align-items-center justify-content-center w-100 mb-1" asp-controller="Home" asp-action="Index">
                    <img src="~/img/Bit-solucion-logo-menu.png" alt="Bit Solución Logo" class="logo-full" />
                </a>

                <div class="environment-badge text-uppercase text-center text-white-50 font-monospace" style="font-size: 0.62rem; letter-spacing: 1.5px; opacity: 0.7;">
                    @if (Context.Request.Host.Host.Contains("localhost") || Context.Request.Host.Host.Contains("127.0.0.1"))
                    {
                        <span style="color: #ffc107;"><i class="bi bi-lightning-fill me-1"></i>Local</span>
                    }
                    else
                    {
                        <span style="color: #0ddb78;"><i class="bi bi-shield-fill-check me-1"></i>Cloud</span>
                    }
                </div>
            </div>

            <nav class="sidebar-nav mt-2">
                <ul class="nav flex-column">
                    <li class="nav-header-custom">General</li>
                   
                    <li class="nav-item">
                        <a class="nav-link @(isHomePage ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> <span>Inicio</span>
                        </a>
                    </li>

                    <li><hr></li>

                    <li class="nav-header-custom">Motor de Validación</li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Validador" ? "active" : "")" asp-controller="Home" asp-action="Validador">
                                <i class="bi bi-journal-code"></i> <span>Validador de Notebooks</span>
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Proyectos" ? "active" : "")" asp-controller="Proyectos" asp-action="Index">
                            <i class="bi bi-kanban"></i> <span>Gestor de Proyectos</span>
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Clientes" ? "active" : "")" asp-controller="Clientes" asp-action="Index">
                                <i class="bi bi-buildings"></i> <span>Empresas / Clientes</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ParameterValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ParameterValidator" ? "active" : "")" asp-controller="ParameterValidator" asp-action="Index">
                                <i class="bi bi-filetype-py"></i> <span>Validador de Parámetros</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "RegexSandbox" ? "active" : "")" asp-controller="RegexSandbox" asp-action="Index">
                                <i class="bi bi-shield-shaded"></i> <span>Sandbox de Reglas</span>
                            </a>
                        </li>
                    }

                    <li><hr></li>

                    <li class="nav-header-custom">Datos y Procesamiento</li>

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DataProfiling" ? "active" : "")" asp-controller="DataProfiling" asp-action="Index">
                                <i class="bi bi-bar-chart-steps"></i> <span>Perfilamiento de Datos</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Cuadratura" ? "active" : "")" asp-controller="Cuadratura" asp-action="Index">
                                <i class="bi bi-table"></i> <span>Cuadratura de Datos</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "NotebookGenerator" ? "active" : "")" asp-controller="NotebookGenerator" asp-action="Index">
                                <i class="bi bi-file-earmark-plus"></i> <span>Generador de Notebooks</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("ValidatorUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DocGen" ? "active" : "")" asp-controller="DocGen" asp-action="Index">
                                <i class="bi bi-journal-text"></i> <span>Documentador Técnico</span>
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "JobConverter" ? "active" : "")" asp-controller="JobConverter" asp-action="Index">
                            <i class="bi bi-wrench-adjustable-circle-fill"></i> <span>Generador de Jobs</span>
                        </a>
                    </li>

                    @if (User.IsInRole("Admin") || User.IsInRole("TempCleanerUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "TempTable" ? "active" : "")" asp-controller="TempTable" asp-action="Index">
                                <i class="bi bi-trash3"></i> <span>Limpieza Temporal</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li><hr></li>
                        <li class="nav-header-custom" style="color: #ffc107 !important; opacity: 0.85;">Sistema</li>
                        <li class="nav-item">
                            <a class="nav-link @(isAdminActive ? "active" : "text-warning fw-bold") d-flex align-items-center"
                               data-bs-toggle="collapse" href="#adminCollapse" role="button" aria-expanded="@(isAdminActive ? "true" : "false")" aria-controls="adminCollapse">
                                <i class="bi bi-shield-lock-fill"></i> <span>Administración</span>
                                <i class="bi bi-chevron-down ms-auto small transition-icon"></i>
                            </a>
                            <div class="collapse @(isAdminActive ? "show" : "")" id="adminCollapse">
                                <ul class="nav flex-column ms-3 mt-1 border-start border-secondary" style="border-width: 2px !important;">
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "AdminDashboard" ? "active" : "")" asp-controller="AdminDashboard" asp-action="Index">
                                            <i class="bi bi-speedometer2"></i> <span>Dashboard Global</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                                            <i class="bi bi-people"></i> <span>Gestionar Usuarios</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "ValidationRuleAdmin" ? "active" : "")" asp-controller="ValidationRuleAdmin" asp-action="Index">
                                            <i class="bi bi-list-check"></i> <span>Reglas Validador</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "FunctionsAdmin" ? "active" : "")" asp-controller="FunctionsAdmin" asp-action="Index">
                                            <i class="bi bi-braces-asterisk"></i> <span>Funciones (Maestro)</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "AuditLog" ? "active" : "")" asp-controller="AuditLog" asp-action="Index">
                                            <i class="bi bi-shield-check"></i> <span>Log de Auditoría</span>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-2 @(currentController == "ParameterAdmin" ? "active" : "")" asp-controller="ParameterAdmin" asp-action="Index">
                                            <i class="bi bi-tags-fill"></i> <span>Admin. Parámetros</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    }
                </ul>
            </nav>
        </aside>
        <main class="main-content">
            <header class="top-bar px-4 d-flex justify-content-between align-items-center">
                <div class="global-search-container flex-grow-1" style="max-width: 450px;">
                    <i class="bi bi-search global-search-icon"></i>
                    <input type="text" id="globalSearchInput" class="global-search-input" placeholder="Buscar proyectos, tablas, código o bitácoras..." autocomplete="off" />
                    <div id="globalSearchResults" class="global-search-results"></div>
                </div>

                <div>
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <div class="content-body container-fluid py-4">
                @RenderBody()
            </div>

            <footer class="border-top py-3 mt-auto" style="border-color: rgba(255,255,255,0.05) !important; background-color: #0b0b0b;">
                <div class="container-fluid px-4 d-flex flex-column flex-md-row justify-content-between align-items-center small">
                    <div class="mb-1 mb-md-0 d-flex align-items-center">
                        <span class="me-2" style="color:#FFD43B;">⚡</span>
                        <strong style="color:#FFD43B;">Bitsolución Herramientas</strong>
                        <span class="text-secondary ms-1">© @DateTime.Now.Year</span>
                    </div>
                    <div class="d-flex align-items-center" data-bs-toggle="tooltip" title="Versión completa: @VersionHelper.GetVersion() | Compilado el @buildDate">
                        <span class="text-secondary me-2">Versión</span>
                        <span class="px-2 py-1 rounded" style="background-color:#FFD43B; color:#000; font-family: monospace; font-weight: bold;">
                            @{
                                var fullVersion = VersionHelper.GetVersion();
                                var shortVersion = fullVersion.Length > 7 ? fullVersion.Substring(0, 7) : fullVersion;
                            }
                            @shortVersion
                        </span>
                    </div>
                </div>
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/lib/qrcode/qrcode.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        let searchTimeout;
        const searchInput = document.getElementById('globalSearchInput');
        const searchResults = document.getElementById('globalSearchResults');

        if(searchInput) {
        searchInput.addEventListener('input', function(e) {
        clearTimeout(searchTimeout);
        const query = e.target.value.trim();

        if (query.length < 2) {
        searchResults.style.display = 'none';
        return;
        }

        searchResults.style.display = 'block';
        searchResults.innerHTML = '<div class="search-loading"><div class="spinner-border spinner-border-sm text-info me-2"></div>Buscando coincidencias...</div>';

        searchTimeout = setTimeout(() => {
        fetch(`/Proyectos/GlobalSearch?q=${encodeURIComponent(query)}`)
        .then(response => response.json())
        .then(data => {
        searchResults.innerHTML = '';

        if (data.length === 0) {
        searchResults.innerHTML = '<div class="search-loading text-warning"><i class="bi bi-emoji-frown fs-4 d-block mb-2 text-secondary"></i>No se encontraron resultados para "'+ query +'"</div>';
        return;
        }

        const grouped = data.reduce((acc, curr) => {
        if (!acc[curr.categoria]) acc[curr.categoria] = [];
        acc[curr.categoria].push(curr);
        return acc;
        }, {});

        for (const [category, items] of Object.entries(grouped)) {
        searchResults.innerHTML += `<h6 class="search-category-header">${category}</h6>`;
        items.forEach(item => {
        searchResults.innerHTML += `
        <a href="${item.url}" class="search-result-item">
        <div class="search-result-icon"><i class="bi ${item.icono}"></i></div>
        <div class="search-result-text">
        <span class="search-result-title">${item.titulo}</span>
        <span class="search-result-desc">${item.descripcion}</span>
        </div>
        </a>
        `;
        });
        }
        })
        .catch(error => {
        searchResults.innerHTML = '<div class="search-loading text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Error de conexión.</div>';
        });
        }, 350);
        });

        document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.style.display = 'none';
        }
        });

        searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResults.innerHTML !== '') {
        searchResults.style.display = 'block';
        }
        });
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

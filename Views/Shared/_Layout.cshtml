    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/lib/qrcode/qrcode.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
        });
        let searchTimeout;
        const searchInput = document.getElementById('globalSearchInput');
        const searchResults = document.getElementById('globalSearchResults');
        if(searchInput) {
        searchInput.addEventListener('input', function(e) {
        clearTimeout(searchTimeout);
        const query = e.target.value.trim();

        if (query.length < 2) {
        searchResults.style.display = 'none';
        return;
        }

        searchResults.style.display = 'block';
        searchResults.innerHTML = '<div class="search-loading"><div class="spinner-border spinner-border-sm text-info me-2"></div>Buscando coincidencias...</div>';

        searchTimeout = setTimeout(() => {
        fetch(`/Proyectos/GlobalSearch?q=${encodeURIComponent(query)}`)
        .then(response => response.json())
        .then(data => {
        searchResults.innerHTML = '';

        if (data.length === 0) {
        searchResults.innerHTML = '<div class="search-loading text-warning"><i class="bi bi-emoji-frown fs-4 d-block mb-2 text-secondary"></i>No se encontraron resultados para "'+ query +'"</div>';
        return;
        }

        const grouped = data.reduce((acc, curr) => {
        if (!acc[curr.categoria]) acc[curr.categoria] = [];
        acc[curr.categoria].push(curr);
        return acc;
        }, {});

        for (const [category, items] of Object.entries(grouped)) {
        searchResults.innerHTML += `<h6 class="search-category-header">${category}</h6>`;
        items.forEach(item => {
        searchResults.innerHTML += `
        <a href="${item.url}" class="search-result-item">
        <div class="search-result-icon"><i class="bi ${item.icono}"></i></div>
        <div class="search-result-text">
        <span class="search-result-title">${item.titulo}</span>
        <span class="search-result-desc">${item.descripcion}</span>
        </div>
        </a>
        `;
        });
        }
        })
        .catch(error => {
        searchResults.innerHTML = '<div class="search-loading text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Error de conexión.</div>';
        });
        }, 350);
        });

        document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.style.display = 'none';
        }
        });
        searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResults.innerHTML !== '') {
        searchResults.style.display = 'block';
        }
        });
        }
        });
    </script>

    @* ── Toggle sidebar ── *@
    <script>
        (function() {
        const sidebar     = document.querySelector('.sidebar');
        const btn         = document.getElementById('btnToggleSidebar');
        const STORAGE_KEY = 'sidebar_collapsed';
        const adminWrapper = document.querySelector('.admin-collapse-wrapper');
        const adminFlyout  = adminWrapper?.querySelector('.admin-flyout');

        // Posicionar flyout de admin dinámicamente
        if (adminWrapper && adminFlyout) {
        adminWrapper.addEventListener('mouseenter', function() {
        const rect = adminWrapper.getBoundingClientRect();
        adminFlyout.style.top = rect.top + 'px';
        });
        }

        // Posicionar tooltips de ::after via CSS variable por elemento
        // Los tooltips usan position:fixed, necesitamos pasar el top via CSS custom property
        document.querySelectorAll('.nav-link[data-sidebar-label]').forEach(link => {
        link.addEventListener('mouseenter', function() {
        const rect = this.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        this.style.setProperty('--tooltip-top', midY + 'px');
        });
        });

        function applyState(collapsed) {
        if (collapsed) {
        sidebar.classList.add('collapsed');
        btn.querySelector('i').className = 'bi bi-layout-sidebar';
        btn.title = 'Expandir menú';
        } else {
        sidebar.classList.remove('collapsed');
        btn.querySelector('i').className = 'bi bi-layout-sidebar-reverse';
        btn.title = 'Colapsar menú';
        }
        }

        const saved = localStorage.getItem(STORAGE_KEY);
        applyState(saved === 'true');

        btn.addEventListener('click', function() {
        const newState = !sidebar.classList.contains('collapsed');
        applyState(newState);
        localStorage.setItem(STORAGE_KEY, newState);
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @* ── Sistema de Notificaciones ── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
        <script>
            (function() {
            const NOTIF_TIPOS_ICONOS = {
            ValidacionRechazada : { icon: 'bi-x-circle-fill',      color: '#dc3545' },
            CodigoSubido        : { icon: 'bi-cloud-upload-fill',  color: '#0dcaf0' },
            Mencion             : { icon: 'bi-at',                 color: '#ffc107' },
            RecordatorioVencido : { icon: 'bi-clock-history',      color: '#fd7e14' },
            DocumentoSubido     : { icon: 'bi-paperclip',          color: '#198754' },
            FaseCambiada        : { icon: 'bi-check-circle-fill',  color: '#0ddb78' }
            };

            function buildNotifHtml(n) {
            const cfg = NOTIF_TIPOS_ICONOS[n.tipo] || { icon: 'bi-info-circle', color: '#6c757d' };
            return `<a href="${n.url || '#'}" class="d-flex align-items-start gap-3 px-3 py-2 text-decoration-none notif-item"
            style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.15s;"
            onmouseover="this.style.background='rgba(255,255,255,0.04)'"
            onmouseout="this.style.background=''"
            data-id="${n.id}">
            <i class="bi ${cfg.icon} flex-shrink-0 mt-1" style="color:${cfg.color}; font-size:1rem;"></i>
            <div class="flex-grow-1 overflow-hidden">
            <div class="text-white fw-bold text-truncate" style="font-size:0.78rem;">${n.titulo}</div>
            ${n.descripcion ? `<div class="text-white-50 text-truncate" style="font-size:0.7rem;">${n.descripcion}</div>` : ''}
            <div class="text-secondary" style="font-size:0.65rem;">${n.fecha}</div>
            </div>
            </a>`;
            }

            function actualizarBadge(count) {
            const badge = document.getElementById('notif-badge');
            if (!badge) return;
            if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.classList.remove('d-none');
            } else {
            badge.classList.add('d-none');
            }
            }

            function cargarNotificaciones() {
            fetch('/Notificaciones/ObtenerNoLeidas')
            .then(r => r.json())
            .then(data => {
            const lista  = document.getElementById('notif-lista');
            const vacio  = document.getElementById('notif-vacio');
            if (!lista) return;

            actualizarBadge(data.length);

            if (data.length === 0) {
            lista.innerHTML = '';
            lista.appendChild(vacio || document.createElement('div'));
            if (vacio) vacio.classList.remove('d-none');
            return;
            }

            if (vacio) vacio.remove();
            lista.innerHTML = data.map(buildNotifHtml).join('');
            })
            .catch(() => {});
            }

            // Cargar al iniciar
            cargarNotificaciones();
            // Refrescar cada 60 segundos como fallback
            setInterval(cargarNotificaciones, 60000);
            // Toggle del panel
            document.getElementById('btnNotificaciones')?.addEventListener('click', function(e) {
            e.stopPropagation();
            const panel = document.getElementById('notif-panel');
            if (!panel) return;
            const abierto = !panel.classList.contains('d-none');
            panel.classList.toggle('d-none');
            if (!abierto) cargarNotificaciones(); // Refrescar al abrir
            });
            // Cerrar al hacer clic fuera
            document.addEventListener('click', function(e) {
            const container = document.getElementById('notif-container');
            if (container && !container.contains(e.target))
            document.getElementById('notif-panel')?.classList.add('d-none');
            });
            // ── SignalR: recibir notificaciones en tiempo real ─────
            const connection = new signalR.HubConnectionBuilder()
            .withUrl('/notificacionesHub')
            .withAutomaticReconnect()
            .build();
            connection.on('NuevaNotificacion', function(n) {
            const lista = document.getElementById('notif-lista');
            const vacio = document.getElementById('notif-vacio');
            if (lista) {
            if (vacio) vacio.remove();
            lista.insertAdjacentHTML('afterbegin', buildNotifHtml(n));
            }
            // Actualizar badge
            const badge = document.getElementById('notif-badge');
            if (badge) {
            const actual = parseInt(badge.textContent) || 0;
            actualizarBadge(actual + 1);
            }
            // Toastr discreto
            if (typeof toastr !== 'undefined') {
            const cfg = NOTIF_TIPOS_ICONOS[n.tipo] || {};
            toastr.info(n.titulo, '', { timeOut: 4000, positionClass: 'toast-bottom-right' });
            }
            });
            connection.start().catch(() => {});
            })();

            window.marcarTodasLeidas = function() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!token) return;
            fetch('/Notificaciones/MarcarTodasLeidas', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token.value }
            })
            .then(r => r.json())
            .then(() => {
            document.getElementById('notif-lista').innerHTML = '';
            document.getElementById('notif-badge')?.classList.add('d-none');
            const vacio = document.getElementById('notif-vacio');
            if (vacio) {
            vacio.classList.remove('d-none');
            document.getElementById('notif-lista').appendChild(vacio);
            }
            });
            };
        </script>
    }

</body>

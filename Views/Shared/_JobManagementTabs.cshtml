@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<style>
    .job-suite-container {
        background-color: #161b22;
        border-radius: 8px;
        padding: 6px;
        margin-bottom: 25px;
        border: 1px solid #30363d;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    /* Grid 100% estricto, sin clases de Bootstrap que interfieran */
    .job-suite-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        width: 100%;
        margin: 0;
        padding: 0;
    }

    .job-suite-btn {
        color: #adb5bd;
        background-color: transparent;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 10px 15px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        border: 1px solid transparent; /* Evita salto al aplicar borde */
    }

        .job-suite-btn:hover {
            color: #fff;
            background-color: rgba(255,255,255,0.05);
        }

        .job-suite-btn.active {
            background-color: rgba(255, 193, 7, 0.12);
            color: #ffc107 !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            border: 1px solid rgba(255, 193, 7, 0.2);
        }
</style>

<div class="job-suite-container">
    <div class="job-suite-grid">
        <a class="job-suite-btn @(currentController == "JobConverter" ? "active" : "")" href="@Url.Action("Index", "JobConverter")">
            <i class="bi bi-wrench-adjustable-circle-fill me-2"></i> Generador (YAML Bundles)
        </a>

        <a class="job-suite-btn @(currentController == "JobVisualizer" ? "active" : "")" href="@Url.Action("Index", "JobVisualizer")">
            <i class="bi bi-diagram-3-fill me-2"></i> Ingeniería Inversa (LINAJE)
        </a>

        <a class="job-suite-btn @(currentController == "LegacyJobMigration" ? "active" : "")" href="@Url.Action("Index", "LegacyJobMigration")">
            <i class="bi bi-file-earmark-code-fill me-2"></i> Migración Legacy (JSON a YAML)
        </a>
    </div>
</div>

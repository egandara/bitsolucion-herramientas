@using Microsoft.AspNetCore.Identity
@using NotebookValidator.Web.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        var quota = user?.AnalysisQuota ?? 0;
        var fullEmail = user?.UserName ?? "Usuario";

        // Lógica para extraer solo el Primer Nombre del correo
        // Ej: "esteban.gandara@empresa.com" -> "Esteban"
        var displayName = fullEmail.Split('@')[0].Split('.')[0];
        if (displayName.Length > 0)
        {
            displayName = char.ToUpper(displayName[0]) + displayName.Substring(1).ToLower();
        }

        var initial = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "U";

        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle topbar-user-toggle d-flex align-items-center" href="#" id="navbarDropdownUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="user-avatar-sm me-2">@initial</div>
                <span class="d-none d-md-inline fw-bold text-white" style="letter-spacing: 0.5px;">Hola, @displayName</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end topbar-dropdown-menu shadow" aria-labelledby="navbarDropdownUser">
                <li class="dropdown-header-custom">
                    <div class="d-flex align-items-center p-3">
                        <div class="user-avatar-lg me-3">@initial</div>
                        <div class="user-info">
                            <p class="user-name-text mb-0 text-white" style="font-size: 1.05rem;">@displayName</p>
                            <small class="user-email-text">@fullEmail</small>
                        </div>
                    </div>
                </li>

                <li><hr class="dropdown-divider"></li>

                <li class="px-3 py-2">
                    <div class="quota-badge-container d-flex justify-content-between align-items-center p-2 rounded">
                        <span class="text-white"><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Créditos</span>
                        <span class="fw-bold text-warning" style="font-size: 1.1rem;">@quota</span>
                    </div>
                </li>

                <li>
                    <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear me-2"></i> Mi Perfil
                    </a>
                </li>
                <li>
                    <a class="dropdown-item py-2" asp-controller="HomeController" asp-action="History">
                        <i class="bi bi-clock-history me-2"></i> Historial de Análisis
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li><hr class="dropdown-divider"></li>
                    <li class="dropdown-header small text-uppercase px-3" style="color: var(--medium-text);">Administración</li>
                    <li>
                        <a class="dropdown-item py-2" asp-controller="AdminDashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-2 text-info"></i> Panel de Control
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider"></li>

                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item logout-item py-2">
                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar sesión
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link topbar-user-toggle text-white" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus"></i> <span>Registrarse</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link topbar-user-toggle text-white" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right"></i> <span>Ingresar</span>
            </a>
        </li>
    }
</ul>

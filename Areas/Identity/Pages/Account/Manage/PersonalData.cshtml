@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Información Personal";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
    Layout = "_ManageLayout.cshtml";
}

<div class="row">
    <div class="col-xl-8 col-lg-10">
        <h3>
            <i class="bi bi-database-gear text-warning me-2"></i>@ViewData["Title"]
        </h3>

        <div class="mt-4 text-white-50">
            <p>Tu cuenta contiene información personal que nos has proporcionado. Esta página te permite descargar o eliminar esos datos de nuestro sistema.</p>

            <div class="alert bg-black border-secondary p-4 mt-4 rounded-3">
                <h5 class="text-white mb-3">Zona de descarga</h5>
                <p class="small">Al hacer clic en descargar, recibirás un archivo con toda la información vinculada a tu perfil en <strong>Bit Solución</strong>.</p>
                <form id="download-data" asp-page="DownloadPersonalData" method="post">
                    <button class="btn btn-warning text-dark fw-bold rounded-pill px-5 shadow-sm" type="submit">
                        <i class="bi bi-download me-2"></i>Descargar mis datos
                    </button>
                </form>
            </div>

            <div class="alert border-danger bg-dark p-4 mt-4 rounded-3" style="background-color: rgba(220, 53, 69, 0.05) !important;">
                <h5 class="text-danger mb-3"><i class="bi bi-exclamation-triangle me-2"></i>Zona de Peligro</h5>
                <p class="small text-white-50">Eliminar tu cuenta es un proceso <strong>permanente e irreversible</strong>. Perderás el acceso a tus análisis, configuraciones y créditos actuales.</p>
                <p>
                    <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger rounded-pill px-4">
                        <i class="bi bi-person-x me-2"></i>Eliminar mi cuenta
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

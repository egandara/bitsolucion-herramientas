@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card bg-black border-secondary shadow-sm p-4">
            <h4 class="text-white mb-4">
                <i class="bi bi-key text-warning me-2"></i>Actualizar Seguridad
            </h4>

            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.OldPassword" class="form-control bg-dark border-secondary text-white shadow-none" autocomplete="current-password" aria-required="true" placeholder="Contraseña actual" />
                    <label asp-for="Input.OldPassword" class="text-white-50">Contraseña actual</label>
                    <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.NewPassword" class="form-control bg-dark border-secondary text-white shadow-none" autocomplete="new-password" aria-required="true" placeholder="Nueva contraseña" />
                    <label asp-for="Input.NewPassword" class="text-white-50">Nueva contraseña</label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control bg-dark border-secondary text-white shadow-none" autocomplete="new-password" aria-required="true" placeholder="Confirmar nueva contraseña" />
                    <label asp-for="Input.ConfirmPassword" class="text-white-50">Confirmar nueva contraseña</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-pill text-dark">
                    <i class="bi bi-shield-lock-fill me-2"></i>ACTUALIZAR CONTRASEÑA
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@section Styles {
    <style>
        .form-floating > label {
            color: #888;
        }

        .form-floating > .form-control:focus ~ label {
            color: #ffc107 !important;
            font-weight: bold;
        }
    </style>
}

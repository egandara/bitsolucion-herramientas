@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NotebookValidator.Web.Data.ApplicationDbContext Context
@{
    ViewData["Title"] = "Perfil de Usuario";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "_ManageLayout.cshtml";

    var user = await UserManager.GetUserAsync(User);
    if (user == null) { return; }

    var userRoles = await UserManager.GetRolesAsync(user);

    // Consultamos los resúmenes de análisis vinculados al usuario
    var userSummaries = Context.AnalysisSummaries
                               .Where(s => Context.AnalysisRuns.Any(r => r.Id == s.AnalysisRunId && r.UserId == user.Id))
                               .OrderByDescending(s => s.AnalysisTimestamp)
                               .ToList();

    var totalAnalyses = userSummaries.Count;

    // Sumamos los contadores de hallazgos
    var totalFindings = userSummaries.Sum(s => s.CriticalCount + s.WarningCount);
    var criticals = userSummaries.Sum(s => s.CriticalCount);
    var warnings = userSummaries.Sum(s => s.WarningCount);

    bool isSecure = user.TwoFactorEnabled;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-12 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-white m-0">
                <i class="bi bi-person-vcard text-warning me-2"></i>Panel de Usuario
            </h3>
            <div class="d-flex gap-2">
                @foreach (var role in userRoles)
                {
                    <span class="badge border border-warning text-warning bg-dark px-3 py-2"
                          data-bs-toggle="tooltip" title="Nivel de acceso: @role.">
                        <i class="bi bi-shield-lock me-1"></i> @role
                    </span>
                }
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card bg-black border-secondary shadow-sm h-100 card-stat">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <h6 class="text-white-50 small fw-bold m-0 text-uppercase">Créditos Disponibles</h6>
                            <i class="bi bi-lightning-charge text-warning"></i>
                        </div>
                        <h3 class="text-white fw-bold mb-2">@user.AnalysisQuota.ToString("N0")</h3>
                        <div class="progress bg-dark" style="height: 6px;">
                            <div class="progress-bar bg-warning" style="width: @(Math.Min((user.AnalysisQuota / 100000.0) * 100, 100))%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-black border-secondary shadow-sm h-100 card-stat">
                    <div class="card-body">
                        <h6 class="text-white-50 small fw-bold mb-3 text-uppercase">Análisis Ejecutados</h6>
                        <div class="d-flex align-items-end justify-content-between">
                            <h3 class="text-white fw-bold m-0">@totalAnalyses</h3>
                            <i class="bi bi-graph-up-arrow text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-black border-secondary shadow-sm h-100 card-stat">
                    <div class="card-body">
                        <h6 class="text-white-50 small fw-bold mb-2 text-uppercase">Hallazgos Totales</h6>
                        <h3 class="text-white fw-bold mb-2">@totalFindings.ToString("N0")</h3>
                        <div class="d-flex gap-3 small">
                            <span class="text-danger"><i class="bi bi-bug-fill me-1"></i>@criticals Críticos</span>
                            <span class="text-warning"><i class="bi bi-exclamation-triangle-fill me-1"></i>@warnings Alertas</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card bg-black border-secondary h-100 p-4 shadow-sm">
                    <h5 class="text-white mb-4 small text-uppercase fw-bold border-bottom border-secondary pb-2">
                        <i class="bi bi-shield-shaded text-warning me-2"></i>Seguridad de la Cuenta
                    </h5>

                    <div class="mb-4 p-3 rounded-3 bg-dark border @(isSecure ? "border-success" : "border-warning") bg-opacity-10">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi @(isSecure ? "bi-shield-check text-success" : "bi-shield-exclamation text-warning") fs-3 me-3"></i>
                            <div>
                                <h6 class="m-0 fw-bold @(isSecure ? "text-success" : "text-warning")">Estado: @(isSecure ? "Protegida" : "Mejora requerida")</h6>
                                <small class="text-white-50">@(isSecure ? "2FA activo." : "Activa 2FA para mayor seguridad.")</small>
                            </div>
                        </div>
                        <hr class="border-secondary opacity-25">

                        <div class="row g-2 small">
                            <div class="col-6">
                                <span class="text-white-50 d-block fw-bold mb-1">REGISTRO:</span>
                                <span class="text-white">
                                    @(user.RegistrationDate.HasValue && user.RegistrationDate.Value != DateTime.MinValue
                                                                        ? user.RegistrationDate.Value.ToString("dd/MM/yyyy")
                                                                        : "Migración")
                                </span>
                            </div>
                            <div class="col-6">
                                <span class="text-white-50 d-block fw-bold mb-1">ÚLTIMO CAMBIO CLAVE:</span>
                                <span class="text-white">
                                    @(user.LastPasswordChangedDate.HasValue
                                                                        ? user.LastPasswordChangedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                                                        : (user.MustChangePassword ? "Requerido" : "Sin cambios"))
                                </span>
                            </div>
                        </div>
                    </div>

                    <form id="profile-form" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control bg-dark border-secondary text-white-50 shadow-none" disabled />
                            <label asp-for="Username">Email / Usuario</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input asp-for="Input.PhoneNumber" class="form-control bg-dark border-secondary text-white shadow-none" placeholder="Teléfono" />
                            <label asp-for="Input.PhoneNumber">Teléfono de Contacto</label>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-pill text-dark shadow-sm">
                            <i class="bi bi-save2 me-2"></i>ACTUALIZAR INFORMACIÓN
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="card bg-black border-secondary h-100 p-4 shadow-sm">
                    <h5 class="text-white mb-4 small text-uppercase fw-bold border-bottom border-secondary pb-2">
                        <i class="bi bi-clock-history text-warning me-2"></i>Última Actividad
                    </h5>
                    @if (userSummaries.Any())
                    {
                        <div class="list-group list-group-flush bg-transparent">
                            @foreach (var summary in userSummaries.Take(4))
                            {
                                <div class="list-group-item bg-transparent border-secondary px-0 text-white-50 py-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-dark p-2 rounded-2 border border-secondary me-3 text-warning">
                                                <i class="bi bi-file-earmark-medical"></i>
                                            </div>
                                            <div>
                                                <span class="text-white d-block small fw-bold">@summary.AnalysisTimestamp.ToString("dd/MM/yyyy HH:mm")</span>
                                                <span class="small text-muted">Análisis realizado con éxito</span>
                                            </div>
                                        </div>
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2">
                                            @(summary.CriticalCount + summary.WarningCount) hallazgos
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="text-center mt-4">
                            <a asp-controller="Home" asp-action="History" class="text-warning small text-decoration-none fw-bold">
                                VER HISTORIAL COMPLETO <i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-folder-x text-muted fs-1 mb-2 d-block"></i>
                            <p class="text-muted small">No hay actividad reciente.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Inicializar tooltips de Bootstrap
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
          return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}

@section Styles {
    <style>
        .form-floating > label {
            color: #888;
        }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: #ffc107 !important;
            font-weight: bold;
        }

        .card-stat {
            transition: transform 0.2s ease;
        }

            .card-stat:hover {
                transform: translateY(-3px);
            }

        .progress-bar {
            transition: width 1s ease-in-out;
        }

        .list-group-item:last-child {
            border-bottom: none;
        }
    </style>
}
